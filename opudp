#!/bin/bash
# ============================================================
#  OPUDP — ZIVPN UDP Ultimate Control Panel 🔥 FIRE EDITION
#  Author  : OfficialOnePesewa
#  GitHub  : https://github.com/OfficialOnePesewa/udp-opudp
#  Command : opudp
#  Version : 4.1.0
# ============================================================
#
#  DB FORMAT:
#  username:password:expiry:quota_mb:max_conn:created_date
#
#  BANDWIDTH FILES (all in /etc/zivpn/bwused/):
#    USERNAME          → cumulative bytes used  (NEVER auto-reset)
#    .USERNAME_raw     → last iptables snapshot (bytes, for delta calc)
#    .USERNAME_blocked → exists when quota exhausted
#
#  HOW COUNTING WORKS:
#    Every 60s (cron) → read iptables byte counters per connected IP
#    delta = current_bytes - last_snapshot
#    If iptables reset (reboot/restart) → current < last → delta = current
#    delta is ADDED to cumulative file → never lost across reboots
#
#  QUOTA ENFORCEMENT:
#    Once cumulative_bytes >= quota_mb * 1048576 → user blocked
#    Block = remove password from config.json + restart ZIVPN
#    Unblock = admin resets bandwidth via option 12
# ============================================================

CONFIG="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
PORT_FILE="/etc/zivpn/port_range"
BACKUP_DIR="/etc/zivpn/backups"
SESSIONS_DIR="/etc/zivpn/sessions"
CONN_LOG="/etc/zivpn/connections.log"
TRIALS_DB="/etc/zivpn/trials.db"
LASTSEEN_DIR="/etc/zivpn/lastseen"
BWUSED_DIR="/etc/zivpn/bwused"
BW_LOCK="/etc/zivpn/.bwlock"
SVC="zivpn"
BIN="/usr/local/bin/zivpn"
LISTEN_PORT="5667"
PANEL_VERSION="4.1.0"
GITHUB_RAW="https://raw.githubusercontent.com/OfficialOnePesewa/udp-opudp/main"
BWMON_SCRIPT="/usr/local/bin/opudp-bwmon"
BWMON_CRON="/etc/cron.d/opudp-bwmon"

# ── 🔥 FIRE COLOURS ───────────────────────────────────────────
FR='\033[38;5;196m'
OR='\033[38;5;208m'
GO='\033[38;5;220m'
YW='\033[1;33m'
W='\033[1;37m'
DIM='\033[2;37m'
G='\033[0;32m'
R='\033[0;31m'
NC='\033[0m'

# ══════════════════════════════════════════════════════════════
#  BACKGROUND BANDWIDTH MONITOR (called by cron every minute)
# ══════════════════════════════════════════════════════════════
if [[ "$1" == "--bwmon" ]]; then

    # ── lock so two ticks never run simultaneously ─────────────
    exec 9>"$BW_LOCK"
    flock -n 9 || exit 0

    [[ ! -f "$USERS_DB" ]] && exit 0

    # Ensure chain exists and is hooked
    iptables -N ZIVPN_BW 2>/dev/null
    iptables -C INPUT  -j ZIVPN_BW 2>/dev/null || iptables -I INPUT  -j ZIVPN_BW
    iptables -C OUTPUT -j ZIVPN_BW 2>/dev/null || iptables -I OUTPUT -j ZIVPN_BW

    # ── snapshot all byte counters from iptables-save -c ───────
    # iptables-save -c outputs lines like:
    #   [pkts:bytes] -A ZIVPN_BW ... -m comment --comment "TAG"
    IPTABLES_SNAP=$(iptables-save -c 2>/dev/null)

    # Helper: read bytes for a specific comment tag
    _bytes_for_tag() {
        local tag="$1"
        # Match the line, extract the bytes field (second number in [pkts:bytes])
        echo "$IPTABLES_SNAP" | grep "\"${tag}\"" | \
            grep -o '^\[[0-9]*:[0-9]*\]' | \
            cut -d: -f2 | tr -d ']' | head -1
    }

    # ── for each active session IP, add bytes to user's counter ─
    while IFS=':' read -r u p e quota mc cd; do
        [[ -z "$u" || -z "$p" ]] && continue

        local used_file="${BWUSED_DIR}/${u}"
        local raw_file="${BWUSED_DIR}/.${u}_raw"

        # Init cumulative file (bytes) if first time
        [[ ! -f "$used_file" ]] && echo "0" > "$used_file"

        # Get IPs for this user from sessions file
        local sfile="${SESSIONS_DIR}/${p}.sessions"

        # Collect total iptables bytes across all IPs for this user
        local iptables_total=0

        if [[ -f "$sfile" ]]; then
            while read -r ip; do
                [[ -z "$ip" ]] && continue
                local tag_in="zivpn_bw_${u}_in_${ip}"
                local tag_out="zivpn_bw_${u}_out_${ip}"
                local b_in b_out
                b_in=$(_bytes_for_tag "$tag_in")
                b_out=$(_bytes_for_tag "$tag_out")
                [[ -z "$b_in"  || ! "$b_in"  =~ ^[0-9]+$ ]] && b_in=0
                [[ -z "$b_out" || ! "$b_out" =~ ^[0-9]+$ ]] && b_out=0
                iptables_total=$(( iptables_total + b_in + b_out ))
            done < "$sfile"
        else
            # Fallback: count ALL traffic on LISTEN_PORT attributed to this user
            # (works when only one user or as aggregate)
            local b_in b_out
            b_in=$(_bytes_for_tag "zivpn_bw_${u}_in")
            b_out=$(_bytes_for_tag "zivpn_bw_${u}_out")
            [[ -z "$b_in"  || ! "$b_in"  =~ ^[0-9]+$ ]] && b_in=0
            [[ -z "$b_out" || ! "$b_out" =~ ^[0-9]+$ ]] && b_out=0
            iptables_total=$(( b_in + b_out ))
        fi

        # ── delta calculation (SURVIVES iptables resets) ────────
        local prev_snapshot=0
        [[ -f "$raw_file" ]] && {
            prev_snapshot=$(cat "$raw_file" 2>/dev/null)
            [[ ! "$prev_snapshot" =~ ^[0-9]+$ ]] && prev_snapshot=0
        }

        local delta=0
        if [[ $iptables_total -ge $prev_snapshot ]]; then
            # Normal case: counter went up since last tick
            delta=$(( iptables_total - prev_snapshot ))
        else
            # iptables was reset (restart/reboot) — counter is below
            # what we last saw. Count everything since reset as new delta.
            delta=$iptables_total
        fi

        # ALWAYS update snapshot so next tick has correct baseline
        echo "$iptables_total" > "$raw_file"

        # Add delta bytes to cumulative file (bytes, never decreases)
        if [[ $delta -gt 0 ]]; then
            local current_bytes
            current_bytes=$(cat "$used_file" 2>/dev/null || echo 0)
            [[ ! "$current_bytes" =~ ^[0-9]+$ ]] && current_bytes=0
            echo $(( current_bytes + delta )) > "$used_file"
        fi

    done < "$USERS_DB"

    # ── quota enforcement pass ──────────────────────────────────
    local rebuild_needed=0
    while IFS=':' read -r u p e quota mc cd; do
        [[ -z "$u" || -z "$p" ]] && continue
        [[ -z "$quota" || "$quota" -eq 0 ]] && continue   # unlimited

        local used_bytes quota_bytes flag_file
        used_bytes=$(cat "${BWUSED_DIR}/${u}" 2>/dev/null || echo 0)
        [[ ! "$used_bytes" =~ ^[0-9]+$ ]] && used_bytes=0
        quota_bytes=$(( quota * 1048576 ))
        flag_file="${BWUSED_DIR}/.${u}_blocked"

        if [[ $used_bytes -ge $quota_bytes ]]; then
            if [[ ! -f "$flag_file" ]]; then
                touch "$flag_file"
                rebuild_needed=1
                echo "[$(date)] BLOCKED: ${u} used $(( used_bytes/1048576 ))MB of ${quota}MB quota" \
                    >> /etc/zivpn/bwmon.log
            fi
        fi
    done < "$USERS_DB"

    # Rebuild config and restart if any user was just blocked
    if [[ $rebuild_needed -eq 1 ]]; then
        local pwds=()
        while IFS=':' read -r u p e quota mc cd; do
            [[ -z "$u" || -z "$p" ]] && continue
            [[ "$e" != "never" && "$e" < "$(date +%Y-%m-%d)" ]] && continue
            [[ -f "${BWUSED_DIR}/.${u}_blocked" ]] && continue
            pwds+=("\"$p\"")
        done < "$USERS_DB"
        local plist=""
        if [[ ${#pwds[@]} -gt 0 ]]; then
            plist=$(printf '%s,' "${pwds[@]}"); plist="${plist%,}"
        fi
        cat > "$CONFIG" << CFGEOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
CFGEOF
        systemctl restart "$SVC" 2>/dev/null
    fi

    flock -u 9
    exit 0
fi

# ── Main panel guard ──────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${R}Run as root: sudo opudp${NC}" && exit 1

# ══════════════════════════════════════════════════════════════
#  INIT
# ══════════════════════════════════════════════════════════════
init() {
    mkdir -p /etc/zivpn "$BACKUP_DIR" "$SESSIONS_DIR" \
             "$LASTSEEN_DIR" "$BWUSED_DIR"
    [[ ! -f "$USERS_DB"  ]] && touch "$USERS_DB"
    [[ ! -f "$PORT_FILE" ]] && echo "6000:19999" > "$PORT_FILE"
    [[ ! -f "$CONN_LOG"  ]] && touch "$CONN_LOG"
    [[ ! -f "$TRIALS_DB" ]] && touch "$TRIALS_DB"
    migrate_db
    check_trials
    install_bwmon
    setup_bw_chain
}

migrate_db() {
    local tmp changed=0
    tmp=$(mktemp)
    local TODAY; TODAY=$(date +%Y-%m-%d)
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0   && changed=1
        [[ -z "$cd" ]] && cd="$TODAY" && changed=1
        [[ -z "$bw" ]] && bw=0   && changed=1
        echo "${u}:${p}:${e}:${bw}:${mc}:${cd}" >> "$tmp"
        # Init bytes file if missing (preserves existing value)
        [[ ! -f "${BWUSED_DIR}/${u}" ]] && echo "0" > "${BWUSED_DIR}/${u}"
    done < "$USERS_DB"
    [[ $changed -eq 1 ]] && mv "$tmp" "$USERS_DB" || rm -f "$tmp"
}

install_bwmon() {
    # Write monitor wrapper
    cat > "$BWMON_SCRIPT" << 'BWMON'
#!/bin/bash
/usr/local/bin/opudp --bwmon
BWMON
    chmod +x "$BWMON_SCRIPT"
    # Install cron if missing
    if [[ ! -f "$BWMON_CRON" ]]; then
        echo "* * * * * root ${BWMON_SCRIPT} >> /etc/zivpn/bwmon.log 2>&1" \
            > "$BWMON_CRON"
        chmod 644 "$BWMON_CRON"
    fi
}

setup_bw_chain() {
    iptables -N ZIVPN_BW 2>/dev/null
    iptables -C INPUT  -j ZIVPN_BW 2>/dev/null || iptables -I INPUT  -j ZIVPN_BW
    iptables -C OUTPUT -j ZIVPN_BW 2>/dev/null || iptables -I OUTPUT -j ZIVPN_BW
}

# Add iptables accounting rules for a user IP
add_bw_rules_for_ip() {
    local ip="$1" username="$2"
    local tag_in="zivpn_bw_${username}_in_${ip}"
    local tag_out="zivpn_bw_${username}_out_${ip}"
    iptables -C ZIVPN_BW -s "$ip" -p udp --sport "$LISTEN_PORT" \
        -m comment --comment "$tag_in" -j RETURN 2>/dev/null || \
    iptables -A ZIVPN_BW -s "$ip" -p udp --sport "$LISTEN_PORT" \
        -m comment --comment "$tag_in" -j RETURN 2>/dev/null
    iptables -C ZIVPN_BW -d "$ip" -p udp --dport "$LISTEN_PORT" \
        -m comment --comment "$tag_out" -j RETURN 2>/dev/null || \
    iptables -A ZIVPN_BW -d "$ip" -p udp --dport "$LISTEN_PORT" \
        -m comment --comment "$tag_out" -j RETURN 2>/dev/null
}

# ══════════════════════════════════════════════════════════════
#  BANDWIDTH HELPERS
# ══════════════════════════════════════════════════════════════

# Returns raw bytes used (stored as bytes for precision)
get_used_bytes() {
    local username="$1"
    local f="${BWUSED_DIR}/${username}"
    [[ ! -f "$f" ]] && echo "0" && return
    local v; v=$(cat "$f" 2>/dev/null)
    [[ "$v" =~ ^[0-9]+$ ]] && echo "$v" || echo "0"
}

# Returns MB used (converted from bytes)
get_used_mb() {
    local bytes; bytes=$(get_used_bytes "$1")
    echo $(( bytes / 1048576 ))
}

# Reset a user's bandwidth counter completely
reset_bw() {
    local username="$1"
    echo "0" > "${BWUSED_DIR}/${username}"
    rm -f "${BWUSED_DIR}/.${username}_raw"     2>/dev/null
    rm -f "${BWUSED_DIR}/.${username}_blocked" 2>/dev/null
}

# Is this user blocked due to quota exhaustion?
is_bw_blocked() {
    [[ -f "${BWUSED_DIR}/.${1}_blocked" ]] && return 0
    return 1
}

# Format bytes → human readable (KB / MB / GB)
fmt_bytes() {
    local b="$1"
    if [[ $b -ge 1073741824 ]]; then
        echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [[ $b -ge 1048576 ]]; then
        echo "$(echo "scale=1; $b/1048576" | bc) MB"
    elif [[ $b -ge 1024 ]]; then
        echo "$(echo "scale=0; $b/1024" | bc) KB"
    else
        echo "${b} B"
    fi
}

# Format MB quota → human readable
fmt_mb() {
    local mb="$1"
    if [[ $mb -eq 0 ]]; then
        echo "Unlimited"
    elif [[ $mb -ge 1024 ]]; then
        echo "$(echo "scale=1; $mb/1024" | bc) GB"
    else
        echo "${mb} MB"
    fi
}

# Colour-coded progress bar  [████░░░░░░] 40%
# Args: used_bytes  quota_mb (0 = unlimited)
bw_bar() {
    local used_b="$1" quota_mb="$2"
    if [[ "$quota_mb" -eq 0 ]]; then
        echo -e "${G}[∞ Unlimited]${NC}"; return
    fi
    local quota_b=$(( quota_mb * 1048576 ))
    local pct=$(( used_b * 100 / quota_b ))
    [[ $pct -gt 100 ]] && pct=100
    local filled=$(( pct * 20 / 100 ))   # 20-char bar
    local empty=$(( 20 - filled ))
    local bar="" i
    for (( i=0; i<filled; i++ )); do bar+="█"; done
    for (( i=0; i<empty;  i++ )); do bar+="░"; done
    local colour
    if   [[ $pct -ge 90 ]]; then colour="$FR"
    elif [[ $pct -ge 70 ]]; then colour="$OR"
    elif [[ $pct -ge 50 ]]; then colour="$YW"
    else                          colour="$G"
    fi
    echo -e "${colour}[${bar}] ${pct}%${NC}"
}

# Full bandwidth summary line for a user
# e.g.  "Used: 1.5 GB  |  Quota: 100 GB  |  Remaining: 98.5 GB"
bw_summary_line() {
    local username="$1" quota_mb="$2"
    local used_bytes used_fmt quota_fmt remaining_fmt remaining_bytes
    used_bytes=$(get_used_bytes "$username")
    used_fmt=$(fmt_bytes "$used_bytes")

    if [[ "$quota_mb" -eq 0 ]]; then
        echo -e "  Used: ${FR}${used_fmt}${NC}  |  Quota: ${G}Unlimited${NC}"
    else
        local quota_bytes=$(( quota_mb * 1048576 ))
        quota_fmt=$(fmt_mb "$quota_mb")
        remaining_bytes=$(( quota_bytes - used_bytes ))
        [[ $remaining_bytes -lt 0 ]] && remaining_bytes=0
        remaining_fmt=$(fmt_bytes "$remaining_bytes")
        echo -e "  Used: ${FR}${used_fmt}${NC}  |  Quota: ${W}${quota_fmt}${NC}  |  Remaining: ${GO}${remaining_fmt}${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  TRIAL MANAGEMENT
# ══════════════════════════════════════════════════════════════
check_trials() {
    [[ ! -s "$TRIALS_DB" ]] && return
    local NOW changed=0; NOW=$(date +%s)
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        if [[ "$NOW" -ge "$te" ]]; then
            sed -i "/^${tu}:/d" "$USERS_DB"            2>/dev/null
            rm -f "${SESSIONS_DIR}/${tp}.sessions"      2>/dev/null
            rm -f "${LASTSEEN_DIR}/${tu}"               2>/dev/null
            rm -f "${BWUSED_DIR}/${tu}"                 2>/dev/null
            rm -f "${BWUSED_DIR}/.${tu}_raw"            2>/dev/null
            rm -f "${BWUSED_DIR}/.${tu}_blocked"        2>/dev/null
            changed=1
        else
            echo "${tu}:${tp}:${te}:${tm}" >> "$tmp"
        fi
    done < "$TRIALS_DB"
    mv "$tmp" "$TRIALS_DB"
    [[ $changed -eq 1 ]] && rebuild_config && systemctl restart "$SVC" 2>/dev/null
}

add_trial_user() {
    fire_header "Trial / Test User (0–60 Minutes)"
    echo -e "  ${OR}Temporary account that auto-expires and auto-removes.${NC}"
    echo ""

    read -rp "  Trial username: " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}Cannot be empty.${NC}" && return
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null && \
        echo -e "${R}Already exists!${NC}" && return

    read -rp "  Password (blank = auto-generate): " password
    password=$(echo "$password" | tr -d ' ')
    if [[ -z "$password" ]]; then
        password="trial-$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c6)"
        echo -e "  ${GO}Auto password: ${W}${password}${NC}"
    fi

    echo ""
    echo -e "  ${OR}╔══════════════════════════════════════════╗${NC}"
    echo -e "  ${OR}║${GO}       TRIAL DURATION OPTIONS             ${OR}║${NC}"
    echo -e "  ${OR}╠══════════════════════════════════════════╣${NC}"
    echo -e "  ${OR}║${NC}  1)  5  min    2)  10 min               ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  3)  15 min    4)  20 min               ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  5)  30 min    6)  45 min               ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  7)  60 min    8)  Custom (1–60 min)    ${OR}║${NC}"
    echo -e "  ${OR}╚══════════════════════════════════════════╝${NC}"
    read -rp "  Choose [1-8]: " tchoice
    local minutes
    case $tchoice in
        1) minutes=5  ;; 2) minutes=10 ;; 3) minutes=15 ;;
        4) minutes=20 ;; 5) minutes=30 ;; 6) minutes=45 ;;
        7) minutes=60 ;;
        8) read -rp "  Enter minutes (1–60): " minutes
           [[ ! "$minutes" =~ ^[0-9]+$ || $minutes -lt 1 || $minutes -gt 60 ]] && \
               echo -e "${R}Invalid.${NC}" && return ;;
        *) echo -e "${R}Invalid.${NC}" && return ;;
    esac

    local NOW expiry_epoch expiry_date TODAY
    NOW=$(date +%s)
    expiry_epoch=$(( NOW + minutes * 60 ))
    expiry_date=$(date -d "@${expiry_epoch}" +%Y-%m-%d)
    TODAY=$(date +%Y-%m-%d)

    echo "${username}:${password}:${expiry_date}:0:0:${TODAY}" >> "$USERS_DB"
    echo "${username}:${password}:${expiry_epoch}:${minutes}"  >> "$TRIALS_DB"
    echo "0" > "${BWUSED_DIR}/${username}"

    rebuild_config && systemctl restart "$SVC" 2>/dev/null

    local si; si=$(get_server_info)
    local srv_ip country city flag ends_at
    srv_ip=$(echo "$si"|cut -d'|' -f1)
    country=$(echo "$si"|cut -d'|' -f2)
    city=$(echo "$si"|cut -d'|' -f4)
    flag=$(echo "$si"|cut -d'|' -f5)
    ends_at=$(date -d "@${expiry_epoch}" "+%H:%M:%S")

    echo ""
    echo -e "${OR}  ╔═══════════════════════════════════════════╗${NC}"
    echo -e "${OR}  ║${GO}  ⚡ TRIAL USER CREATED!                  ${OR}║${NC}"
    echo -e "${OR}  ╠═══════════════════════════════════════════╣${NC}"
    echo -e "${OR}  ║${NC}  Password   : ${GO}${password}${NC}"
    echo -e "${OR}  ║${NC}  Duration   : ${GO}${minutes} minutes${NC}"
    echo -e "${OR}  ║${NC}  Expires At : ${FR}${ends_at}${NC}"
    echo -e "${OR}  ║${NC}  Server     : ${GO}${srv_ip}${NC}  ${flag} ${country}${NC}"
    echo -e "${OR}  ╚═══════════════════════════════════════════╝${NC}"
    _print_copy_block "$srv_ip" "$flag" "$country" "$city" \
        "$password" "⏱ ${minutes} min trial — expires ${ends_at}" \
        "Unlimited" "Unlimited" "TRIAL"
    echo ""
    echo -e "  ${GO}Live countdown (Ctrl+C to exit)...${NC}"
    local remaining
    while true; do
        check_trials
        remaining=$(( expiry_epoch - $(date +%s) ))
        [[ $remaining -le 0 ]] && \
            echo -e "\r  ${FR}⏰ Trial EXPIRED — '${username}' removed!         ${NC}" && \
            echo "" && break
        printf "\r  ${OR}⏱  ${GO}%02d:%02d${OR} remaining (mm:ss)   ${NC}" \
            $(( remaining/60 )) $(( remaining%60 ))
        sleep 1
    done
}

list_trials() {
    [[ ! -s "$TRIALS_DB" ]] && echo -e "  ${DIM}No active trials.${NC}" && return
    local NOW; NOW=$(date +%s)
    echo ""
    printf "  %-18s %-20s %-8s %s\n" "USERNAME" "PASSWORD" "MINS" "EXPIRES IN"
    fire_divider
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        local rem=$(( te - NOW ))
        printf "  %-18s %-20s %-8s " "$tu" "$tp" "${tm}m"
        if [[ $rem -le 0 ]]; then
            echo -e "${R}EXPIRED${NC}"
        else
            echo -e "${GO}$(( rem/60 ))m $(( rem%60 ))s left${NC}"
        fi
    done < "$TRIALS_DB"
}

# ══════════════════════════════════════════════════════════════
#  CORE HELPERS
# ══════════════════════════════════════════════════════════════
get_ip()   { curl -s4 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'; }
get_port() { cat "$PORT_FILE" 2>/dev/null || echo "6000:19999"; }
today()    { date +%Y-%m-%d; }
pause()    { echo ""; read -rp "  Press Enter to continue..."; }

fire_divider() { echo -e "${OR}  ══════════════════════════════════════════════════════════${NC}"; }
fire_header()  {
    echo -e "${OR}  ╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${OR}  ║${GO}  🔥  ${W}${1}${OR}"
    echo -e "${OR}  ╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

is_expired() {
    [[ "$1" == "never" ]] && return 1
    [[ "$1" < "$(today)" ]] && return 0
    return 1
}

days_left() {
    [[ "$1" == "never" ]] && echo "∞" && return
    local dl=$(( ( $(date -d "$1" +%s 2>/dev/null || echo 0) - $(date +%s) ) / 86400 ))
    [[ $dl -lt 0 ]] && echo "0" || echo "$dl"
}

days_used() {
    [[ -z "$1" || "$1" == "?" ]] && echo "?" && return
    local du=$(( ( $(date +%s) - $(date -d "$1" +%s 2>/dev/null || echo 0) ) / 86400 ))
    [[ $du -lt 0 ]] && echo "0" || echo "$du"
}

update_lastseen() { date +%s > "${LASTSEEN_DIR}/${1}" 2>/dev/null; }

get_lastseen() {
    local f="${LASTSEEN_DIR}/${1}"
    [[ ! -f "$f" ]] && echo "Never" && return
    local e; e=$(cat "$f" 2>/dev/null)
    date -d "@${e}" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "Unknown"
}

count_active() {
    local n=0
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        is_expired "$e"   && continue
        is_bw_blocked "$u" && continue
        n=$(( n+1 ))
    done < "$USERS_DB"
    echo "$n"
}

count_live_connections() {
    ss -u state established 2>/dev/null | grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u | wc -l
}

get_connected_ips() {
    ss -u state established 2>/dev/null | grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u
}

count_trials() {
    [[ ! -s "$TRIALS_DB" ]] && echo "0" && return
    local NOW n=0; NOW=$(date +%s)
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        [[ $NOW -lt $te ]] && n=$(( n+1 ))
    done < "$TRIALS_DB"
    echo "$n"
}

rebuild_config() {
    local pwds=()
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" || -z "$p" ]] && continue
        is_expired "$e"    && continue
        is_bw_blocked "$u" && continue
        pwds+=("\"$p\"")
    done < "$USERS_DB"
    local plist=""
    [[ ${#pwds[@]} -gt 0 ]] && {
        plist=$(printf '%s,' "${pwds[@]}"); plist="${plist%,}"
    }
    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
EOF
}

apply_conn_limits() {
    iptables -L INPUT --line-numbers -n 2>/dev/null | grep "connlimit" | \
        awk '{print $1}' | sort -rn | xargs -I{} iptables -D INPUT {} 2>/dev/null
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" || "$mc" -le 0 ]] && continue
        is_expired "$e" && continue
        iptables -A INPUT -p udp --dport "$LISTEN_PORT" \
            -m connlimit --connlimit-above "$mc" --connlimit-mask 32 \
            -j REJECT --reject-with icmp-port-unreachable 2>/dev/null
    done < "$USERS_DB"
}

refresh_activity() {
    local live_ips; live_ips=$(get_connected_ips)
    [[ -z "$live_ips" ]] && return
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        local sfile="${SESSIONS_DIR}/${p}.sessions"
        [[ ! -f "$sfile" ]] && continue
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            echo "$live_ips" | grep -q "^${ip}$" && {
                update_lastseen "$u"
                add_bw_rules_for_ip "$ip" "$u"
                break
            }
        done < "$sfile"
    done < "$USERS_DB"
}

# ── Country/flag detection ────────────────────────────────────
country_code_to_flag() {
    local code="${1^^}" flag="" i
    for (( i=0; i<${#code}; i++ )); do
        local ord; ord=$(printf '%d' "'${code:$i:1}")
        flag+=$(python3 -c \
            "import sys;sys.stdout.buffer.write(chr(${ord}+127397).encode('utf-8'))" \
            2>/dev/null || echo "")
    done
    echo "$flag"
}

get_server_info() {
    local cache="/etc/zivpn/.server_info_cache"
    if [[ -f "$cache" ]]; then
        local now_t cached_t
        now_t=$(date +%s); cached_t=$(stat -c %Y "$cache" 2>/dev/null || echo 0)
        [[ $(( now_t - cached_t )) -lt 3600 ]] && cat "$cache" && return
    fi
    local ip country country_code city flag raw
    raw=$(curl -s --max-time 5 \
        "http://ip-api.com/json/?fields=status,country,countryCode,city,query" 2>/dev/null)
    if echo "$raw" | grep -q '"status":"success"'; then
        ip=$(echo "$raw"|grep -o '"query":"[^"]*"'|cut -d'"' -f4)
        country=$(echo "$raw"|grep -o '"country":"[^"]*"'|cut -d'"' -f4)
        country_code=$(echo "$raw"|grep -o '"countryCode":"[^"]*"'|cut -d'"' -f4)
        city=$(echo "$raw"|grep -o '"city":"[^"]*"'|cut -d'"' -f4)
        flag=$(country_code_to_flag "$country_code")
    else
        raw=$(curl -s --max-time 5 "https://ipinfo.io/json" 2>/dev/null)
        ip=$(echo "$raw"|grep -o '"ip": *"[^"]*"'|cut -d'"' -f4)
        country_code=$(echo "$raw"|grep -o '"country": *"[^"]*"'|cut -d'"' -f4)
        city=$(echo "$raw"|grep -o '"city": *"[^"]*"'|cut -d'"' -f4)
        country="$country_code"; flag=$(country_code_to_flag "$country_code")
        [[ -z "$ip" ]] && ip=$(get_ip)
    fi
    [[ -z "$ip"      ]] && ip=$(get_ip)
    [[ -z "$country" ]] && country="Unknown"
    [[ -z "$city"    ]] && city="Unknown"
    [[ -z "$flag"    ]] && flag="🌐"
    echo "${ip}|${country}|${country_code}|${city}|${flag}" | tee "$cache"
}

