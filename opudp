#  DB FORMAT (v3):
#  username:password:expiry:bandwidth:max_conn:created_date
#
#  TRIALS DB:
#  /etc/zivpn/trials.db → username:password:expiry_epoch:minutes
#
#  ACTIVITY:
#  /etc/zivpn/lastseen/USERNAME → last seen epoch
# ============================================================

CONFIG="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
PORT_FILE="/etc/zivpn/port_range"
BACKUP_DIR="/etc/zivpn/backups"
SESSIONS_DIR="/etc/zivpn/sessions"
CONN_LOG="/etc/zivpn/connections.log"
TRIALS_DB="/etc/zivpn/trials.db"
LASTSEEN_DIR="/etc/zivpn/lastseen"
SVC="zivpn"
BIN="/usr/local/bin/zivpn"
LISTEN_PORT="5667"
PANEL_VERSION="3.0.0"
GITHUB_RAW="https://raw.githubusercontent.com/OfficialOnePesewa/udp-opudp/main"

# ── 🔥 FIRE COLOUR PALETTE ────────────────────────────────────
FR='\033[38;5;196m'   # Fire Red
OR='\033[38;5;208m'   # Orange
GO='\033[38;5;220m'   # Gold
YW='\033[1;33m'       # Yellow
W='\033[1;37m'        # White Bold
DIM='\033[2;37m'      # Dim
G='\033[0;32m'        # Green  (kept for OK/active)
R='\033[0;31m'        # Red    (kept for errors/expired)
NC='\033[0m'          # Reset

# ── Guard ─────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${FR}Run as root: sudo opudp${NC}" && exit 1

# ══════════════════════════════════════════════════════════════
#  INIT & MIGRATION
# ══════════════════════════════════════════════════════════════
init() {
    mkdir -p /etc/zivpn "$BACKUP_DIR" "$SESSIONS_DIR" "$LASTSEEN_DIR"
    [[ ! -f "$USERS_DB"  ]] && touch "$USERS_DB"
    [[ ! -f "$PORT_FILE" ]] && echo "6000:19999" > "$PORT_FILE"
    [[ ! -f "$CONN_LOG"  ]] && touch "$CONN_LOG"
    [[ ! -f "$TRIALS_DB" ]] && touch "$TRIALS_DB"
    migrate_db
    check_trials
}

# Migrate DB: add max_conn and created_date if missing
migrate_db() {
    local tmp changed=0
    tmp=$(mktemp)
    local TODAY
    TODAY=$(date +%Y-%m-%d)
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0 && changed=1
        [[ -z "$cd" ]] && cd="$TODAY" && changed=1
        echo "${u}:${p}:${e}:${bw}:${mc}:${cd}" >> "$tmp"
    done < "$USERS_DB"
    [[ $changed -eq 1 ]] && mv "$tmp" "$USERS_DB" || rm -f "$tmp"
}

# ══════════════════════════════════════════════════════════════
#  TRIAL MANAGEMENT
# ══════════════════════════════════════════════════════════════
check_trials() {
    [[ ! -s "$TRIALS_DB" ]] && return
    local NOW changed=0
    NOW=$(date +%s)
    local tmp
    tmp=$(mktemp)
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        if [[ "$NOW" -ge "$te" ]]; then
            sed -i "/^${tu}:/d" "$USERS_DB" 2>/dev/null
            rm -f "${SESSIONS_DIR}/${tp}.sessions" 2>/dev/null
            rm -f "${LASTSEEN_DIR}/${tu}" 2>/dev/null
            changed=1
        else
            echo "${tu}:${tp}:${te}:${tm}" >> "$tmp"
        fi
    done < "$TRIALS_DB"
    mv "$tmp" "$TRIALS_DB"
    if [[ $changed -eq 1 ]]; then
        rebuild_config
        systemctl restart "$SVC" 2>/dev/null
    fi
}

add_trial_user() {
    fire_header "Trial / Test User (0–60 Minutes)"
    echo ""
    echo -e "  ${OR}Create a temporary test account that auto-expires.${NC}"
    echo -e "  ${DIM}Perfect for demos, testing connections, short access.${NC}"
    echo ""

    read -rp "  Trial username (e.g. test1): " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}Username cannot be empty.${NC}" && return
    if grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}User '${username}' already exists!${NC}"; return
    fi

    read -rp "  Password (leave blank to auto-generate): " password
    password=$(echo "$password" | tr -d ' ')
    if [[ -z "$password" ]]; then
        password="trial-$(tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c6)"
        echo -e "  ${GO}Auto-generated password: ${W}${password}${NC}"
    fi

    echo ""
    echo -e "  ${OR}╔══════════════════════════════════════════╗${NC}"
    echo -e "  ${OR}║${GO}       TRIAL DURATION OPTIONS             ${OR}║${NC}"
    echo -e "  ${OR}╠══════════════════════════════════════════╣${NC}"
    echo -e "  ${OR}║${NC}  1)  5  minutes   2)  10 minutes         ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  3)  15 minutes   4)  20 minutes         ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  5)  30 minutes   6)  45 minutes         ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  7)  60 minutes   8)  Custom (0–60 min)  ${OR}║${NC}"
    echo -e "  ${OR}╚══════════════════════════════════════════╝${NC}"
    echo ""
    read -rp "  Choose [1-8]: " tchoice
    local minutes
    case $tchoice in
        1) minutes=5   ;;
        2) minutes=10  ;;
        3) minutes=15  ;;
        4) minutes=20  ;;
        5) minutes=30  ;;
        6) minutes=45  ;;
        7) minutes=60  ;;
        8)
            read -rp "  Enter minutes (1–60): " minutes
            if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [[ "$minutes" -lt 1 || "$minutes" -gt 60 ]]; then
                echo -e "${R}Invalid. Must be 1–60 minutes.${NC}"; return
            fi
            ;;
        *) echo -e "${R}Invalid choice.${NC}"; return ;;
    esac

    local NOW expiry_epoch expiry_date
    NOW=$(date +%s)
    expiry_epoch=$((NOW + minutes * 60))
    expiry_date=$(date -d "@${expiry_epoch}" +%Y-%m-%d)
    local TODAY
    TODAY=$(date +%Y-%m-%d)

    echo "${username}:${password}:${expiry_date}:0:0:${TODAY}" >> "$USERS_DB"
    echo "${username}:${password}:${expiry_epoch}:${minutes}" >> "$TRIALS_DB"

    rebuild_config
    systemctl restart "$SVC" 2>/dev/null

    local server_ip ends_at
    server_ip=$(get_ip)
    ends_at=$(date -d "@${expiry_epoch}" "+%H:%M:%S")

    echo ""
    echo -e "${OR}  ╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${OR}  ║${GO}  🔥  TRIAL USER CREATED SUCCESSFULLY!  🔥        ${OR}║${NC}"
    echo -e "${OR}  ╠═══════════════════════════════════════════════════╣${NC}"
    echo -e "${OR}  ║${NC}  Username   : ${GO}${username}${NC}"
    echo -e "${OR}  ║${NC}  Password   : ${GO}${password}${NC}"
    echo -e "${OR}  ║${NC}  Duration   : ${GO}${minutes} minutes${NC}"
    echo -e "${OR}  ║${NC}  Expires At : ${FR}${ends_at} today${NC}"
    echo -e "${OR}  ║${NC}  Server IP  : ${GO}${server_ip}${NC}"
    echo -e "${OR}  ╠═══════════════════════════════════════════════════╣${NC}"
    echo -e "${OR}  ║${DIM}  Auto-removed when expired. No manual cleanup.    ${OR}║${NC}"
    echo -e "${OR}  ╚═══════════════════════════════════════════════════╝${NC}"
    echo ""

    echo -e "  ${GO}Watching trial countdown (Ctrl+C to go back)...${NC}"
    echo ""
    local remaining
    while true; do
        check_trials
        remaining=$((expiry_epoch - $(date +%s)))
        if [[ $remaining -le 0 ]]; then
            echo -e "\r  ${FR}⏰ Trial EXPIRED — user '${username}' removed!         ${NC}"
            echo ""
            break
        fi
        local mins=$((remaining / 60))
        local secs=$((remaining % 60))
        printf "\r  ${OR}⏱  Time remaining: ${GO}%02d:%02d${OR} (mm:ss)   ${NC}" "$mins" "$secs"
        sleep 1
    done
}

list_trials() {
    [[ ! -s "$TRIALS_DB" ]] && echo -e "  ${DIM}No active trials.${NC}" && return
    local NOW
    NOW=$(date +%s)
    echo ""
    printf "  %-18s %-20s %-8s %s\n" "USERNAME" "PASSWORD" "MINS" "EXPIRES IN"
    fire_divider
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        local rem=$((te - NOW))
        if [[ $rem -le 0 ]]; then
            printf "  %-18s %-20s %-8s " "$tu" "$tp" "${tm}m"
            echo -e "${R}EXPIRED${NC}"
        else
            local rm=$((rem / 60)); local rs=$((rem % 60))
            printf "  %-18s %-20s %-8s " "$tu" "$tp" "${tm}m"
            echo -e "${GO}${rm}m ${rs}s remaining${NC}"
        fi
    done < "$TRIALS_DB"
}

# ══════════════════════════════════════════════════════════════
#  HELPERS
# ══════════════════════════════════════════════════════════════
get_ip()   { curl -s4 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'; }
get_port() { cat "$PORT_FILE" 2>/dev/null || echo "6000:19999"; }
today()    { date +%Y-%m-%d; }
pause()    { echo ""; read -rp "  Press Enter to continue..."; }

fire_divider() {
    echo -e "${OR}  ══════════════════════════════════════════════════════════${NC}"
}

fire_header() {
    echo -e "${OR}  ╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${OR}  ║${GO}  🔥  ${W}$1${OR}"
    echo -e "${OR}  ╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

is_expired() {
    local exp="$1"
    [[ "$exp" == "never" ]] && return 1
    [[ "$exp" < "$(today)" ]] && return 0
    return 1
}

days_left() {
    local exp="$1"
    [[ "$exp" == "never" ]] && echo "∞" && return
    local now_s exp_s
    now_s=$(date +%s)
    exp_s=$(date -d "$exp" +%s 2>/dev/null) || { echo "?"; return; }
    local dl=$(( (exp_s - now_s) / 86400 ))
    [[ $dl -lt 0 ]] && echo "0" || echo "$dl"
}

days_used() {
    local created="$1"
    [[ -z "$created" || "$created" == "?" ]] && echo "?" && return
    local now_s cr_s
    now_s=$(date +%s)
    cr_s=$(date -d "$created" +%s 2>/dev/null) || { echo "?"; return; }
    local du=$(( (now_s - cr_s) / 86400 ))
    [[ $du -lt 0 ]] && echo "0" || echo "$du"
}

update_lastseen() {
    local username="$1"
    date +%s > "${LASTSEEN_DIR}/${username}" 2>/dev/null
}

get_lastseen() {
    local username="$1"
    local f="${LASTSEEN_DIR}/${username}"
    [[ ! -f "$f" ]] && echo "Never" && return
    local epoch
    epoch=$(cat "$f" 2>/dev/null)
    [[ -z "$epoch" ]] && echo "Never" && return
    date -d "@${epoch}" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "Unknown"
}

count_active() {
    local n=0
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        is_expired "$e" || n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

count_live_connections() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u | wc -l
}

get_connected_ips() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u
}

count_trials() {
    [[ ! -s "$TRIALS_DB" ]] && echo "0" && return
    local NOW n=0
    NOW=$(date +%s)
    while IFS=':' read -r tu tp te tm; do
        [[ -z "$tu" ]] && continue
        [[ "$NOW" -lt "$te" ]] && n=$((n+1))
    done < "$TRIALS_DB"
    echo "$n"
}

rebuild_config() {
    local pwds=()
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" || -z "$p" ]] && continue
        is_expired "$e" || pwds+=("\"$p\"")
    done < "$USERS_DB"
    local plist=""
    if [[ ${#pwds[@]} -gt 0 ]]; then
        plist=$(printf '%s,' "${pwds[@]}")
        plist="${plist%,}"
    fi
    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
EOF
}

apply_conn_limits() {
    iptables -L INPUT --line-numbers -n 2>/dev/null | \
        grep "connlimit" | awk '{print $1}' | sort -rn | \
        xargs -I{} iptables -D INPUT {} 2>/dev/null
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        if [[ "$mc" -gt 0 ]] 2>/dev/null; then
            iptables -A INPUT -p udp --dport "$LISTEN_PORT" \
                -m connlimit --connlimit-above "$mc" --connlimit-mask 32 \
                -j REJECT --reject-with icmp-port-unreachable 2>/dev/null
        fi
    done < "$USERS_DB"
}

refresh_activity() {
    local live_ips
    live_ips=$(get_connected_ips)
    [[ -z "$live_ips" ]] && return
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        local sfile="${SESSIONS_DIR}/${p}.sessions"
        [[ ! -f "$sfile" ]] && continue
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            if echo "$live_ips" | grep -q "^${ip}$"; then
                update_lastseen "$u"
                break
            fi
        done < "$sfile"
    done < "$USERS_DB"
}

