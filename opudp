# ══════════════════════════════════════════════════════════════
#  17) Change Port
# ══════════════════════════════════════════════════════════════
change_port() {
    fire_header "Change UDP Port Range"
    local cur ps pe
    cur=$(get_port); ps=$(echo "$cur"|cut -d: -f1); pe=$(echo "$cur"|cut -d: -f2)
    echo -e "  ${OR}Current: ${GO}${cur}${NC}"; echo ""
    read -rp "  New start: " np1; read -rp "  New end:   " np2
    [[ ! "$np1" =~ ^[0-9]+$ || ! "$np2" =~ ^[0-9]+$ ]] && echo -e "${FR}Not numbers.${NC}" && return
    [[ $np1 -ge $np2 ]] && echo -e "${FR}Start must be less than end.${NC}" && return
    local iface; iface=$(ip -4 route ls|grep default|grep -Po '(?<=dev )(\S+)'|head -1)
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp \
        --dport "${np1}:${np2}" -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${ps}:${pe}/udp" 2>/dev/null
    ufw allow "${np1}:${np2}/udp"      2>/dev/null
    echo "${np1}:${np2}" > "$PORT_FILE"
    echo -e "${G}  ✓ Port range → ${GO}${np1}:${np2}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) Auto-Update
# ══════════════════════════════════════════════════════════════
auto_update() {
    fire_header "Auto-Update ZIVPN + OPUDP"
