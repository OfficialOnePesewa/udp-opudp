# ══════════════════════════════════════════════════════════════
#  5) List Users — card view with live BW bar
# ══════════════════════════════════════════════════════════════
list_users() {
    fire_header "User List — Live BW • Days • Online"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${YW}No users. Use option 6 to add one.${NC}"; return
    fi

    local tc; tc=$(count_trials)
    [[ $tc -gt 0 ]] && {
        echo -e "  ${YW}⚡ Active Trials: ${tc}${NC}"
        list_trials; echo ""; fire_divider; echo ""
    }

    while IFS=':' read -r u p e quota mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"    ]] && mc=0
        [[ -z "$cd"    ]] && cd="?"
        [[ -z "$quota" ]] && quota=0

        local dl du conn_disp online status
        local used_bytes quota_bytes remaining_bytes
        local used_fmt quota_fmt remaining_fmt
        dl=$(days_left "$e")
        du=$(days_used "$cd")
        [[ "$mc" -eq 0 ]] && conn_disp="∞" || conn_disp="$mc"

        # ── Bandwidth figures (bytes for precision) ────────────
        used_bytes=$(get_used_bytes "$u")
        used_fmt=$(fmt_bytes "$used_bytes")
        if [[ "$quota" -eq 0 ]]; then
            quota_fmt="Unlimited"; remaining_fmt="Unlimited"
        else
            quota_bytes=$(( quota * 1048576 ))
            quota_fmt=$(fmt_mb "$quota")
            remaining_bytes=$(( quota_bytes - used_bytes ))
            [[ $remaining_bytes -lt 0 ]] && remaining_bytes=0
            remaining_fmt=$(fmt_bytes "$remaining_bytes")
        fi

        # ── Online check (seen in last 5 min) ─────────────────
        online="${DIM}OFFLINE${NC}"
        local lsf="${LASTSEEN_DIR}/${u}"
        [[ -f "$lsf" ]] && {
            local le; le=$(cat "$lsf" 2>/dev/null)
            [[ $(( $(date +%s) - le )) -le 300 ]] && online="${G}● ONLINE${NC}"
        }

        local is_trial=""
        grep -q "^${u}:" "$TRIALS_DB" 2>/dev/null && is_trial=" ⚡"

        # ── Status ─────────────────────────────────────────────
        if is_bw_blocked "$u"; then
            status="${FR}🚫 DATA EXHAUSTED${NC}"
        elif is_expired "$e"; then
            status="${FR}✗ EXPIRED${NC}"
        elif [[ "$dl" != "∞" && "$dl" -le 1 ]]; then
            status="${FR}⚠ CRITICAL${NC}"
        elif [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
            status="${YW}⚡ EXPIRING${NC}"
        elif [[ "$dl" != "∞" && "$dl" -le 7 ]]; then
            status="${OR}SOON${NC}"
        else
            status="${G}✓ ACTIVE${NC}"
        fi

        # ── Card ───────────────────────────────────────────────
        echo -e "${OR}  ┌────────────────────────────────────────────────────────┐${NC}"
        printf   "  ${OR}│${NC}  ${W}%-16s${NC}  pw: ${GO}%-22s${NC}  conn: %s\n" \
                 "${u}${is_trial}" "$p" "$conn_disp"
        printf   "  ${OR}│${NC}  Status   : "; echo -e "$status"
        printf   "  ${OR}│${NC}  Online   : "; echo -e "$online"
        echo -e  "  ${OR}│${NC}  Days     : ${GO}${du}d used${NC}  —  ${YW}${dl}d left${NC}  (expiry: ${DIM}${e}${NC})"
        echo -e  "  ${OR}│${NC}  Created  : ${DIM}${cd}${NC}"
        echo -e  "  ${OR}│${NC}  ${FR}Used     : ${FR}${used_fmt}${NC}"
        echo -e  "  ${OR}│${NC}  ${W}Quota    : ${W}${quota_fmt}${NC}"
        echo -e  "  ${OR}│${NC}  ${GO}Remaining: ${GO}${remaining_fmt}${NC}"
        echo -ne "  ${OR}│${NC}  BW Bar   : "
        bw_bar "$used_bytes" "$quota"
        echo -e "${OR}  └────────────────────────────────────────────────────────┘${NC}"
        echo ""
    done < "$USERS_DB"
    echo -e "  ${DIM}BW updates every 60s. Survives reboots & ZIVPN restarts.${NC}"
    echo -e "  ${DIM}🚫 DATA EXHAUSTED = blocked until you reset (option 12).${NC}"
}

