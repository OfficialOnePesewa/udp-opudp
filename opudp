# ══════════════════════════════════════════════════════════════
#  15) Backup
# ══════════════════════════════════════════════════════════════
backup_data() {
    echo -e "${C}═══ Backup All Data ═════════════════════════════════════════${NC}"
    local name="opudp_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    local path="${BACKUP_DIR}/${name}"
    tar -czf "$path" /etc/zivpn/ 2>/dev/null
    local size
    size=$(du -sh "$path" 2>/dev/null | cut -f1)
    echo -e "${G}  Backup saved:${NC} ${Y}${path}${NC} (${size})"
}

# ══════════════════════════════════════════════════════════════
#  16) Restore Backup
# ══════════════════════════════════════════════════════════════
restore_backup() {
    echo -e "${C}═══ Restore Backup ══════════════════════════════════════════${NC}"
    local files
    files=$(ls "$BACKUP_DIR"/*.tar.gz 2>/dev/null)
    if [[ -z "$files" ]]; then
        echo -e "  ${Y}No backups found in ${BACKUP_DIR}${NC}"; return
    fi
    echo ""
    echo -e "  Available backups:"
    ls -lh "$BACKUP_DIR"/*.tar.gz 2>/dev/null | awk '{print "  "$9, $5}'
    echo ""
    read -rp "  Enter backup filename: " bname
    local bpath="${BACKUP_DIR}/${bname}"
    if [[ ! -f "$bpath" ]]; then
        echo -e "${R}  File not found.${NC}"; return
    fi
    read -rp "  Restore from '${bname}'? This overwrites current data [y/N]: " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
    tar -xzf "$bpath" -C / 2>/dev/null
    migrate_db
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Restored from ${bname}.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  17) Change Port Range
# ══════════════════════════════════════════════════════════════
change_port() {
    echo -e "${C}═══ Change UDP Port Range ═══════════════════════════════════${NC}"
    local current
    current=$(get_port)
    local old_start old_end
    old_start=$(echo "$current" | cut -d: -f1)
    old_end=$(echo "$current"   | cut -d: -f2)
    echo -e "  Current range: ${Y}${current}${NC}"
    echo ""
    read -rp "  New start port (e.g. 6000): " pstart
    read -rp "  New end port   (e.g. 19999): " pend
    if [[ -z "$pstart" || -z "$pend" ]]; then
        echo -e "${R}  Invalid ports.${NC}"; return
    fi
    if ! [[ "$pstart" =~ ^[0-9]+$ && "$pend" =~ ^[0-9]+$ ]]; then
        echo -e "${R}  Ports must be numbers.${NC}"; return
    fi
    if [[ "$pstart" -ge "$pend" ]]; then
        echo -e "${R}  Start must be less than end.${NC}"; return
    fi
    local iface
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${old_start}:${old_end}" \
        -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp \
        --dport "${pstart}:${pend}" \
        -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${old_start}:${old_end}/udp" 2>/dev/null
    ufw allow "${pstart}:${pend}/udp" 2>/dev/null
    echo "${pstart}:${pend}" > "$PORT_FILE"
    echo -e "${G}  Port range changed to ${pstart}:${pend}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) Auto-Update
# ══════════════════════════════════════════════════════════════
auto_update() {
    echo -e "${C}═══ Auto-Update ZIVPN ═══════════════════════════════════════${NC}"
    local LATEST_URL="https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64"
    echo -e "  ${Y}Downloading latest ZIVPN binary...${NC}"
    systemctl stop "$SVC" 2>/dev/null
    if wget -q --show-progress "$LATEST_URL" -O "${BIN}.new"; then
        chmod +x "${BIN}.new"
        mv "${BIN}.new" "$BIN"
        systemctl start "$SVC"
        echo -e "${G}  ZIVPN updated and restarted.${NC}"
    else
        echo -e "${R}  Download failed. Restarting existing version.${NC}"
        rm -f "${BIN}.new"
        systemctl start "$SVC"
    fi
    echo ""
    echo -e "  ${Y}Updating OPUDP panel...${NC}"
    if wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new; then
        chmod +x /usr/local/bin/opudp.new
        mv /usr/local/bin/opudp.new /usr/local/bin/opudp
        echo -e "${G}  OPUDP panel updated. Re-run 'opudp' to use new version.${NC}"
    else
        rm -f /usr/local/bin/opudp.new
        echo -e "${Y}  Panel update skipped (could not reach GitHub).${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  19) Set Connection Limit
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    echo -e "${C}═══ Set Connection Limit ════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Enter username to update: " username
    username=$(echo "$username" | tr -d ' ')
    if ! grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}User '${username}' not found.${NC}"; return
    fi
    local current_limit
    current_limit=$(grep "^${username}:" "$USERS_DB" | cut -d: -f5)
    [[ -z "$current_limit" ]] && current_limit=0
    if [[ "$current_limit" -eq 0 ]]; then
        echo -e "  Current limit: ${G}Unlimited${NC}"
    else
        echo -e "  Current limit: ${Y}${current_limit} device(s)${NC}"
    fi
    echo ""
    echo -e "  ${W}New Connection Limit:${NC}"
    echo "    1) 1 device      2) 2 devices"
    echo "    3) 3 devices     4) 5 devices"
    echo "    5) 10 devices    6) Unlimited"
    echo "    7) Custom number"
    read -rp "  Choose [1-7]: " conn_choice
    case $conn_choice in
        1) new_limit=1  ;;
        2) new_limit=2  ;;
        3) new_limit=3  ;;
        4) new_limit=5  ;;
        5) new_limit=10 ;;
        6) new_limit=0  ;;
        7)
            read -rp "  Enter max connections: " new_limit
            if ! [[ "$new_limit" =~ ^[0-9]+$ ]]; then
                echo -e "${R}Invalid. Setting to unlimited.${NC}"
                new_limit=0
            fi
            ;;
        *) echo -e "${R}Invalid choice.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*\):[^:]*$/\1:${new_limit}/" "$USERS_DB"
    apply_conn_limits
    local label
    [[ "$new_limit" -eq 0 ]] && label="Unlimited" || label="${new_limit} device(s)"
    echo -e "${G}  '${username}' connection limit set to: ${label}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  99) Uninstall
# ══════════════════════════════════════════════════════════════
uninstall() {
    echo -e "${R}═══ UNINSTALL ZIVPN + OPUDP (DANGER) ═══════════════════════${NC}"
    echo ""
    echo -e "${R}  This will permanently remove:${NC}"
    echo "    - ZIVPN binary and service"
    echo "    - All user data (/etc/zivpn/)"
    echo "    - iptables NAT + connlimit rules"
    echo "    - The opudp panel command"
    echo ""
    read -rp "  Type 'yes' to confirm uninstall: " confirm
    [[ "$confirm" != "yes" ]] && echo "  Cancelled." && return
    local iface port ps pe
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    port=$(get_port)
    ps=$(echo "$port" | cut -d: -f1)
    pe=$(echo "$port" | cut -d: -f2)
    systemctl stop "$SVC"    2>/dev/null
    systemctl disable "$SVC" 2>/dev/null
    rm -f /etc/systemd/system/zivpn.service
    systemctl daemon-reload  2>/dev/null
    rm -f "$BIN"
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -L INPUT --line-numbers -n 2>/dev/null | \
        grep "connlimit" | awk '{print $1}' | sort -rn | \
        xargs -I{} iptables -D INPUT {} 2>/dev/null
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${ps}:${pe}/udp"    2>/dev/null
    ufw delete allow "${LISTEN_PORT}/udp" 2>/dev/null
    rm -rf /etc/zivpn
    rm -f /usr/local/bin/opudp
    echo ""
    echo -e "${G}  ZIVPN and OPUDP fully removed.${NC}"
    exit 0
}

