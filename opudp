#!/bin/bash
# ============================================================
#  OPUDP — ZIVPN UDP Ultimate Control Panel
#  Author  : OfficialOnePesewa
#  GitHub  : https://github.com/OfficialOnePesewa/udp-opudp
#  Command : opudp
#  Version : 2.0.0
# ============================================================
#
#  CREDENTIAL GUIDE:
#  ─────────────────────────────────────────────────────────
#  USERNAME  → label only (for your records in this panel)
#  PASSWORD  → what you enter in the ZIVPN Pro app
#  MAX CONN  → how many devices can connect with that password
#              0 = unlimited
#
#  users.db format:
#  username:password:expiry:bandwidth:max_conn
# ============================================================

CONFIG="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
PORT_FILE="/etc/zivpn/port_range"
BACKUP_DIR="/etc/zivpn/backups"
SESSIONS_DIR="/etc/zivpn/sessions"
CONN_LOG="/etc/zivpn/connections.log"
SVC="zivpn"
BIN="/usr/local/bin/zivpn"
LISTEN_PORT="5667"
PANEL_VERSION="2.0.0"
GITHUB_RAW="https://raw.githubusercontent.com/OfficialOnePesewa/udp-opudp/main"

# ── Colours ──────────────────────────────────────────────────
R='\033[0;31m'  ; G='\033[0;32m' ; Y='\033[1;33m'
C='\033[0;36m'  ; W='\033[1;37m' ; B='\033[0;34m'
M='\033[0;35m'  ; NC='\033[0m'

# ── Guard ─────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${R}Run as root: sudo opudp${NC}" && exit 1

# ── Init ──────────────────────────────────────────────────────
init() {
    mkdir -p /etc/zivpn "$BACKUP_DIR" "$SESSIONS_DIR"
    [[ ! -f "$USERS_DB"  ]] && touch "$USERS_DB"
    [[ ! -f "$PORT_FILE" ]] && echo "6000:19999" > "$PORT_FILE"
    [[ ! -f "$CONN_LOG"  ]] && touch "$CONN_LOG"
    migrate_db
}

# ── Migrate old DB (adds max_conn=0 if missing) ───────────────
migrate_db() {
    local tmp
    tmp=$(mktemp)
    local changed=0
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        if [[ -z "$mc" ]]; then
            echo "${u}:${p}:${e}:${bw}:0" >> "$tmp"
            changed=1
        else
            echo "${u}:${p}:${e}:${bw}:${mc}" >> "$tmp"
        fi
    done < "$USERS_DB"
    [[ $changed -eq 1 ]] && mv "$tmp" "$USERS_DB" || rm -f "$tmp"
}

# ── Helpers ───────────────────────────────────────────────────
get_ip()   { curl -s4 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'; }
get_port() { cat "$PORT_FILE" 2>/dev/null || echo "6000:19999"; }
today()    { date +%Y-%m-%d; }
pause()    { echo ""; read -rp "  Press Enter to continue..."; }
divider()  { echo -e "${C}──────────────────────────────────────────────────────────────${NC}"; }

is_expired() {
    local exp="$1"
    [[ "$exp" == "never" ]] && return 1
    [[ "$exp" < "$(today)" ]] && return 0
    return 1
}

days_left() {
    local exp="$1"
    [[ "$exp" == "never" ]] && echo "∞" && return
    local now_s exp_s
    now_s=$(date +%s)
    exp_s=$(date -d "$exp" +%s 2>/dev/null) || { echo "?"; return; }
    echo $(( (exp_s - now_s) / 86400 ))
}

count_active() {
    local n=0
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        is_expired "$e" || n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

count_live_connections() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | \
        cut -d: -f1 | \
        sort -u | \
        wc -l
}

get_connected_ips() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | \
        cut -d: -f1 | \
        sort -u
}

count_user_connections() {
    local password="$1"
    local session_file="${SESSIONS_DIR}/${password}.sessions"
    [[ ! -f "$session_file" ]] && echo "0" && return
    local live_ips
    live_ips=$(get_connected_ips)
    local active=0
    while read -r ip; do
        [[ -z "$ip" ]] && continue
        if echo "$live_ips" | grep -q "^${ip}$"; then
            active=$((active + 1))
        fi
    done < "$session_file"
    local tmp
    tmp=$(mktemp)
    while read -r ip; do
        [[ -z "$ip" ]] && continue
        echo "$live_ips" | grep -q "^${ip}$" && echo "$ip" >> "$tmp"
    done < "$session_file"
    mv "$tmp" "$session_file"
    echo "$active"
}

rebuild_config() {
    local pwds=()
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" || -z "$p" ]] && continue
        is_expired "$e" || pwds+=("\"$p\"")
    done < "$USERS_DB"

    local plist=""
    if [[ ${#pwds[@]} -gt 0 ]]; then
        plist=$(printf '%s,' "${pwds[@]}")
        plist="${plist%,}"
    fi

    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
EOF
}

apply_conn_limits() {
    iptables -L INPUT --line-numbers -n 2>/dev/null | \
        grep "connlimit" | awk '{print $1}' | sort -rn | \
        xargs -I{} iptables -D INPUT {} 2>/dev/null

    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        if [[ "$mc" -gt 0 ]] 2>/dev/null; then
            iptables -A INPUT -p udp --dport "$LISTEN_PORT" \
                -m connlimit --connlimit-above "$mc" --connlimit-mask 32 \
                -j REJECT --reject-with icmp-port-unreachable 2>/dev/null
        fi
    done < "$USERS_DB"
}

# ── Header ─────────────────────────────────────────────────────
show_header() {
    clear
    local svc_st users port ip live_conn
    svc_st=$(systemctl is-active "$SVC" 2>/dev/null)
    users=$(count_active)
    port=$(get_port)
    ip=$(get_ip)
    live_conn=$(count_live_connections)

    echo -e "${C}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${C}║${W}       EXPIRY + BANDWIDTH  Ultimate Control Panel             ${C}║${NC}"
    echo -e "${C}║${C}           User Expiry  •  Limits  •  Stats                   ${C}║${NC}"
    echo -e "${C}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    if [[ "$svc_st" == "active" ]]; then
        echo -e "  Service: ${G}active${NC}    Total Users: ${G}${users}${NC}    Live Connections: ${G}${live_conn}${NC}"
    else
        echo -e "  Service: ${R}inactive${NC}  Total Users: ${G}${users}${NC}    Live Connections: ${R}0${NC}"
    fi
    echo -e "  IP: ${C}${ip}${NC}   UDP Port Range: ${Y}${port}${NC}   Panel v${PANEL_VERSION}"
    echo ""
}

# ── Menu ───────────────────────────────────────────────────────
show_menu() {
    echo -e "  ${G}1)${NC}  Start ZIVPN              ${G}11)${NC} Bandwidth + Expiry Report"
    echo -e "  ${G}2)${NC}  Stop ZIVPN               ${G}12)${NC} Reset All Bandwidth"
    echo -e "  ${G}3)${NC}  Restart ZIVPN            ${G}13)${NC} Speed Test"
    echo -e "  ${G}4)${NC}  Status                   ${G}14)${NC} Live Logs"
    echo -e "  ${G}5)${NC}  List Users + Expiry      ${G}15)${NC} Backup All Data"
    echo -e "  ${G}6)${NC}  Add User (with expiry)   ${G}16)${NC} Restore Backup"
    echo -e "  ${G}7)${NC}  Remove User              ${G}17)${NC} Change Port Range"
    echo -e "  ${G}8)${NC}  Renew/Extend User        ${G}18)${NC} Auto-Update ZIVPN"
    echo -e "  ${G}9)${NC}  Cleanup Expired Users    ${G}19)${NC} Set Connection Limit"
    echo -e "  ${G}10)${NC} Connection Stats         ${R}99)${NC} UNINSTALL (DANGER)"
    echo -e "  ${G}0)${NC}  Exit"
    echo ""
    echo -ne "${Y}Choose [0-99] ► ${NC}"
}

# ══════════════════════════════════════════════════════════════
#  1) Start
# ══════════════════════════════════════════════════════════════
start_svc() {
    echo -e "${Y}Starting ZIVPN...${NC}"
    systemctl start "$SVC"
    sleep 1
    if systemctl is-active --quiet "$SVC"; then
        echo -e "${G}ZIVPN is now running.${NC}"
    else
        echo -e "${R}Failed to start. Check: journalctl -u zivpn -n 20${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  2) Stop
# ══════════════════════════════════════════════════════════════
stop_svc() {
    echo -e "${Y}Stopping ZIVPN...${NC}"
    systemctl stop "$SVC"
    echo -e "${R}ZIVPN stopped.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  3) Restart
# ══════════════════════════════════════════════════════════════
restart_svc() {
    echo -e "${Y}Restarting ZIVPN...${NC}"
    systemctl restart "$SVC"
    sleep 1
    if systemctl is-active --quiet "$SVC"; then
        echo -e "${G}ZIVPN restarted successfully.${NC}"
    else
        echo -e "${R}Restart failed. Check: journalctl -u zivpn -n 20${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  4) Status
# ══════════════════════════════════════════════════════════════
show_status() {
    echo -e "${C}═══ ZIVPN Service Status ════════════════════════════════════${NC}"
    systemctl status "$SVC" --no-pager -l
    echo ""
    divider
    echo -e "  Config file : ${Y}${CONFIG}${NC}"
    echo -e "  Users DB    : ${Y}${USERS_DB}${NC}"
    echo -e "  Port file   : ${Y}${PORT_FILE}${NC}"
    echo -e "  Binary      : ${Y}${BIN}${NC}"
    echo -e "  Sessions    : ${Y}${SESSIONS_DIR}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  5) List Users + Expiry
# ══════════════════════════════════════════════════════════════
list_users() {
    echo -e "${C}═══ User List ═══════════════════════════════════════════════${NC}"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users found. Use option 6 to add one.${NC}"
        return
    fi
    printf "\n  %-18s %-20s %-12s %-8s %-8s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "MAX CONN" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        local dl status conn_display
        [[ -z "$mc" ]] && mc=0
        [[ "$mc" -eq 0 ]] && conn_display="∞" || conn_display="$mc"
        if is_expired "$e"; then
            dl="—"
            status="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            if [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${Y}EXPIRING${NC}"
            else
                status="${G}ACTIVE${NC}"
            fi
        fi
        printf "  %-18s %-20s %-12s %-8s %-8s " \
            "$u" "$p" "$e" "$dl" "$conn_display"
        echo -e "$status"
    done < "$USERS_DB"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  6) Add User
# ══════════════════════════════════════════════════════════════
add_user() {
    echo -e "${C}═══ Add New User ════════════════════════════════════════════${NC}"
    echo ""

    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}Username cannot be empty.${NC}" && return
    if grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}User '${username}' already exists!${NC}"; return
    fi

    read -rp "  Password: " password
    password=$(echo "$password" | tr -d ' ')
    [[ -z "$password" ]] && echo -e "${R}Password cannot be empty.${NC}" && return

    echo ""
    echo -e "  ${W}Expiry Options:${NC}"
    echo "    1) 1 month    2) 3 months"
    echo "    3) 6 months   4) 1 year"
    echo "    5) Never      6) Custom date (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " exp_choice
    case $exp_choice in
        1) expiry=$(date -d "+1 month"   +%Y-%m-%d) ;;
        2) expiry=$(date -d "+3 months"  +%Y-%m-%d) ;;
        3) expiry=$(date -d "+6 months"  +%Y-%m-%d) ;;
        4) expiry=$(date -d "+1 year"    +%Y-%m-%d) ;;
        5) expiry="never" ;;
        6)
            read -rp "  Enter date (YYYY-MM-DD): " expiry
            if ! date -d "$expiry" +%Y-%m-%d &>/dev/null; then
                echo -e "${R}Invalid date format.${NC}"; return
            fi
            ;;
        *) echo -e "${R}Invalid choice.${NC}"; return ;;
    esac

    echo ""
    echo -e "  ${W}Connection Limit (max devices with this password):${NC}"
    echo "    1) 1 device      2) 2 devices"
    echo "    3) 3 devices     4) 5 devices"
    echo "    5) 10 devices    6) Unlimited"
    echo "    7) Custom number"
    read -rp "  Choose [1-7]: " conn_choice
    case $conn_choice in
        1) max_conn=1  ;;
        2) max_conn=2  ;;
        3) max_conn=3  ;;
        4) max_conn=5  ;;
        5) max_conn=10 ;;
        6) max_conn=0  ;;
        7)
            read -rp "  Enter max connections (e.g. 4): " max_conn
            if ! [[ "$max_conn" =~ ^[0-9]+$ ]]; then
                echo -e "${R}Invalid number. Setting to unlimited.${NC}"
                max_conn=0
            fi
            ;;
        *) max_conn=0 ;;
    esac

    echo "${username}:${password}:${expiry}:0:${max_conn}" >> "$USERS_DB"
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null

    local server_ip
    server_ip=$(get_ip)
    local conn_label
    [[ "$max_conn" -eq 0 ]] && conn_label="Unlimited" || conn_label="${max_conn} device(s)"

    echo ""
    echo -e "${G}  ✓ User '${username}' added!${NC}"
    echo ""
    echo -e "${C}  ╔═══════════ ZIVPN App Configuration ══════════════╗${NC}"
    echo -e "${C}  ║${NC}  UDP Server   :  ${Y}${server_ip}${NC}"
    echo -e "${C}  ║${NC}  UDP Password :  ${Y}${password}${NC}  ${G}← enter this in the app${NC}"
    echo -e "${C}  ║${NC}  Expiry       :  ${Y}${expiry}${NC}"
    echo -e "${C}  ║${NC}  Max Devices  :  ${Y}${conn_label}${NC}"
    echo -e "${C}  ║${NC}  (Username '${username}' is for panel only)${NC}"
    echo -e "${C}  ╚══════════════════════════════════════════════════╝${NC}"
}

# ══════════════════════════════════════════════════════════════
#  7) Remove User
# ══════════════════════════════════════════════════════════════
remove_user() {
    echo -e "${C}═══ Remove User ═════════════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Enter username to remove: " username
    username=$(echo "$username" | tr -d ' ')
    if ! grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}User '${username}' not found.${NC}"; return
    fi
    read -rp "  Confirm remove '${username}'? [y/N]: " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
    local pass
    pass=$(grep "^${username}:" "$USERS_DB" | cut -d: -f2)
    sed -i "/^${username}:/d" "$USERS_DB"
    rm -f "${SESSIONS_DIR}/${pass}.sessions" 2>/dev/null
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  User '${username}' removed and config reloaded.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  8) Renew / Extend User
# ══════════════════════════════════════════════════════════════
renew_user() {
    echo -e "${C}═══ Renew / Extend User ═════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Enter username to renew: " username
    username=$(echo "$username" | tr -d ' ')
    if ! grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}User '${username}' not found.${NC}"; return
    fi
    echo ""
    echo -e "  ${W}New Expiry:${NC}"
    echo "    1) 1 month    2) 3 months"
    echo "    3) 6 months   4) 1 year"
    echo "    5) Never      6) Custom date (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " exp_choice
    case $exp_choice in
        1) new_expiry=$(date -d "+1 month"   +%Y-%m-%d) ;;
        2) new_expiry=$(date -d "+3 months"  +%Y-%m-%d) ;;
        3) new_expiry=$(date -d "+6 months"  +%Y-%m-%d) ;;
        4) new_expiry=$(date -d "+1 year"    +%Y-%m-%d) ;;
        5) new_expiry="never" ;;
        6)
            read -rp "  Enter date (YYYY-MM-DD): " new_expiry
            if ! date -d "$new_expiry" +%Y-%m-%d &>/dev/null; then
                echo -e "${R}Invalid date.${NC}"; return
            fi
            ;;
        *) echo -e "${R}Invalid choice.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*\):[^:]*:\([^:]*:[^:]*\)$/\1:${new_expiry}:\2/" "$USERS_DB"
    rebuild_config
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  '${username}' renewed → expiry: ${new_expiry}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  9) Cleanup Expired Users
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    echo -e "${C}═══ Cleanup Expired Users ═══════════════════════════════════${NC}"
    local count=0
    local tmp
    tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${R}Removing:${NC} ${u} (expired: ${e})"
            rm -f "${SESSIONS_DIR}/${p}.sessions" 2>/dev/null
            count=$((count + 1))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo ""
    echo -e "${G}  Done. Removed ${count} expired user(s).${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) Connection Stats
# ══════════════════════════════════════════════════════════════
conn_stats() {
    echo -e "${C}═══ Connection Stats ════════════════════════════════════════${NC}"
    echo ""
    local total_live
    total_live=$(count_live_connections)
    echo -e "  Total live connections to server: ${G}${total_live}${NC}"
    echo ""
    local ips
    ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Currently connected IPs:${NC}"
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            echo -e "    ${G}→${NC} ${ip}"
        done <<< "$ips"
    else
        echo -e "  ${Y}No active connections detected.${NC}"
    fi
    echo ""
    divider
    echo ""
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users in database.${NC}"
        return
    fi
    printf "  %-18s %-20s %-10s %-10s %s\n" \
        "USERNAME" "PASSWORD" "MAX CONN" "LIVE" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0
        local live_count limit_display conn_status
        live_count=$(ss -u state established 2>/dev/null | \
            grep ":${LISTEN_PORT}" | wc -l)
        [[ "$mc" -eq 0 ]] && limit_display="∞" || limit_display="$mc"
        if is_expired "$e"; then
            conn_status="${R}EXPIRED${NC}"
        elif [[ "$mc" -gt 0 && "$live_count" -ge "$mc" ]]; then
            conn_status="${R}LIMIT REACHED${NC}"
        elif [[ "$live_count" -gt 0 ]]; then
            conn_status="${G}CONNECTED${NC}"
        else
            conn_status="${Y}IDLE${NC}"
        fi
        printf "  %-18s %-20s %-10s %-10s " \
            "$u" "$p" "$limit_display" "$live_count"
        echo -e "$conn_status"
    done < "$USERS_DB"
    echo ""
    echo -e "  ${Y}Tip: Use option 19 to change a user's connection limit.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  11) Bandwidth + Expiry Report
# ══════════════════════════════════════════════════════════════
bw_report() {
    echo -e "${C}═══ Bandwidth + Expiry Report ═══════════════════════════════${NC}"
    local iface
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    local rx tx rx_mb tx_mb
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    rx_mb=$(echo "scale=2; $rx/1048576" | bc)
    tx_mb=$(echo "scale=2; $tx/1048576" | bc)
    echo ""
    echo -e "  Interface : ${Y}${iface}${NC}"
    echo -e "  Total RX  : ${G}${rx_mb} MB${NC}"
    echo -e "  Total TX  : ${G}${tx_mb} MB${NC}"
    echo ""
    divider
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users.${NC}"; return
    fi
    printf "  %-18s %-20s %-12s %-8s %-8s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "MAX CONN" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0
        local dl status conn_display
        [[ "$mc" -eq 0 ]] && conn_display="∞" || conn_display="$mc"
        if is_expired "$e"; then
            dl="—"; status="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            if [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${Y}EXPIRING SOON${NC}"
            else
                status="${G}ACTIVE${NC}"
            fi
        fi
        printf "  %-18s %-20s %-12s %-8s %-8s " \
            "$u" "$p" "$e" "$dl" "$conn_display"
        echo -e "$status"
    done < "$USERS_DB"
}

# ══════════════════════════════════════════════════════════════
#  12) Reset Bandwidth
# ══════════════════════════════════════════════════════════════
reset_bandwidth() {
    echo -e "${C}═══ Reset Bandwidth Counters ════════════════════════════════${NC}"
    read -rp "  Reset iptables byte/packet counters? [y/N]: " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
    iptables -Z 2>/dev/null
    echo -e "${G}  iptables counters reset.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  13) Speed Test
# ══════════════════════════════════════════════════════════════
speed_test() {
    echo -e "${C}═══ Speed Test ══════════════════════════════════════════════${NC}"
    if command -v speedtest &>/dev/null; then
        speedtest
    elif command -v speedtest-cli &>/dev/null; then
        speedtest-cli
    else
        echo -e "  ${Y}Installing speedtest-cli...${NC}"
        apt-get install -y -q speedtest-cli 2>/dev/null \
            || pip3 install speedtest-cli --break-system-packages -q 2>/dev/null
        if command -v speedtest-cli &>/dev/null; then
            speedtest-cli
        else
            echo -e "  ${Y}Falling back to curl speed test...${NC}"
            echo ""
            echo -ne "  Download: "
            curl -o /dev/null -s -w "%{speed_download}" \
                http://speedtest.tele2.net/10MB.zip | \
                awk '{printf "%.2f MB/s\n", $1/1048576}'
        fi
    fi
}

