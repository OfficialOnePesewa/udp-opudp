# ══════════════════════════════════════════════════════════════
#  17) Change Port Range
# ══════════════════════════════════════════════════════════════
change_port() {
    fire_header "Change UDP Port Range"
    local current old_start old_end
    current=$(get_port)
    old_start=$(echo "$current" | cut -d: -f1)
    old_end=$(echo "$current"   | cut -d: -f2)
    echo -e "  ${OR}Current range:${NC} ${GO}${current}${NC}"
    echo ""
    read -rp "  New start port (e.g. 6000): "  pstart
    read -rp "  New end port   (e.g. 19999): " pend
    if [[ -z "$pstart" || -z "$pend" ]]; then
        echo -e "${FR}  Invalid ports.${NC}"; return
    fi
    if ! [[ "$pstart" =~ ^[0-9]+$ && "$pend" =~ ^[0-9]+$ ]]; then
        echo -e "${FR}  Ports must be numbers.${NC}"; return
    fi
    if [[ "$pstart" -ge "$pend" ]]; then
        echo -e "${FR}  Start must be less than end.${NC}"; return
    fi
    local iface
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${old_start}:${old_end}" \
        -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp \
        --dport "${pstart}:${pend}" \
        -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${old_start}:${old_end}/udp" 2>/dev/null
    ufw allow "${pstart}:${pend}/udp" 2>/dev/null
    echo "${pstart}:${pend}" > "$PORT_FILE"
    echo -e "${G}  ✓ Port range changed to ${GO}${pstart}:${pend}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) Auto-Update
# ══════════════════════════════════════════════════════════════
auto_update() {
    fire_header "Auto-Update ZIVPN + OPUDP"
    local LATEST_URL="https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64"
    echo -e "  ${YW}Downloading latest ZIVPN binary...${NC}"
    systemctl stop "$SVC" 2>/dev/null
    if wget -q --show-progress "$LATEST_URL" -O "${BIN}.new"; then
        chmod +x "${BIN}.new"
        mv "${BIN}.new" "$BIN"
        systemctl start "$SVC"
        echo -e "${G}  ✓ ZIVPN updated and restarted.${NC}"
    else
        echo -e "${FR}  Download failed. Restarting existing version.${NC}"
        rm -f "${BIN}.new"
        systemctl start "$SVC"
    fi
    echo ""
    echo -e "  ${YW}Updating OPUDP Fire Edition panel...${NC}"
    if wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new; then
        chmod +x /usr/local/bin/opudp.new
        mv /usr/local/bin/opudp.new /usr/local/bin/opudp
        echo -e "${G}  ✓ OPUDP panel updated. Re-run 'opudp' for new version.${NC}"
    else
        rm -f /usr/local/bin/opudp.new
        echo -e "${YW}  Panel update skipped (could not reach GitHub).${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  19) Set Connection Limit
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    fire_header "Set Connection Limit"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Enter username to update: " username
    username=$(echo "$username" | tr -d ' ')
    if ! grep -q "^${username}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${FR}User '${username}' not found.${NC}"; return
    fi
    local current_limit
    current_limit=$(grep "^${username}:" "$USERS_DB" | cut -d: -f5)
    [[ -z "$current_limit" ]] && current_limit=0
    if [[ "$current_limit" -eq 0 ]]; then
        echo -e "  ${OR}Current limit:${NC} ${G}Unlimited${NC}"
    else
        echo -e "  ${OR}Current limit:${NC} ${GO}${current_limit} device(s)${NC}"
    fi
    echo ""
    echo "    1) 1 device    2) 2 devices   3) 3 devices"
    echo "    4) 5 devices   5) 10 devices  6) Unlimited"
    echo "    7) Custom number"
    read -rp "  Choose [1-7]: " conn_choice
    local new_limit
    case $conn_choice in
        1) new_limit=1  ;;
        2) new_limit=2  ;;
        3) new_limit=3  ;;
        4) new_limit=5  ;;
        5) new_limit=10 ;;
        6) new_limit=0  ;;
        7)
            read -rp "  Enter max connections: " new_limit
            if ! [[ "$new_limit" =~ ^[0-9]+$ ]]; then
                echo -e "${FR}Invalid. Setting to unlimited.${NC}"
                new_limit=0
            fi
            ;;
        *) echo -e "${FR}Invalid choice.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*\):[^:]*:\([^:]*\)$/\1:${new_limit}:\2/" "$USERS_DB"
    apply_conn_limits
    local label
    [[ "$new_limit" -eq 0 ]] && label="Unlimited" || label="${new_limit} device(s)"
    echo -e "${G}  ✓ '${username}' connection limit set to: ${GO}${label}${NC}"
}

