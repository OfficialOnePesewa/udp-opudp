# ══════════════════════════════════════════════════════════════
#  5) List Users + Expiry  (+ Days Used + Last Seen)
# ══════════════════════════════════════════════════════════════
list_users() {
    fire_header "User List — Days Used • Days Left • Last Seen"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${YW}No users found. Use option 6 to add one.${NC}"
        return
    fi

    local trial_count
    trial_count=$(count_trials)
    [[ "$trial_count" -gt 0 ]] && {
        echo -e "  ${YW}⚡ Active Trials: ${trial_count}${NC}"
        list_trials
        echo ""
        fire_divider
        echo ""
    }

    printf "  ${OR}%-16s %-18s %-12s %-6s %-6s %-7s %-8s %s${NC}\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "USED" "LEFT" "CONN" "ONLINE" "STATUS"
    fire_divider

    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0
        [[ -z "$cd" ]] && cd="?"

        local dl du conn_disp status online lastseen_epoch
        dl=$(days_left "$e")
        du=$(days_used "$cd")
        [[ "$mc" -eq 0 ]] && conn_disp="∞" || conn_disp="${mc}"

        online="${DIM}OFFLINE${NC}"
        local ls_file="${LASTSEEN_DIR}/${u}"
        if [[ -f "$ls_file" ]]; then
            lastseen_epoch=$(cat "$ls_file" 2>/dev/null)
            local now_e
            now_e=$(date +%s)
            if [[ $((now_e - lastseen_epoch)) -le 300 ]]; then
                online="${G}ONLINE${NC} "
            fi
        fi

        local is_trial=""
        grep -q "^${u}:" "$TRIALS_DB" 2>/dev/null && is_trial=" ⚡"

        if is_expired "$e"; then
            status="${FR}EXPIRED${NC}"
            dl="—"; du="${du}d"
        else
            if [[ "$dl" != "∞" && "$dl" -le 1 ]]; then
                status="${FR}⚠ CRITICAL${NC}"
            elif [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${YW}⚡ EXPIRING${NC}"
            elif [[ "$dl" != "∞" && "$dl" -le 7 ]]; then
                status="${OR}SOON${NC}     "
            else
                status="${G}✓ ACTIVE${NC} "
            fi
            dl="${dl}d"
            du="${du}d"
        fi

        printf "  %-16s %-18s %-12s %-6s %-6s %-7s " \
            "${u}${is_trial}" "$p" "$e" "$du" "$dl" "$conn_disp"
        echo -ne "$online  "
        echo -e "$status"
    done < "$USERS_DB"
    echo ""
    echo -e "  ${DIM}USED = days since created   LEFT = days until expiry   ⚡ = trial${NC}"
    echo -e "  ${DIM}ONLINE = connected in last 5 min (updates when panel is open)${NC}"
}

