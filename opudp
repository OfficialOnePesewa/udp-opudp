# ══════════════════════════════════════════════════════════════
#  17) CHANGE PORT
# ══════════════════════════════════════════════════════════════
change_port() {
    echo -e "${C}═══ Change UDP Port Range ═══════════════════════════════════${NC}"
    local cur; cur=$(get_port)
    local os oe; os=$(echo "$cur"|cut -d:-f1); oe=$(echo "$cur"|cut -d:-f2)
    echo -e "  Current: ${Y}${cur}${NC}"; echo ""
    read -rp "  New start port: " ps; read -rp "  New end port: " pe
    [[ -z "$ps" || -z "$pe" ]] && echo -e "${R}  Invalid.${NC}" && return
    [[ ! "$ps" =~ ^[0-9]+$ || ! "$pe" =~ ^[0-9]+$ ]] && echo -e "${R}  Numbers only.${NC}" && return
    [[ "$ps" -ge "$pe" ]] && echo -e "${R}  Start < end required.${NC}" && return
    local iface; iface=$(ip -4 route show default 2>/dev/null | awk 'NR==1{print $5}')
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${os}:${oe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${os}:${oe}/udp" 2>/dev/null
    ufw allow "${ps}:${pe}/udp" 2>/dev/null
    echo "${ps}:${pe}" > "$PORT_FILE"
    echo -e "${G}  Port range → ${ps}:${pe}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) AUTO-UPDATE
# ══════════════════════════════════════════════════════════════
auto_update() {
    echo -e "${C}═══ Auto-Update ═════════════════════════════════════════════${NC}"
    systemctl stop "$SVC" 2>/dev/null
    local BIN_URL="https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64"
    wget -q "$BIN_URL" -O "${BIN}.new" 2>/dev/null \
        && chmod +x "${BIN}.new" && mv "${BIN}.new" "$BIN" \
        && echo -e "${G}  ZIVPN binary updated.${NC}" \
        || { rm -f "${BIN}.new"; echo -e "${Y}  Binary update skipped.${NC}"; }
    systemctl start "$SVC"
    wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new 2>/dev/null \
        && chmod +x /usr/local/bin/opudp.new \
        && mv /usr/local/bin/opudp.new /usr/local/bin/opudp \
        && echo -e "${G}  Panel updated. Re-run: opudp${NC}" \
        || { rm -f /usr/local/bin/opudp.new; echo -e "${Y}  Panel update skipped.${NC}"; }
}

# ══════════════════════════════════════════════════════════════
#  19) SET CONNECTION LIMIT
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    echo -e "${C}═══ Set Connection Limit ════════════════════════════════════${NC}"
    list_users; [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
        || { echo -e "${R}  Not found.${NC}"; return; }
    local cur; cur=$(grep "^${username}:" "$USERS_DB" | cut -d: -f5)
    [[ "$cur" -eq 0 ]] \
        && echo -e "  Current: ${G}Unlimited${NC}" \
        || echo -e "  Current: ${Y}${cur} device(s)${NC}"
    echo ""
    echo "    1) 1  2) 2  3) 3  4) 5  5) 10  6) Unlimited  7) Custom"
    read -rp "  Choose [1-7]: " cc
    case $cc in
        1) nl=1  ;; 2) nl=2  ;; 3) nl=3  ;;
        4) nl=5  ;; 5) nl=10 ;; 6) nl=0  ;;
        7) read -rp "  Max: " nl; [[ "$nl" =~ ^[0-9]+$ ]] || nl=0 ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*\):[^:]*:\([^:]*:[^:]*\)$/\1:${nl}:\2/" "$USERS_DB"
    apply_conn_rules
    local lbl; [[ "$nl" -eq 0 ]] && lbl="Unlimited" || lbl="${nl} device(s)"
    echo -e "${G}  '${username}' limit → ${lbl}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  HELPER: Pick user and load their HWIDs
# ══════════════════════════════════════════════════════════════
pick_user_show_hwids() {
    list_users; [[ ! -s "$USERS_DB" ]] && return 1
    read -rp "  Username: " sel_user
    sel_user=$(echo "$sel_user" | tr -d ' ')
    grep -q "^${sel_user}:" "$USERS_DB" 2>/dev/null \
        || { echo -e "${R}  User not found.${NC}"; return 1; }
    sel_hwids=$(grep "^${sel_user}:" "$USERS_DB" | cut -d: -f6)
    sel_hl=$(grep    "^${sel_user}:" "$USERS_DB" | cut -d: -f7)
    [[ -z "$sel_hwids" ]] && sel_hwids="none"
    [[ -z "$sel_hl"    ]] && sel_hl="0"
    return 0
}

# ══════════════════════════════════════════════════════════════
#  20) HWID — VIEW ALL USERS
# ══════════════════════════════════════════════════════════════
hwid_view_all() {
    echo -e "${M}═══ HWID Device Lock — All Users ════════════════════════════${NC}"
    echo ""
    echo -e "  ${W}How customers get HWID:${NC} ${C}ZIVPN Pro → ☰ Menu → Tool → HWID → Copy${NC}"
    echo ""
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users.${NC}"; return
    fi

    local total_locked=0 total_not_set=0

    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        [[ -z "$hwid" ]] && hwid="none"
        [[ -z "$hl"   ]] && hl="0"
        local n_hwids; n_hwids=$(count_hwids "$hwid")

        if [[ "$hl" == "1" && "$hwid" != "none" ]]; then
            total_locked=$((total_locked+1))
            echo -e "  ${M}▶ ${u}${NC} (${G}${p}${NC}) — ${M}${n_hwids} device(s) locked${NC}"
            local idx=1
            IFS=',' read -ra arr <<< "$hwid"
            for h in "${arr[@]}"; do
                echo -e "    ${M}[${idx}]${NC} $(format_hwid "$h")"
                idx=$((idx+1))
            done
        else
            total_not_set=$((total_not_set+1))
            echo -e "  ${Y}▶ ${u}${NC} (${G}${p}${NC}) — ${Y}no HWID set${NC}"
        fi
        echo ""
    done < "$USERS_DB"

    divider
    echo -e "  ${M}Locked  :${NC} ${M}${total_locked}${NC} user(s)"
    echo -e "  ${Y}Not Set :${NC} ${Y}${total_not_set}${NC} user(s)"
    echo ""
    echo -e "  ${W}Options 21–24 to manage HWIDs per user.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  21) HWID — ADD DEVICE
# ══════════════════════════════════════════════════════════════
hwid_add_device() {
    echo -e "${M}═══ HWID — Add Device to User ═══════════════════════════════${NC}"
    echo ""
    pick_user_show_hwids || return

    local n_hwids; n_hwids=$(count_hwids "$sel_hwids")
    echo ""
    echo -e "  ${W}User: ${G}${sel_user}${NC}"
    if [[ "$sel_hl" == "1" && "$sel_hwids" != "none" ]]; then
        echo -e "  ${W}Current devices: ${M}${n_hwids}${NC}"
        local idx=1
        IFS=',' read -ra arr <<< "$sel_hwids"
        for h in "${arr[@]}"; do
            echo -e "    ${M}[${idx}]${NC} $(format_hwid "$h")"
            idx=$((idx+1))
        done
    else
        echo -e "  ${Y}No devices registered yet.${NC}"
    fi

    echo ""
    echo -e "  ${W}How many new devices to add?${NC}"
    echo "    1) 1 device   2) 2 devices  3) 3 devices"
    echo "    4) 4 devices  5) 5 devices"
    read -rp "  Choose [1-5]: " nc
    [[ ! "$nc" =~ ^[1-5]$ ]] && echo -e "${R}  Invalid.${NC}" && return

    local added=0
    local updated_hwids="$sel_hwids"
    local updated_hl="$sel_hl"

    for (( i=1; i<=nc; i++ )); do
        echo ""
        echo -e "  ${W}New Device ${i}:${NC}"
        echo -e "  ${C}Customer: ZIVPN Pro → ☰ Menu → Tool → HWID → tap to copy${NC}"
        read -rp "  Paste HWID: " h_input
        h_input=$(echo "$h_input" | tr -d ' -' | tr '[:lower:]' '[:upper:]')

        if ! is_valid_hwid "$h_input"; then
            echo -e "  ${R}  ✗ Invalid HWID — skipped. Must be 32 hex characters.${NC}"
            continue
        fi

        if hwid_in_list "$h_input" "$updated_hwids"; then
            echo -e "  ${Y}  ⚠ This HWID is already registered for ${sel_user}.${NC}"
            continue
        fi

        updated_hwids=$(add_hwid_to_list "$h_input" "$updated_hwids")
        updated_hl="1"
        echo -e "  ${G}  ✓ Device ${i} added: $(format_hwid "$h_input")${NC}"
        added=$((added+1))
    done

    if [[ $added -gt 0 ]]; then
        sed -i "s/^\(${sel_user}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:${updated_hwids}:${updated_hl}/" "$USERS_DB"
        echo ""
        echo -e "${G}  ✓ Added ${added} new device(s) to '${sel_user}'.${NC}"
        local total; total=$(count_hwids "$updated_hwids")
        echo -e "${G}  Total registered devices: ${M}${total}${NC}"
        echo "$(now_ts) | HWID ADD | user=${sel_user} | new=${added} | total_hwids=${updated_hwids}" >> "$HWID_LOG"
    else
        echo -e "${Y}  No valid new HWIDs were added.${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  22) HWID — REMOVE DEVICE
# ══════════════════════════════════════════════════════════════
hwid_remove_device() {
    echo -e "${M}═══ HWID — Remove Device from User ══════════════════════════${NC}"
    echo ""
    pick_user_show_hwids || return

    if [[ "$sel_hl" != "1" || "$sel_hwids" == "none" ]]; then
        echo -e "  ${Y}No devices registered for '${sel_user}'.${NC}"
        return
    fi

    echo ""
    echo -e "  ${W}User: ${G}${sel_user}${NC} — registered devices:${NC}"
    echo ""

    local idx=1
    declare -a hwid_arr=()
    IFS=',' read -ra hwid_arr <<< "$sel_hwids"
    for h in "${hwid_arr[@]}"; do
        echo -e "    ${M}[${idx}]${NC} $(format_hwid "$h")   ${C}(${h})${NC}"
        idx=$((idx+1))
    done

    echo ""
    echo -e "  ${W}Enter device number(s) to remove${NC}"
    echo -e "  ${Y}(e.g. 1  or  1,3  or  all)${NC}"
    read -rp "  Remove: " rem_input

    local updated_hwids="$sel_hwids"
    local removed=0

    if [[ "${rem_input,,}" == "all" ]]; then
        read -rp "  Remove ALL devices from '${sel_user}'? [y/N]: " c
        [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
        removed=${#hwid_arr[@]}
        sed -i "s/^\(${sel_user}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:none:0/" "$USERS_DB"
        echo -e "${G}  All ${removed} device(s) removed from '${sel_user}'.${NC}"
        echo "$(now_ts) | HWID REMOVE ALL | user=${sel_user}" >> "$HWID_LOG"
        return
    fi

    IFS=',' read -ra rem_indices <<< "$rem_input"
    for ri in "${rem_indices[@]}"; do
        ri=$(echo "$ri" | tr -d ' ')
        if ! [[ "$ri" =~ ^[0-9]+$ ]] || \
           [[ "$ri" -lt 1 || "$ri" -gt "${#hwid_arr[@]}" ]]; then
            echo -e "  ${Y}  Invalid number: ${ri} — skipped.${NC}"
            continue
        fi
        local target_hwid="${hwid_arr[$((ri-1))]}"
        updated_hwids=$(remove_hwid_from_list "$target_hwid" "$updated_hwids")
        echo -e "  ${R}  Removed [${ri}]:${NC} $(format_hwid "$target_hwid")"
        removed=$((removed+1))
        echo "$(now_ts) | HWID REMOVE | user=${sel_user} | hwid=${target_hwid}" >> "$HWID_LOG"
    done

    if [[ $removed -gt 0 ]]; then
        local new_hl="1"
        [[ "$updated_hwids" == "none" ]] && new_hl="0"
        sed -i "s/^\(${sel_user}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:${updated_hwids}:${new_hl}/" "$USERS_DB"
        local remaining; remaining=$(count_hwids "$updated_hwids")
        echo ""
        echo -e "${G}  Removed ${removed} device(s). Remaining: ${remaining}${NC}"
    else
        echo -e "${Y}  Nothing removed.${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  23) HWID — VIEW USER DEVICES
# ══════════════════════════════════════════════════════════════
hwid_view_user() {
    echo -e "${M}═══ HWID — View User's Registered Devices ═══════════════════${NC}"
    echo ""
    pick_user_show_hwids || return

    local n_hwids; n_hwids=$(count_hwids "$sel_hwids")
    echo ""
    echo -e "  ${W}User     :${NC} ${G}${sel_user}${NC}"

    if [[ "$sel_hl" == "1" && "$sel_hwids" != "none" ]]; then
        echo -e "  ${W}Devices  :${NC} ${M}${n_hwids} registered${NC}"
        echo -e "  ${W}Status   :${NC} ${M}LOCKED — only these devices can connect${NC}"
        echo ""
        divider
        local idx=1
        IFS=',' read -ra arr <<< "$sel_hwids"
        for h in "${arr[@]}"; do
            echo ""
            echo -e "  ${M}Device [${idx}]${NC}"
            echo -e "    Full HWID  : ${M}${h}${NC}"
            echo -e "    Formatted  : ${M}$(format_hwid "$h")${NC}"
            idx=$((idx+1))
        done
        divider
        echo ""
        echo -e "  ${Y}Use option 21 to add more devices.${NC}"
        echo -e "  ${Y}Use option 22 to remove a device.${NC}"
    else
        echo -e "  ${W}Devices  :${NC} ${Y}None registered${NC}"
        echo -e "  ${W}Status   :${NC} ${Y}UNLOCKED — any device can connect${NC}"
        echo ""
        echo -e "  ${Y}Use option 21 to register devices.${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  24) HWID — CLEAR ALL DEVICES
# ══════════════════════════════════════════════════════════════
hwid_clear_all() {
    echo -e "${M}═══ HWID — Clear All Devices ════════════════════════════════${NC}"
    echo ""
    pick_user_show_hwids || return

    local n_hwids; n_hwids=$(count_hwids "$sel_hwids")

    if [[ "$sel_hwids" == "none" || $n_hwids -eq 0 ]]; then
        echo -e "  ${Y}  '${sel_user}' has no registered devices.${NC}"
        return
    fi

    echo ""
    echo -e "  ${W}User: ${G}${sel_user}${NC} has ${M}${n_hwids}${NC} registered device(s):"
    echo ""
    local idx=1
    IFS=',' read -ra arr <<< "$sel_hwids"
    for h in "${arr[@]}"; do
        echo -e "    ${M}[${idx}]${NC} $(format_hwid "$h")"
        idx=$((idx+1))
    done
    echo ""
    echo -e "  ${R}⚠  This will remove ALL HWID locks. Any device can connect after.${NC}"
    read -rp "  Confirm clear all? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return

    sed -i "s/^\(${sel_user}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:none:0/" "$USERS_DB"
    echo -e "${G}  All ${n_hwids} device(s) cleared for '${sel_user}'.${NC}"
    echo -e "${Y}  Use option 21 to register new devices.${NC}"
    echo "$(now_ts) | HWID CLEAR ALL | user=${sel_user} | removed_hwids=${sel_hwids}" >> "$HWID_LOG"
}

# ══════════════════════════════════════════════════════════════
#  25) HWID — MONITOR LOGS
# ══════════════════════════════════════════════════════════════
hwid_logs() {
    echo -e "${M}═══ HWID Monitor Logs ═══════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${W}Recent HWID events (last 50 lines):${NC}"
    echo ""
    divider
    if [[ ! -s "$HWID_LOG" ]]; then
        echo -e "  ${Y}No HWID events yet.${NC}"
    else
        tail -50 "$HWID_LOG" | while read -r line; do
            if echo "$line" | grep -q "BLOCKED"; then
                echo -e "  ${R}${line}${NC}"
            elif echo "$line" | grep -q "LOCKED\|SET\|ADD"; then
                echo -e "  ${M}${line}${NC}"
            elif echo "$line" | grep -q "OK\|CREATED"; then
                echo -e "  ${G}${line}${NC}"
            elif echo "$line" | grep -q "RESET\|REMOVE\|CLEAR"; then
                echo -e "  ${Y}${line}${NC}"
            else
                echo -e "  ${C}${line}${NC}"
            fi
        done
    fi
    echo ""
    divider
    echo ""
    systemctl is-active --quiet opudp-hwid-monitor \
        && echo -e "  ${G}● HWID Monitor: running${NC}" \
        || echo -e "  ${R}● HWID Monitor: stopped${NC}"
    echo ""
    echo -e "  ${M}r)${NC} Restart monitor  ${M}c)${NC} Clear log  ${M}l)${NC} Watch live  ${M}0)${NC} Back"
    echo ""
    echo -ne "${M}Choose: ${NC}"
    read -r lsub
    case $lsub in
        r) systemctl restart opudp-hwid-monitor
           echo -e "${G}  Monitor restarted.${NC}" ;;
        c) read -rp "  Clear all HWID logs? [y/N]: " c
           [[ "$c" == "y" || "$c" == "Y" ]] \
               && > "$HWID_LOG" && echo -e "${G}  Cleared.${NC}" \
               || echo "  Cancelled." ;;
        l) echo -e "${C}  Watching — Ctrl+C to stop${NC}"
           tail -f "$HWID_LOG" ;;
    esac
}

# ══════════════════════════════════════════════════════════════
#  99) UNINSTALL
# ══════════════════════════════════════════════════════════════
uninstall() {
    echo -e "${R}═══ UNINSTALL (DANGER) ══════════════════════════════════════${NC}"
    echo ""
    echo -e "${R}  Removes: ZIVPN, OPUDP, HWID monitor, all data${NC}"
    echo ""
    read -rp "  Type 'yes' to confirm: " confirm
    [[ "$confirm" != "yes" ]] && echo "  Cancelled." && return
    local iface port ps pe
    iface=$(ip -4 route show default 2>/dev/null | awk 'NR==1{print $5}')
    port=$(get_port); ps=$(echo "$port"|cut -d:-f1); pe=$(echo "$port"|cut -d:-f2)
    systemctl stop    "$SVC" opudp-hwid-monitor 2>/dev/null
    systemctl disable "$SVC" opudp-hwid-monitor 2>/dev/null
    rm -f /etc/systemd/system/zivpn.service
    rm -f /etc/systemd/system/opudp-hwid-monitor.service
    systemctl daemon-reload 2>/dev/null
    rm -f "$BIN" /usr/local/bin/opudp /usr/local/bin/opudp-hwid-monitor
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    while iptables -L INPUT -n --line-numbers 2>/dev/null | grep -q "opudp-conn"; do
        local ln
        ln=$(iptables -L INPUT -n --line-numbers 2>/dev/null | grep "opudp-conn" | head -1 | awk '{print $1}')
        [[ -z "$ln" ]] && break
        iptables -D INPUT "$ln" 2>/dev/null
    done
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${ps}:${pe}/udp"    2>/dev/null
    ufw delete allow "${LISTEN_PORT}/udp" 2>/dev/null
    rm -rf /etc/zivpn /etc/sysctl.d/99-opudp.conf
    rm -f /etc/network/if-pre-up.d/opudp-iptables
    echo -e "\n${G}  Fully removed.${NC}"
    exit 0
}

