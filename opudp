# ══════════════════════════════════════════════════════════════
#  1) Start
# ══════════════════════════════════════════════════════════════
start_svc() {
    fire_header "Start ZIVPN"
    echo -e "  ${YW}Starting ZIVPN...${NC}"
    systemctl start "$SVC"
    sleep 1
    if systemctl is-active --quiet "$SVC"; then
        echo -e "  ${G}✓ ZIVPN is now running.${NC}"
    else
        echo -e "  ${FR}✗ Failed to start. Check: journalctl -u zivpn -n 20${NC}"
    fi
}

# ══════════════════════════════════════════════════════════════
#  2) Stop
# ══════════════════════════════════════════════════════════════
stop_svc() {
    fire_header "Stop ZIVPN"
    echo -e "  ${YW}Stopping ZIVPN...${NC}"
    systemctl stop "$SVC"
    echo -e "  ${FR}✖ ZIVPN stopped.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  3) Restart
# ══════════════════════════════════════════════════════════════
restart_svc() {
    fire_header "Restart ZIVPN"
    echo -e "  ${YW}Restarting ZIVPN...${NC}"
    systemctl restart "$SVC"
    sleep 1
    if systemctl is-active --quiet "$SVC"; then
        echo -e "  ${G}✓ ZIVPN restarted successfully.${NC}"
    else
        echo -e "  ${FR}✗ Restart failed. Check: journalctl -u zivpn -n 20${NC}"
    fi
}

