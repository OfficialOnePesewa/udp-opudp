# ══════════════════════════════════════════════════════════════
#  9) Cleanup Expired Users
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    fire_header "Cleanup Expired Users"
    local count=0 tmp
    tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${FR}✗ Removing:${NC} ${u} ${DIM}(expired: ${e})${NC}"
            sed -i "/^${u}:/d" "$TRIALS_DB" 2>/dev/null
            rm -f "${SESSIONS_DIR}/${p}.sessions" 2>/dev/null
            rm -f "${LASTSEEN_DIR}/${u}" 2>/dev/null
            count=$((count + 1))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}:${cd}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo ""
    echo -e "${G}  ✓ Done. Removed ${count} expired user(s).${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) Connection Stats
# ══════════════════════════════════════════════════════════════
conn_stats() {
    fire_header "Connection Stats"
    local total_live
    total_live=$(count_live_connections)
    echo -e "  ${OR}Total live connections to server:${NC} ${GO}${total_live}${NC}"
    echo ""
    local ips
    ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Currently connected IPs:${NC}"
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            echo -e "    ${GO}→${NC} ${ip}"
        done <<< "$ips"
    else
        echo -e "  ${YW}No active connections detected.${NC}"
    fi
    echo ""
    fire_divider
    echo ""
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${YW}No users in database.${NC}"; return
    fi
    printf "  ${OR}%-16s %-18s %-8s %-6s %-8s %-18s %s${NC}\n" \
        "USERNAME" "PASSWORD" "LIMIT" "LIVE" "DAYS LEFT" "LAST SEEN" "STATUS"
    fire_divider
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0
        local live_count limit_display conn_status dl lastseen
        live_count=$(ss -u state established 2>/dev/null | grep ":${LISTEN_PORT}" | wc -l)
        [[ "$mc" -eq 0 ]] && limit_display="∞" || limit_display="$mc"
        dl=$(days_left "$e")
        lastseen=$(get_lastseen "$u")
        if is_expired "$e"; then
            conn_status="${FR}EXPIRED${NC}"
        elif [[ "$mc" -gt 0 && "$live_count" -ge "$mc" ]]; then
            conn_status="${FR}LIMIT REACHED${NC}"
        elif [[ "$live_count" -gt 0 ]]; then
            conn_status="${G}CONNECTED${NC}"
        else
            conn_status="${YW}IDLE${NC}"
        fi
        printf "  %-16s %-18s %-8s %-6s %-8s %-18s " \
            "$u" "$p" "$limit_display" "$live_count" "${dl}d" "$lastseen"
        echo -e "$conn_status"
    done < "$USERS_DB"
    echo ""
    echo -e "  ${DIM}Tip: LAST SEEN updates when user is actively connected.${NC}"
    echo -e "  ${DIM}     Even offline, days used keeps counting from creation date.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  11) Bandwidth + Expiry Report
# ══════════════════════════════════════════════════════════════
bw_report() {
    fire_header "Bandwidth + Expiry Report"
    local iface rx tx rx_mb tx_mb
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    rx_mb=$(echo "scale=2; $rx/1048576" | bc)
    tx_mb=$(echo "scale=2; $tx/1048576" | bc)
    echo -e "  ${OR}Interface :${NC} ${GO}${iface}${NC}"
    echo -e "  ${OR}Total RX  :${NC} ${GO}${rx_mb} MB${NC}   ${DIM}(Download)${NC}"
    echo -e "  ${OR}Total TX  :${NC} ${GO}${tx_mb} MB${NC}   ${DIM}(Upload)${NC}"
    echo ""
    fire_divider
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${YW}No users.${NC}"; return
    fi
    printf "  ${OR}%-16s %-18s %-12s %-6s %-6s %-8s %s${NC}\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "USED" "LEFT" "CONN" "STATUS"
    fire_divider
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc=0
        [[ -z "$cd" ]] && cd="?"
        local dl du conn_display status
        dl=$(days_left "$e")
        du=$(days_used "$cd")
        [[ "$mc" -eq 0 ]] && conn_display="∞" || conn_display="$mc"
        if is_expired "$e"; then
            status="${FR}EXPIRED${NC}"
            dl="—"
        else
            if [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${FR}⚠ EXPIRING SOON${NC}"
            else
                status="${G}✓ ACTIVE${NC}"
            fi
        fi
        printf "  %-16s %-18s %-12s %-6s %-6s %-8s " \
            "$u" "$p" "$e" "${du}d" "${dl}d" "$conn_display"
        echo -e "$status"
    done < "$USERS_DB"
}

