restore_backup() {
    echo -e "${C}═══ Restore Backup ══════════════════════════════════════════${NC}"
    ls "$BACKUP_DIR"/*.tar.gz 2>/dev/null || { echo -e "  ${Y}No backups found.${NC}"; return; }
    echo ""
    ls -lh "$BACKUP_DIR"/*.tar.gz | awk '{print "  "$9, $5}'
    echo ""
    read -rp "  Filename: " bn
    local bp="${BACKUP_DIR}/${bn}"
    [[ ! -f "$bp" ]] && echo -e "${R}  Not found.${NC}" && return
    read -rp "  Restore '${bn}'? Overwrites all data [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    tar -xzf "$bp" -C / 2>/dev/null
    migrate_db; rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Restored.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  17) Change Port Range
# ══════════════════════════════════════════════════════════════
change_port() {
    echo -e "${C}═══ Change UDP Port Range ═══════════════════════════════════${NC}"
    local cur; cur=$(get_port)
    local os oe; os=$(echo "$cur"|cut -d: -f1); oe=$(echo "$cur"|cut -d: -f2)
    echo -e "  Current: ${Y}${cur}${NC}"
    read -rp "  New start: " ps; read -rp "  New end: " pe
    [[ -z "$ps" || -z "$pe" ]] && echo -e "${R}  Invalid.${NC}" && return
    [[ ! "$ps" =~ ^[0-9]+$ || ! "$pe" =~ ^[0-9]+$ ]] && echo -e "${R}  Not numbers.${NC}" && return
    [[ "$ps" -ge "$pe" ]] && echo -e "${R}  Start must be < end.${NC}" && return
    local iface; iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    iptables -t nat -D PREROUTING -i "$iface" -p udp --dport "${os}:${oe}" \
        -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp --dport "${ps}:${pe}" \
        -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${os}:${oe}/udp" 2>/dev/null
    ufw allow "${ps}:${pe}/udp" 2>/dev/null
    echo "${ps}:${pe}" > "$PORT_FILE"
    echo -e "${G}  Port range → ${ps}:${pe}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) Auto-Update
# ══════════════════════════════════════════════════════════════
auto_update() {
    echo -e "${C}═══ Auto-Update ZIVPN ═══════════════════════════════════════${NC}"
    systemctl stop "$SVC" 2>/dev/null
    wget -q --show-progress \
        "https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64" \
        -O "${BIN}.new" \
        && chmod +x "${BIN}.new" && mv "${BIN}.new" "$BIN" \
        && echo -e "${G}  ZIVPN updated.${NC}" \
        || { rm -f "${BIN}.new"; echo -e "${R}  Download failed.${NC}"; }
    systemctl start "$SVC"
}

# ══════════════════════════════════════════════════════════════
#  19) Set Connection Limit
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    echo -e "${C}═══ Set Connection Limit ════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Password of entry to update: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" 2>/dev/null || { echo -e "${R}  Not found.${NC}"; return; }
    echo "    1)1  2)2  3)3  4)5  5)10  6)Unlimited  7)Custom"
    read -rp "  Choose: " cc
    case $cc in
        1) nl=1;; 2) nl=2;; 3) nl=3;; 4) nl=5;; 5) nl=10;; 6) nl=0;;
        7) read -rp "  Number: " nl; [[ ! "$nl" =~ ^[0-9]+$ ]] && nl=0;;
        *) echo -e "${R}Invalid.${NC}"; return;;
    esac
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${nl}:${hwid}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    apply_conn_limits
    local lb; [[ "$nl" -eq 0 ]] && lb="Unlimited" || lb="${nl}"
    echo -e "${G}  Connection limit set to: ${lb}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  20) HWID Management
# ══════════════════════════════════════════════════════════════
hwid_menu() {
    while true; do
        clear
        echo -e "${M}╔══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${M}║              HWID Device Management                          ║${NC}"
        echo -e "${M}╚══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "  ${M}a)${NC} List all HWID bindings"
        echo -e "  ${M}b)${NC} Bind / update HWID for an entry (by password)"
        echo -e "  ${M}c)${NC} Add new device entry for existing user"
        echo -e "  ${M}d)${NC} Remove / unbind HWID"
        echo -e "  ${M}e)${NC} Search by HWID"
        echo -e "  ${M}f)${NC} Show what client should type in ZIVPN app"
        echo -e "  ${M}g)${NC} Export HWID list to file"
        echo -e "  ${M}0)${NC} Back"
        echo ""
        echo -ne "${M}Choose ► ${NC}"
        read -r hc; echo ""
        case "$hc" in
            a) hwid_list_all ;;
            b) hwid_bind ;;
            c) hwid_add_device ;;
            d) hwid_unbind ;;
            e) hwid_search ;;
            f) hwid_show_client_string ;;
            g) hwid_export ;;
            0) break ;;
            *) echo -e "${R}  Invalid.${NC}" ;;
        esac
        [[ "$hc" != "0" ]] && pause
    done
}

hwid_list_all() {
    echo -e "${M}═══ All HWID Bindings ═══════════════════════════════════════${NC}"
    [[ ! -s "$USERS_DB" ]] && echo -e "  ${Y}No users.${NC}" && return
    local bound=0 unbound_count=0
    printf "\n  %-16s %-18s %-12s %-6s %s\n" "USERNAME" "PASSWORD" "EXPIRY" "CONN" "HWID"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$hwid" ]] && hwid="unbound"
        [[ -z "$mc"   ]] && mc=0
        local cd; [[ "$mc" -eq 0 ]] && cd="∞" || cd="$mc"
        local el; is_expired "$e" && el="${R}[EXP]${NC}" || el=""
        printf "  %-16s %-18s %-12s %-6s " "$u" "$p" "$e" "$cd"
        if [[ "$hwid" == "unbound" ]]; then
            echo -e "${Y}unbound${NC} $el"; unbound_count=$((unbound_count+1))
        else
            echo -e "${M}${hwid}${NC} $el"; bound=$((bound+1))
        fi
    done < "$USERS_DB"
    echo ""
    echo -e "  ${M}Bound: ${bound}${NC}   ${Y}Unbound: ${unbound_count}${NC}"
    [[ "$unbound_count" -gt 0 ]] && echo -e "  ${Y}⚠ Unbound entries have NO device restriction.${NC}"
}

hwid_bind() {
    echo -e "${M}═══ Bind HWID ═══════════════════════════════════════════════${NC}"
    hwid_list_all; echo ""
    read -rp "  Enter PASSWORD of entry to bind: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" 2>/dev/null || { echo -e "${R}  Not found.${NC}"; return; }
    local cu; cu=$(grep ":${tp}:" "$USERS_DB" | cut -d: -f6)
    local uu; uu=$(grep ":${tp}:" "$USERS_DB" | cut -d: -f1)
    echo -e "  User: ${G}${uu}${NC}   Current HWID: ${Y}${cu:-unbound}${NC}"
    read -rp "  New HWID: " nh
    nh=$(echo "$nh" | tr -d ' ')
    [[ -z "$nh" ]] && echo "  Cancelled." && return
    [[ "$nh" == *"${HWID_SEP}"* ]] && echo -e "${R}  HWID cannot contain '|'.${NC}" && return
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${mc}:${nh}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    echo -e "${G}  ✓ HWID bound: ${M}${nh}${NC}"
    echo -e "  ${Y}Client must now enter: ${Y}${tp}${M}|${nh}${NC}${Y} in ZIVPN app.${NC}"
}

hwid_add_device() {
    echo -e "${M}═══ Add New Device for Existing User ════════════════════════${NC}"
    list_users
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null || { echo -e "${R}  Not found.${NC}"; return; }
    local inh; inh=$(grep "^${username}:" "$USERS_DB" | head -1 | cut -d: -f3)
    read -rp "  New device password: " np
    np=$(echo "$np" | tr -d ' ')
    [[ -z "$np" ]] && echo -e "${R}  Empty.${NC}" && return
    grep -q ":${np}:" "$USERS_DB" 2>/dev/null && { echo -e "${R}  Password in use.${NC}"; return; }
    [[ "$np" == *"${HWID_SEP}"* ]] && echo -e "${R}  Password cannot contain '|'.${NC}" && return
    read -rp "  New device HWID: " nh
    nh=$(echo "$nh" | tr -d ' ')
    [[ -z "$nh" ]] && nh="unbound"
    echo "${username}:${np}:${inh}:0:1:${nh}" >> "$USERS_DB"
    rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  ✓ Device added.${NC}"
    echo -e "  Password : ${Y}${np}${NC}"
    echo -e "  HWID     : ${M}${nh}${NC}"
    [[ "$nh" != "unbound" ]] && echo -e "  ${W}Client enters:${NC} ${Y}${np}${M}|${nh}${NC}"
}

hwid_unbind() {
    echo -e "${M}═══ Unbind HWID ═════════════════════════════════════════════${NC}"
    read -rp "  Password of entry to unbind: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" 2>/dev/null || { echo -e "${R}  Not found.${NC}"; return; }
    read -rp "  Confirm unbind? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${mc}:unbound" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    echo -e "${G}  HWID unbound. Entry now accepts any device.${NC}"
}

hwid_search() {
    echo -e "${M}═══ Search by HWID ══════════════════════════════════════════${NC}"
    read -rp "  HWID to search: " sh
    sh=$(echo "$sh" | tr -d ' ')
    [[ -z "$sh" ]] && return
    local found=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        if [[ "$hwid" == *"$sh"* ]]; then
            echo -e "  ${G}Match:${NC} user=${G}${u}${NC} pass=${Y}${p}${NC} hwid=${M}${hwid}${NC} expiry=${Y}${e}${NC}"
            found=$((found+1))
        fi
    done < "$USERS_DB"
    [[ "$found" -eq 0 ]] && echo -e "  ${Y}No match found.${NC}" || echo -e "\n  ${found} result(s)."
}

hwid_show_client_string() {
    echo -e "${M}═══ Client Connection Strings ═══════════════════════════════${NC}"
    echo -e "  ${W}Copy the exact string below into the ZIVPN app password field:${NC}"
    echo ""
    local ip; ip=$(get_ip)
    local mode; mode=$(auth_mode)
    if [[ "$mode" != "external" ]]; then
        echo -e "  ${Y}⚠ HWID enforcement is currently OFF.${NC}"
        echo -e "  ${Y}  Enable it via option 21 first.${NC}"
        echo ""
    fi
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        echo -e "  ${W}User:${NC} ${G}${u}${NC}"
        echo -e "  ${W}UDP Server  :${NC} ${Y}${ip}${NC}"
        if [[ "$hwid" != "unbound" ]]; then
            echo -e "  ${W}UDP Password:${NC} ${Y}${p}${M}|${hwid}${NC}   ${G}← paste this EXACTLY${NC}"
        else
            echo -e "  ${W}UDP Password:${NC} ${Y}${p}${NC}   ${Y}(no HWID restriction)${NC}"
        fi
        is_expired "$e" || echo -e "  ${W}Expiry      :${NC} ${Y}${e}${NC}"
        divider
    done < "$USERS_DB"
}

hwid_export() {
    echo -e "${M}═══ Export HWID List ════════════════════════════════════════${NC}"
    local f="/etc/zivpn/hwid_export_$(date +%Y%m%d_%H%M%S).txt"
    {
        echo "# OPUDP HWID Export — $(date)"
        echo "# FORMAT: USERNAME | PASSWORD | EXPIRY | CONN | HWID | STATUS"
        echo "# ────────────────────────────────────────────────────────────"
        while IFS=':' read -r u p e bw mc hwid; do
            [[ -z "$u" ]] && continue
            [[ -z "$hwid" ]] && hwid="unbound"; [[ -z "$mc" ]] && mc=0
            local st; is_expired "$e" && st="EXPIRED" || st="ACTIVE"
            printf "%-16s | %-18s | %-12s | %-6s | %-26s | %s\n" \
                "$u" "$p" "$e" "$mc" "$hwid" "$st"
        done < "$USERS_DB"
    } > "$f"
    echo -e "${G}  Exported: ${Y}${f}${NC}"
    cat "$f"
}

# ══════════════════════════════════════════════════════════════
#  21) HWID Enforcement Setup ← NEW CORE FEATURE
# ══════════════════════════════════════════════════════════════
hwid_enforcement_setup() {
    while true; do
        clear
        local mode; mode=$(auth_mode)
        local auth_st; auth_st=$(systemctl is-active "$AUTH_SVC" 2>/dev/null)

        echo -e "${M}╔══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${M}║         TRUE HWID ENFORCEMENT — Setup & Control              ║${NC}"
        echo -e "${M}╚══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "  Current auth mode  : ${Y}${mode}${NC}"
        if [[ "$auth_st" == "active" ]]; then
            echo -e "  Auth daemon status : ${G}running${NC}"
        else
            echo -e "  Auth daemon status : ${R}stopped${NC}"
        fi
        echo ""
        echo -e "  ${M}────── How True HWID Enforcement Works ──────${NC}"
        echo "  When enabled, ZIVPN uses 'external' auth mode."
        echo "  Every connection attempt calls opudp-authd which:"
        echo "    • Verifies the password exists in users.db"
        echo "    • Checks the account is not expired"
        echo "    • Splits the payload on '|' to extract the HWID"
        echo "    • Compares client HWID against the stored HWID"
        echo "    • DENIES if any check fails — including wrong HWID"
        echo ""
        echo "  Client enters in ZIVPN app:  password|HWID"
        echo "  Example:  abc123|a1b2c3d4e5f6a1b2"
        echo ""
        echo -e "  ${M}─────────────────────────────────────────────${NC}"
        echo ""
        echo -e "  ${M}a)${NC} ${G}ENABLE${NC}  HWID enforcement (switch to external auth)"
        echo -e "  ${M}b)${NC} ${R}DISABLE${NC} HWID enforcement (switch back to passwords)"
        echo -e "  ${M}c)${NC} Start auth daemon"
        echo -e "  ${M}d)${NC} Stop auth daemon"
        echo -e "  ${M}e)${NC} Restart auth daemon"
        echo -e "  ${M}f)${NC} View live auth log (Ctrl+C to stop)"
        echo -e "  ${M}g)${NC} View recent deny log"
        echo -e "  ${M}h)${NC} Test auth daemon manually"
        echo -e "  ${M}0)${NC} Back to main menu"
        echo ""
        echo -ne "${M}Choose ► ${NC}"
        read -r sc; echo ""
        case "$sc" in
            a) hwid_enable_enforcement ;;
            b) hwid_disable_enforcement ;;
            c) systemctl start  "$AUTH_SVC" 2>/dev/null && echo -e "${G}  Auth daemon started.${NC}" || echo -e "${R}  Failed. Run option h to diagnose.${NC}" ;;
            d) systemctl stop   "$AUTH_SVC" 2>/dev/null && echo -e "${R}  Auth daemon stopped.${NC}" ;;
            e) systemctl restart "$AUTH_SVC" 2>/dev/null && echo -e "${G}  Auth daemon restarted.${NC}" ;;
            f) echo -e "${C}  Ctrl+C to stop${NC}"; tail -f "$AUTH_LOG" ;;
            g) hwid_show_deny_log ;;
            h) hwid_test_auth ;;
            0) break ;;
            *) echo -e "${R}  Invalid.${NC}" ;;
        esac
        [[ "$sc" != "0" ]] && pause
    done
}

hwid_enable_enforcement() {
    echo -e "${M}═══ Enable True HWID Enforcement ════════════════════════════${NC}"
    echo ""

    # Check Python3 is available
    if ! command -v python3 &>/dev/null; then
        echo -e "${Y}  Python3 not found. Installing...${NC}"
        apt-get install -y python3 2>/dev/null
        command -v python3 &>/dev/null || { echo -e "${R}  Python3 install failed. Cannot continue.${NC}"; return; }
    fi
    echo -e "  ${G}Python3 found.${NC}"

    # Check auth binary exists
    if [[ ! -f "$AUTH_BIN" ]]; then
        echo -e "${R}  opudp-authd not found at ${AUTH_BIN}${NC}"
        echo -e "  ${Y}Download and place it there, then re-run this option.${NC}"
        return
    fi
    chmod +x "$AUTH_BIN"
    echo -e "  ${G}Auth daemon binary found.${NC}"

    # Install systemd service
    install_auth_service
    sleep 1

    if ! systemctl is-active --quiet "$AUTH_SVC"; then
        echo -e "${R}  Auth daemon failed to start!${NC}"
        echo -e "  ${Y}Check: journalctl -u opudp-auth -n 30${NC}"
        return
    fi
    echo -e "  ${G}Auth daemon is running.${NC}"

    # Check unbound users — warn admin
    local unbound_count=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$hwid" == "unbound" || -z "$hwid" ]] && unbound_count=$((unbound_count+1))
    done < "$USERS_DB"

    if [[ "$unbound_count" -gt 0 ]]; then
        echo ""
        echo -e "  ${Y}⚠ Warning: ${unbound_count} entry/entries have HWID='unbound'.${NC}"
        echo -e "  ${Y}  These entries will accept connections from ANY device.${NC}"
        echo -e "  ${Y}  Use option 20 → b to bind HWIDs to those entries.${NC}"
        echo ""
        read -rp "  Continue enabling enforcement anyway? [y/N]: " uc
        [[ "$uc" != "y" && "$uc" != "Y" ]] && echo "  Cancelled." && return
    fi

    # Switch ZIVPN to external auth mode
    rebuild_config_external
    systemctl restart "$SVC" 2>/dev/null
    sleep 1

    if systemctl is-active --quiet "$SVC"; then
        echo ""
        echo -e "${G}  ✓ HWID Enforcement is now ACTIVE!${NC}"
        echo ""
        echo -e "  ${W}What changes for your users:${NC}"
        echo -e "  • They must enter ${Y}password${M}|${Y}HWID${NC} in the ZIVPN app"
        echo -e "  • Wrong HWID = DENIED even with correct password"
        echo -e "  • No HWID in password field = DENIED"
        echo -e "  • Unbound entries still accept any HWID"
        echo ""
        echo -e "  ${W}How to get Android HWID:${NC}"
        echo -e "  • Settings → About Phone → Android ID"
        echo -e "  • Termux: ${Y}settings get secure android_id${NC}"
        echo -e "  • Dial:   ${Y}*#*#8255#*#*${NC}"
    else
        echo -e "${R}  ZIVPN failed to restart. Reverting to passwords mode.${NC}"
        rebuild_config_passwords
        systemctl restart "$SVC" 2>/dev/null
    fi
}

hwid_disable_enforcement() {
    echo -e "${M}═══ Disable HWID Enforcement ════════════════════════════════${NC}"
    echo ""
    echo -e "  ${Y}This switches ZIVPN back to plain password mode.${NC}"
    echo -e "  ${Y}Any device with the correct password can connect.${NC}"
    read -rp "  Confirm disable HWID enforcement? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    rebuild_config_passwords
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  HWID enforcement disabled. Switched to passwords mode.${NC}"
}

hwid_show_deny_log() {
    echo -e "${M}═══ Recent DENY Events ══════════════════════════════════════${NC}"
    echo ""
    if [[ ! -f "$AUTH_LOG" ]]; then
        echo -e "  ${Y}No auth log found yet.${NC}"; return
    fi
    local denies
    denies=$(grep "DENY" "$AUTH_LOG" 2>/dev/null | tail -30)
    if [[ -z "$denies" ]]; then
        echo -e "  ${G}No DENY events recorded yet.${NC}"
    else
        echo "$denies" | while read -r line; do
            echo -e "  ${R}${line}${NC}"
        done
    fi
    echo ""
    echo -e "  Full log: ${Y}${AUTH_LOG}${NC}"
    echo -e "  Conn log: ${Y}${CONN_LOG}${NC}"
}

hwid_test_auth() {
    echo -e "${M}═══ Test Auth Daemon ════════════════════════════════════════${NC}"
    echo ""
    if ! systemctl is-active --quiet "$AUTH_SVC"; then
        echo -e "${R}  Auth daemon is not running. Start it first (option c).${NC}"; return
    fi
    echo -e "  Sending test request to auth daemon on port ${AUTH_PORT}..."
    echo ""

    # Test 1: no HWID separator
    local r1
    r1=$(curl -s -X POST "http://127.0.0.1:${AUTH_PORT}/auth" \
        -H "Content-Type: application/json" \
        -d '{"addr":"1.2.3.4:1234","payload":"testpassword"}' 2>/dev/null)
    echo -ne "  Test 1 — No HWID separator:  "
    echo "$r1" | grep -q '"ok":false' \
        && echo -e "${G}DENIED correctly${NC} ${Y}(${r1})${NC}" \
        || echo -e "${R}Unexpected: ${r1}${NC}"

    # Test 2: random wrong password
    local r2
    r2=$(curl -s -X POST "http://127.0.0.1:${AUTH_PORT}/auth" \
        -H "Content-Type: application/json" \
        -d '{"addr":"1.2.3.4:1234","payload":"wrongpassword|randomhwid"}' 2>/dev/null)
    echo -ne "  Test 2 — Wrong password:     "
    echo "$r2" | grep -q '"ok":false' \
        && echo -e "${G}DENIED correctly${NC} ${Y}(${r2})${NC}" \
        || echo -e "${R}Unexpected: ${r2}${NC}"

    # Test 3: real user (pick first bound entry)
    local tp th tu
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        if [[ "$hwid" != "unbound" && -n "$hwid" ]]; then
            tp="$p"; th="$hwid"; tu="$u"; break
        fi
    done < "$USERS_DB"

    if [[ -n "$tp" ]]; then
        local r3
        r3=$(curl -s -X POST "http://127.0.0.1:${AUTH_PORT}/auth" \
            -H "Content-Type: application/json" \
            -d "{\"addr\":\"1.2.3.4:1234\",\"payload\":\"${tp}|${th}\"}" 2>/dev/null)
        echo -ne "  Test 3 — Valid pass+HWID (${tu}): "
        echo "$r3" | grep -q '"ok":true' \
            && echo -e "${G}ALLOWED correctly${NC} ${Y}(${r3})${NC}" \
            || echo -e "${R}Unexpected — check users.db: ${r3}${NC}"

        # Test 4: correct password, WRONG HWID
        local r4
        r4=$(curl -s -X POST "http://127.0.0.1:${AUTH_PORT}/auth" \
            -H "Content-Type: application/json" \
            -d "{\"addr\":\"1.2.3.4:1234\",\"payload\":\"${tp}|WRONGHWID0000\"}" 2>/dev/null)
        echo -ne "  Test 4 — Correct pass, WRONG HWID: "
        echo "$r4" | grep -q '"ok":false' \
            && echo -e "${G}DENIED correctly${NC} ${Y}(${r4})${NC}" \
            || echo -e "${R}NOT denied — HWID enforcement may be broken: ${r4}${NC}"
    else
        echo -e "  ${Y}Test 3 & 4 skipped — no HWID-bound entries found. Add one first.${NC}"
    fi

    echo ""
    echo -e "  ${G}Tests complete.${NC} All 4 should show 'correctly'.${NC}"
}

