# ══════════════════════════════════════════════════════════════
#  16) Restore Backup
# ══════════════════════════════════════════════════════════════
restore_backup() {
    ls "$BACKUP_DIR"/*.tar.gz 2>/dev/null || { echo -e "  ${Y}No backups.${NC}"; return; }
    echo ""; ls -lh "$BACKUP_DIR"/*.tar.gz | awk '{print "  "$9, $5}'; echo ""
    read -rp "  Filename: " bn
    local bp="${BACKUP_DIR}/${bn}"
    [[ ! -f "$bp" ]] && echo -e "${R}  Not found.${NC}" && return
    read -rp "  Restore '${bn}'? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    tar -xzf "$bp" -C / 2>/dev/null
    migrate_db; rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Restored.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  17) Change Port Range
# ══════════════════════════════════════════════════════════════
change_port() {
    local cur; cur=$(get_port)
    local os oe; os=$(echo "$cur"|cut -d: -f1); oe=$(echo "$cur"|cut -d: -f2)
    echo -e "  Current: ${Y}${cur}${NC}"
    read -rp "  New start: " ps; read -rp "  New end: " pe
    [[ -z "$ps" || -z "$pe" ]] && echo -e "${R}  Invalid.${NC}" && return
    [[ ! "$ps" =~ ^[0-9]+$ || ! "$pe" =~ ^[0-9]+$ ]] && echo -e "${R}  Not numbers.${NC}" && return
    [[ "$ps" -ge "$pe" ]] && echo -e "${R}  Start must be less than end.${NC}" && return
    local iface; iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${os}:${oe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -t nat -A PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}"
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${os}:${oe}/udp" 2>/dev/null
    ufw allow "${ps}:${pe}/udp" 2>/dev/null
    echo "${ps}:${pe}" > "$PORT_FILE"
    echo -e "${G}  Port range → ${ps}:${pe}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  18) Auto-Update
# ══════════════════════════════════════════════════════════════
auto_update() {
    echo -e "${C}═══ Auto-Update ═════════════════════════════════════════════${NC}"
    systemctl stop "$SVC" 2>/dev/null
    wget -q --show-progress \
        "https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64" \
        -O "${BIN}.new" \
        && chmod +x "${BIN}.new" && mv "${BIN}.new" "$BIN" \
        && echo -e "${G}  ZIVPN binary updated.${NC}" \
        || { rm -f "${BIN}.new"; echo -e "${R}  Download failed.${NC}"; }
    systemctl start "$SVC"
    echo ""
    wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new 2>/dev/null \
        && chmod +x /usr/local/bin/opudp.new \
        && mv /usr/local/bin/opudp.new /usr/local/bin/opudp \
        && echo -e "${G}  OPUDP panel updated. Re-run 'opudp'.${NC}" \
        || echo -e "${Y}  Panel update skipped.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  19) Set Connection Limit
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Enter password of entry to update: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" || { echo -e "${R}  Not found.${NC}"; return; }
    echo "    1)1  2)2  3)3  4)5  5)10  6)Unlimited  7)Custom"
    read -rp "  Choose: " cc
    case $cc in
        1) nl=1;; 2) nl=2;; 3) nl=3;; 4) nl=5;; 5) nl=10;; 6) nl=0;;
        7) read -rp "  Number: " nl; [[ ! "$nl" =~ ^[0-9]+$ ]] && nl=0;;
        *) echo -e "${R}  Invalid.${NC}"; return;;
    esac
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${nl}:${hwid}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    apply_conn_limits
    local lb; [[ "$nl" -eq 0 ]] && lb="Unlimited" || lb="${nl}"
    echo -e "${G}  Limit set to: ${lb}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  20) HWID Management
# ══════════════════════════════════════════════════════════════
hwid_menu() {
    while true; do
        clear
        echo -e "${M}╔══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${M}║              HWID Device Management                          ║${NC}"
        echo -e "${M}╚══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "  ${M}a)${NC} List all HWID bindings"
        echo -e "  ${M}b)${NC} Bind / update HWID for an entry"
        echo -e "  ${M}c)${NC} Add new device for existing user"
        echo -e "  ${M}d)${NC} Remove / unbind HWID"
        echo -e "  ${M}e)${NC} Search by HWID"
        echo -e "  ${M}f)${NC} Show client connection strings"
        echo -e "  ${M}g)${NC} Export HWID list"
        echo -e "  ${M}0)${NC} Back"
        echo ""
        echo -ne "${M}Choose ► ${NC}"
        read -r hc; echo ""
        case "$hc" in
            a) hwid_list_all    ;;
            b) hwid_bind        ;;
            c) hwid_add_device  ;;
            d) hwid_unbind      ;;
            e) hwid_search      ;;
            f) hwid_client_strings ;;
            g) hwid_export      ;;
            0) break ;;
            *) echo -e "${R}  Invalid.${NC}" ;;
        esac
        [[ "$hc" != "0" ]] && pause
    done
}

hwid_list_all() {
    echo -e "${M}═══ All HWID Bindings ═══════════════════════════════════════${NC}"
    [[ ! -s "$USERS_DB" ]] && echo -e "  ${Y}No users.${NC}" && return
    local bound=0 unbound_c=0
    printf "\n  %-16s %-16s %-12s %-6s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "CONN" "HWID"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$hwid" ]] && hwid="unbound"
        [[ -z "$mc"   ]] && mc=0
        local cd el zp
        [[ "$mc" -eq 0 ]] && cd="∞" || cd="$mc"
        is_expired "$e" && el="${R}[EXP]${NC}" || el=""
        zp=$(zivpn_password "$p" "$hwid")
        printf "  %-16s %-16s %-12s %-6s " "$u" "$p" "$e" "$cd"
        if [[ "$hwid" == "unbound" ]]; then
            echo -e "${Y}unbound${NC} $el"
            unbound_c=$((unbound_c+1))
        else
            echo -e "${M}${hwid}${NC} $el"
            bound=$((bound+1))
        fi
    done < "$USERS_DB"
    echo ""
    echo -e "  ${M}HWID-Locked: ${bound}${NC}   ${Y}Unbound: ${unbound_c}${NC}"
    [[ "$unbound_c" -gt 0 ]] && \
        echo -e "  ${Y}⚠ Unbound entries accept connections from ANY device.${NC}"
}

hwid_bind() {
    echo -e "${M}═══ Bind / Update HWID ══════════════════════════════════════${NC}"
    hwid_list_all; echo ""
    read -rp "  Enter PASSWORD of entry to bind: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" || { echo -e "${R}  Not found.${NC}"; return; }
    local cu uu
    cu=$(grep ":${tp}:" "$USERS_DB" | cut -d: -f6)
    uu=$(grep ":${tp}:" "$USERS_DB" | cut -d: -f1)
    echo -e "  User: ${G}${uu}${NC}   Current HWID: ${Y}${cu:-unbound}${NC}"
    read -rp "  New HWID: " nh
    nh=$(echo "$nh" | tr -d ' ')
    [[ -z "$nh" ]] && echo "  Cancelled." && return
    [[ "$nh" == *"${HWID_SEP}"* ]] && echo -e "${R}  HWID cannot contain '|'.${NC}" && return
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${mc}:${nh}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    systemctl restart "$SVC" 2>/dev/null
    local zp; zp=$(zivpn_password "$tp" "$nh")
    echo -e "${G}  ✓ HWID bound and config updated!${NC}"
    echo -e "  Client must now type in ZIVPN app: ${Y}${zp}${NC}"
}

hwid_add_device() {
    echo -e "${M}═══ Add New Device for Existing User ════════════════════════${NC}"
    list_users
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" || { echo -e "${R}  Not found.${NC}"; return; }
    local inh; inh=$(grep "^${username}:" "$USERS_DB" | head -1 | cut -d: -f3)
    read -rp "  New device password: " np
    np=$(echo "$np" | tr -d ' ')
    [[ -z "$np" ]] && echo -e "${R}  Empty.${NC}" && return
    grep -q ":${np}:" "$USERS_DB" && { echo -e "${R}  Password in use.${NC}"; return; }
    [[ "$np" == *"${HWID_SEP}"* ]] && echo -e "${R}  Password cannot contain '|'.${NC}" && return
    read -rp "  New device HWID: " nh
    nh=$(echo "$nh" | tr -d ' ')
    [[ -z "$nh" ]] && nh="unbound"
    echo "${username}:${np}:${inh}:0:1:${nh}" >> "$USERS_DB"
    rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    local zp; zp=$(zivpn_password "$np" "$nh")
    echo -e "${G}  ✓ Device added.${NC}"
    echo -e "  Client types in ZIVPN app: ${Y}${zp}${NC}"
}

hwid_unbind() {
    echo -e "${M}═══ Unbind HWID ═════════════════════════════════════════════${NC}"
    read -rp "  Password of entry to unbind: " tp
    tp=$(echo "$tp" | tr -d ' ')
    grep -q ":${tp}:" "$USERS_DB" || { echo -e "${R}  Not found.${NC}"; return; }
    read -rp "  Confirm unbind? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$p" == "$tp" ]] \
            && echo "${u}:${p}:${e}:${bw}:${mc}:unbound" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  HWID unbound. Entry now accepts any device.${NC}"
}

hwid_search() {
    read -rp "  HWID to search: " sh
    sh=$(echo "$sh" | tr -d ' ')
    [[ -z "$sh" ]] && return
    local found=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        if [[ "$hwid" == *"$sh"* ]]; then
            echo -e "  ${G}Match:${NC} user=${G}${u}${NC} pass=${Y}${p}${NC} hwid=${M}${hwid}${NC} expiry=${Y}${e}${NC}"
            found=$((found+1))
        fi
    done < "$USERS_DB"
    [[ "$found" -eq 0 ]] && echo -e "  ${Y}No match found.${NC}" \
        || echo -e "\n  ${found} result(s)."
}

hwid_client_strings() {
    echo -e "${M}═══ Client Connection Strings ═══════════════════════════════${NC}"
    echo -e "  ${W}Give these EXACT strings to each user for their ZIVPN app:${NC}"
    echo ""
    local ip; ip=$(get_ip)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        local zp; zp=$(zivpn_password "$p" "$hwid")
        echo -e "  ${W}User: ${G}${u}${NC}"
        echo -e "  UDP Server   → ${Y}${ip}${NC}"
        echo -e "  UDP Password → ${Y}${zp}${NC}"
        [[ "$hwid" != "unbound" ]] \
            && echo -e "  HWID Locked  → ${M}Yes — wrong device = DENIED${NC}" \
            || echo -e "  HWID Locked  → ${Y}No — any device accepted${NC}"
        echo -e "  Expiry       → ${Y}${e}${NC}"
        divider
    done < "$USERS_DB"
}

hwid_export() {
    local f="/etc/zivpn/hwid_export_$(date +%Y%m%d_%H%M%S).txt"
    {
        echo "# OPUDP HWID Export — $(date)"
        printf "%-16s | %-16s | %-34s | %-12s | %-26s | %s\n" \
            "USERNAME" "PASSWORD" "ZIVPN_PASSWORD (type in app)" "EXPIRY" "HWID" "STATUS"
        echo "# ────────────────────────────────────────────────────────────────────────────"
        while IFS=':' read -r u p e bw mc hwid; do
            [[ -z "$u" ]] && continue
            [[ -z "$hwid" ]] && hwid="unbound"
            local zp st
            zp=$(zivpn_password "$p" "$hwid")
            is_expired "$e" && st="EXPIRED" || st="ACTIVE"
            printf "%-16s | %-16s | %-34s | %-12s | %-26s | %s\n" \
                "$u" "$p" "$zp" "$e" "$hwid" "$st"
        done < "$USERS_DB"
    } > "$f"
    echo -e "${G}  Exported: ${Y}${f}${NC}"
    echo ""
    cat "$f"
}

