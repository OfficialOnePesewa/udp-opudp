    [[ "$quota_mb" -eq 0 ]] && bw_label="Unlimited"   || bw_label=$(fmt_mb "$quota_mb")

    echo ""
    echo -e "${OR}  ╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${OR}  ║${GO}  ✓ USER ADDED SUCCESSFULLY!                       ${OR}║${NC}"
    echo -e "${OR}  ╠═══════════════════════════════════════════════════╣${NC}"
    echo -e "${OR}  ║${NC}  Server IP   : ${GO}${srv_ip}${NC}"
    echo -e "${OR}  ║${NC}  Server Loc  : ${GO}${flag} ${country} — ${city}${NC}"
    echo -e "${OR}  ║${NC}  Password    : ${GO}${password}${NC}  ${G}← enter in ZIVPN app${NC}"
    echo -e "${OR}  ║${NC}  Expiry      : ${GO}${expiry}${NC}"
    echo -e "${OR}  ║${NC}  Max Devices : ${GO}${conn_label}${NC}"
    echo -e "${OR}  ║${NC}  Data Quota  : ${GO}${bw_label}${NC}  ${DIM}← decreases as user uses data${NC}"
    echo -e "${OR}  ║${NC}  BW Used     : ${GO}0 B${NC}  ${DIM}(live — updates every 60s)${NC}"
    echo -e "${OR}  ║${NC}  Created     : ${GO}${TODAY}${NC}"
    echo -e "${OR}  ╚═══════════════════════════════════════════════════╝${NC}"
    _print_copy_block "$srv_ip" "$flag" "$country" "$city" \
        "$password" "$expiry" "$conn_label" "$bw_label" "NORMAL"
}

# ══════════════════════════════════════════════════════════════
#  7) Remove User
# ══════════════════════════════════════════════════════════════
remove_user() {
    fire_header "Remove User"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to remove: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null || {
        echo -e "${FR}Not found.${NC}"; return; }
    read -rp "  Confirm remove '${username}'? [y/N]: " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
    local pass; pass=$(grep "^${username}:" "$USERS_DB" | cut -d: -f2)
    sed -i "/^${username}:/d" "$USERS_DB"
    sed -i "/^${username}:/d" "$TRIALS_DB"                 2>/dev/null
    rm -f "${SESSIONS_DIR}/${pass}.sessions"                2>/dev/null
    rm -f "${LASTSEEN_DIR}/${username}"                     2>/dev/null
    rm -f "${BWUSED_DIR}/${username}"                       2>/dev/null
    rm -f "${BWUSED_DIR}/.${username}_raw"                  2>/dev/null
    rm -f "${BWUSED_DIR}/.${username}_blocked"              2>/dev/null
    rebuild_config; apply_conn_limits; systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  ✓ '${username}' removed.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  8) Renew / Extend
# ══════════════════════════════════════════════════════════════
renew_user() {
    fire_header "Renew / Extend User"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to renew: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null || {
        echo -e "${FR}Not found.${NC}"; return; }

    echo ""
    echo -e "  ${OR}╔════════════════════════════════════╗${NC}"
    echo -e "  ${OR}║${GO}      NEW EXPIRY OPTIONS             ${OR}║${NC}"
    echo -e "  ${OR}╠════════════════════════════════════╣${NC}"
    echo -e "  ${OR}║${NC}  1) 1 month    2) 3 months          ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  3) 6 months   4) 1 year            ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  5) Never      6) Custom days        ${OR}║${NC}"
    echo -e "  ${OR}║${NC}  7) Custom date (YYYY-MM-DD)         ${OR}║${NC}"
    echo -e "  ${OR}╚════════════════════════════════════╝${NC}"
    read -rp "  Choose [1-7]: " ec
    local new_expiry cd
    case $ec in
        1) new_expiry=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) new_expiry=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) new_expiry=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) new_expiry=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) new_expiry="never" ;;
        6) read -rp "  Days: " cd
           [[ ! "$cd" =~ ^[0-9]+$ || $cd -lt 1 ]] && echo -e "${FR}Invalid.${NC}" && return
           new_expiry=$(date -d "+${cd} days" +%Y-%m-%d)
           echo -e "  ${GO}Expiry: ${W}${new_expiry}${NC} ${DIM}(${cd} days)${NC}" ;;
        7) read -rp "  Date (YYYY-MM-DD): " new_expiry
           date -d "$new_expiry" +%Y-%m-%d &>/dev/null || { echo -e "${FR}Invalid.${NC}"; return; } ;;
        *) echo -e "${FR}Invalid.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*\):[^:]*:\([^:]*:[^:]*:[^:]*\)$/\1:${new_expiry}:\2/" "$USERS_DB"
    sed -i "/^${username}:/d" "$TRIALS_DB" 2>/dev/null
    rebuild_config; systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  ✓ '${username}' → new expiry: ${GO}${new_expiry}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  9) Cleanup Expired
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    fire_header "Cleanup Expired Users"
    local count=0 tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc cd; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${FR}✗ ${u}${NC} ${DIM}(expired: ${e})${NC}"
            sed -i "/^${u}:/d" "$TRIALS_DB"            2>/dev/null
            rm -f "${SESSIONS_DIR}/${p}.sessions"       2>/dev/null
            rm -f "${LASTSEEN_DIR}/${u}"                2>/dev/null
            rm -f "${BWUSED_DIR}/${u}"                  2>/dev/null
            rm -f "${BWUSED_DIR}/.${u}_raw"             2>/dev/null
            rm -f "${BWUSED_DIR}/.${u}_blocked"         2>/dev/null
            count=$(( count+1 ))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}:${cd}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config; apply_conn_limits; systemctl restart "$SVC" 2>/dev/null
    echo ""; echo -e "${G}  ✓ Removed ${count} expired user(s).${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) Connection Stats
# ══════════════════════════════════════════════════════════════
conn_stats() {
    fire_header "Connection Stats"
    echo -e "  ${OR}Live connections:${NC} ${GO}$(count_live_connections)${NC}"
    echo ""
    local ips; ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Connected IPs:${NC}"
        while read -r ip; do [[ -n "$ip" ]] && echo -e "    ${GO}→ ${ip}${NC}"; done <<< "$ips"
    else
        echo -e "  ${YW}No active connections.${NC}"
    fi
    echo ""; fire_divider; echo ""
    [[ ! -s "$USERS_DB" ]] && return
    printf "  ${OR}%-16s %-12s %-12s %-14s %-18s %s${NC}\n" \
        "USERNAME" "USED" "QUOTA" "REMAINING" "LAST SEEN" "STATUS"
    fire_divider
    while IFS=':' read -r u p e quota mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$quota" ]] && quota=0
        local used_b q_fmt used_fmt rem_fmt conn_status
        used_b=$(get_used_bytes "$u")
        used_fmt=$(fmt_bytes "$used_b")
        if [[ "$quota" -eq 0 ]]; then
            q_fmt="∞"; rem_fmt="∞"
        else
            local qb=$(( quota * 1048576 ))
            local rb=$(( qb - used_b )); [[ $rb -lt 0 ]] && rb=0
            q_fmt=$(fmt_mb "$quota"); rem_fmt=$(fmt_bytes "$rb")
        fi
        if is_bw_blocked "$u"; then conn_status="${FR}🚫 EXHAUSTED${NC}"
        elif is_expired "$e";    then conn_status="${FR}EXPIRED${NC}"
        else conn_status="${G}ACTIVE${NC}"
        fi
        printf "  %-16s %-12s %-12s %-14s %-18s " \
            "$u" "$used_fmt" "$q_fmt" "$rem_fmt" "$(get_lastseen "$u")"
        echo -e "$conn_status"
    done < "$USERS_DB"
}

# ══════════════════════════════════════════════════════════════
#  11) Bandwidth Report
# ══════════════════════════════════════════════════════════════
bw_report() {
    fire_header "Bandwidth Usage Report"
    local iface rx tx
    iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    echo -e "  ${OR}Interface :${NC} ${GO}${iface}${NC}"
    echo -e "  ${OR}Server RX :${NC} ${GO}$(fmt_bytes "$rx")${NC}  ${DIM}(total inbound since boot)${NC}"
    echo -e "  ${OR}Server TX :${NC} ${GO}$(fmt_bytes "$tx")${NC}  ${DIM}(total outbound since boot)${NC}"
    echo ""; fire_divider; echo ""
    [[ ! -s "$USERS_DB" ]] && return

    while IFS=':' read -r u p e quota mc cd; do
        [[ -z "$u" ]] && continue
        [[ -z "$quota" ]] && quota=0
        [[ -z "$cd"    ]] && cd="?"

        local used_b quota_b remaining_b
        local used_fmt quota_fmt remaining_fmt dl du status
        dl=$(days_left "$e"); du=$(days_used "$cd")
        used_b=$(get_used_bytes "$u")
        used_fmt=$(fmt_bytes "$used_b")

        if [[ "$quota" -eq 0 ]]; then
            quota_fmt="Unlimited"; remaining_fmt="Unlimited"; remaining_b=0
        else
            quota_b=$(( quota * 1048576 ))
            quota_fmt=$(fmt_mb "$quota")
            remaining_b=$(( quota_b - used_b ))
            [[ $remaining_b -lt 0 ]] && remaining_b=0
            remaining_fmt=$(fmt_bytes "$remaining_b")
        fi

        if is_bw_blocked "$u"; then
            status="${FR}🚫 DATA EXHAUSTED — BLOCKED${NC}"
        elif is_expired "$e"; then
            status="${FR}✗ EXPIRED${NC}"
        else
            status="${G}✓ ACTIVE${NC}"
        fi

        echo -e "${OR}  ┌──────────────────────────────────────────────────────┐${NC}"
        printf   "  ${OR}│${NC}  ${W}%-14s${NC}  created: ${DIM}%-12s${NC}  days left: ${GO}%s${NC}\n" \
            "$u" "$cd" "${dl}d"
        echo -ne "  ${OR}│${NC}  Status    : "; echo -e "$status"
        echo -e  "  ${OR}│${NC}"
        echo -e  "  ${OR}│${NC}  ${FR}▶ Used     : ${FR}${used_fmt}${NC}"
        echo -e  "  ${OR}│${NC}  ${W}▶ Quota    : ${W}${quota_fmt}${NC}  ${DIM}(total allowed)${NC}"
        echo -e  "  ${OR}│${NC}  ${GO}▶ Remaining: ${GO}${remaining_fmt}${NC}  ${DIM}(quota minus used)${NC}"
        echo -e  "  ${OR}│${NC}"
        echo -ne "  ${OR}│${NC}  Progress  : "
        bw_bar "$used_b" "$quota"
        echo -e "${OR}  └──────────────────────────────────────────────────────┘${NC}"
        echo ""
    done < "$USERS_DB"
    echo -e "  ${DIM}Counter updates every 60s and survives reboots/restarts.${NC}"
    echo -e "  ${DIM}To reset a user's counter → option 12.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  12) Reset Bandwidth
# ══════════════════════════════════════════════════════════════
reset_bandwidth() {
    fire_header "Reset User Bandwidth"
    echo ""
    echo -e "  ${OR}What to reset?${NC}"
    echo "    1) One specific user"
    echo "    2) ALL users"
    echo "    3) Server iptables counters only"
    echo ""
    read -rp "  Choose [1-3]: " rc
    case $rc in
        1)
            list_users
            [[ ! -s "$USERS_DB" ]] && return
            read -rp "  Username: " username
            username=$(echo "$username" | tr -d ' ')
            grep -q "^${username}:" "$USERS_DB" 2>/dev/null || {
                echo -e "${FR}Not found.${NC}"; return; }
            local used_b; used_b=$(get_used_bytes "$username")
            echo -e "  ${OR}Current usage : ${FR}$(fmt_bytes "$used_b")${NC}"
            read -rp "  Reset '${username}' bandwidth to 0? [y/N]: " confirm
            [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
            reset_bw "$username"
            rebuild_config; systemctl restart "$SVC" 2>/dev/null
            echo -e "${G}  ✓ Bandwidth reset. '${username}' can connect again.${NC}"
            ;;
        2)
            read -rp "  Reset ALL users to 0? [y/N]: " confirm
            [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
            while IFS=':' read -r u p e bw mc cd; do
                [[ -z "$u" ]] && continue
                reset_bw "$u"
            done < "$USERS_DB"
            rebuild_config; systemctl restart "$SVC" 2>/dev/null
            echo -e "${G}  ✓ All users reset to 0.${NC}"
            ;;
        3)
            read -rp "  Reset iptables counters? [y/N]: " confirm
            [[ "$confirm" != "y" && "$confirm" != "Y" ]] && echo "  Cancelled." && return
            iptables -Z 2>/dev/null
            # Also reset raw snapshots so delta restarts cleanly
            find "$BWUSED_DIR" -name ".*_raw" -delete 2>/dev/null
            echo -e "${G}  ✓ iptables counters + snapshots reset.${NC}"
            ;;
        *) echo -e "${FR}Invalid.${NC}" ;;
    esac
}

