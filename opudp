#!/bin/bash
# ============================================================
#  OPUDP — ZIVPN UDP Ultimate Control Panel
#  Author  : OfficialOnePesewa
#  GitHub  : https://github.com/OfficialOnePesewa/udp-opudp
#  Command : opudp
#  Version : 4.0.0  (True HWID Enforcement Edition)
# ============================================================
#
#  HOW TRUE HWID ENFORCEMENT WORKS:
#  ─────────────────────────────────────────────────────────
#  ZIVPN is switched from "passwords" mode to "external" auth.
#  On every connection attempt, ZIVPN calls opudp-authd
#  (a local HTTP server on 127.0.0.1:7777) to validate.
#
#  The auth daemon checks THREE things before allowing:
#    1. Is the password registered?
#    2. Is the account not expired?
#    3. Does the HWID match what's stored for this password?
#
#  If ANY check fails → connection is DENIED immediately.
#  An unregistered device with the correct password = DENIED.
#
#  CLIENT SETUP (user must enter in ZIVPN app):
#    UDP Password field:  mypassword|DEVICE_HWID
#    Separator: | (pipe character)
#
#  HOW TO GET ANDROID HWID:
#    Method 1: Settings → About Phone → Android ID
#    Method 2: Dial  *#*#8255#*#*  (Google Talk Service Monitor)
#    Method 3: Use "Device ID" app from Play Store
#    Method 4: Run in Termux:  settings get secure android_id
#
#  users.db format (v4):
#  username:password:expiry:bandwidth:max_conn:hwid
# ============================================================

CONFIG="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
PORT_FILE="/etc/zivpn/port_range"
BACKUP_DIR="/etc/zivpn/backups"
SESSIONS_DIR="/etc/zivpn/sessions"
CONN_LOG="/etc/zivpn/connections.log"
AUTH_LOG="/etc/zivpn/auth.log"
SVC="zivpn"
AUTH_SVC="opudp-auth"
BIN="/usr/local/bin/zivpn"
AUTH_BIN="/usr/local/bin/opudp-authd"
AUTH_SVC_FILE="/etc/systemd/system/opudp-auth.service"
LISTEN_PORT="5667"
AUTH_PORT="7777"
PANEL_VERSION="4.0.0"
HWID_SEP="|"
GITHUB_RAW="https://raw.githubusercontent.com/OfficialOnePesewa/udp-opudp/main"

# ── Colours ──────────────────────────────────────────────────
R='\033[0;31m' ; G='\033[0;32m' ; Y='\033[1;33m'
C='\033[0;36m' ; W='\033[1;37m' ; B='\033[0;34m'
M='\033[0;35m' ; NC='\033[0m'

# ── Guard ─────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${R}Run as root: sudo opudp${NC}" && exit 1

# ── Init ──────────────────────────────────────────────────────
init() {
    mkdir -p /etc/zivpn "$BACKUP_DIR" "$SESSIONS_DIR"
    [[ ! -f "$USERS_DB"  ]] && touch "$USERS_DB"
    [[ ! -f "$PORT_FILE" ]] && echo "6000:19999" > "$PORT_FILE"
    [[ ! -f "$CONN_LOG"  ]] && touch "$CONN_LOG"
    [[ ! -f "$AUTH_LOG"  ]] && touch "$AUTH_LOG"
    migrate_db
    ensure_auth_service
}

# ── Migrate DB ────────────────────────────────────────────────
migrate_db() {
    local tmp changed=0
    tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0       && changed=1
        [[ -z "$hwid" ]] && hwid="unbound" && changed=1
        echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    [[ $changed -eq 1 ]] && mv "$tmp" "$USERS_DB" || rm -f "$tmp"
}

# ── Ensure auth service is installed ──────────────────────────
ensure_auth_service() {
    # Install Python auth daemon systemd service if not present
    if [[ ! -f "$AUTH_SVC_FILE" ]]; then
        install_auth_service
    fi
}

install_auth_service() {
    if [[ ! -f "$AUTH_BIN" ]]; then
        echo -e "${Y}  opudp-authd not found. Run option 21 to install HWID enforcement.${NC}"
        return
    fi
    cat > "$AUTH_SVC_FILE" << EOF
[Unit]
Description=OPUDP HWID Auth Daemon
After=network.target zivpn.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 ${AUTH_BIN}
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable "$AUTH_SVC" 2>/dev/null
    systemctl start  "$AUTH_SVC" 2>/dev/null
}

# ── Helpers ───────────────────────────────────────────────────
get_ip()   { curl -s4 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'; }
get_port() { cat "$PORT_FILE" 2>/dev/null || echo "6000:19999"; }
today()    { date +%Y-%m-%d; }
pause()    { echo ""; read -rp "  Press Enter to continue..."; }
divider()  { echo -e "${C}──────────────────────────────────────────────────────────────${NC}"; }

is_expired() {
    local exp="$1"
    [[ "$exp" == "never" ]] && return 1
    [[ "$exp" < "$(today)" ]] && return 0
    return 1
}

days_left() {
    local exp="$1"
    [[ "$exp" == "never" ]] && echo "∞" && return
    local now_s exp_s
    now_s=$(date +%s)
    exp_s=$(date -d "$exp" +%s 2>/dev/null) || { echo "?"; return; }
    echo $(( (exp_s - now_s) / 86400 ))
}

auth_mode() {
    # Returns "external" or "passwords"
    grep -o '"mode": *"[^"]*"' "$CONFIG" 2>/dev/null | grep -o '"[^"]*"$' | tr -d '"'
}

count_active() {
    local n=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" || n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

count_live_connections() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u | wc -l
}

get_connected_ips() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u
}

count_hwid_bound() {
    local n=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$hwid" != "unbound" && -n "$hwid" ]] && n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

# ── Config builders ───────────────────────────────────────────
rebuild_config_external() {
    # HWID enforcement mode — ZIVPN calls our auth daemon
    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "external",
    "config": {
      "addr": "http://127.0.0.1:${AUTH_PORT}/auth"
    }
  }
}
EOF
}

rebuild_config_passwords() {
    # Legacy passwords mode — no HWID enforcement
    local pwds=()
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" || -z "$p" ]] && continue
        is_expired "$e" || pwds+=("\"$p\"")
    done < "$USERS_DB"
    local plist=""
    if [[ ${#pwds[@]} -gt 0 ]]; then
        plist=$(printf '%s,' "${pwds[@]}")
        plist="${plist%,}"
    fi
    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
EOF
}

rebuild_config() {
    local mode
    mode=$(auth_mode)
    if [[ "$mode" == "external" ]]; then
        rebuild_config_external
    else
        rebuild_config_passwords
    fi
}

apply_conn_limits() {
    iptables -L INPUT --line-numbers -n 2>/dev/null | \
        grep "connlimit" | awk '{print $1}' | sort -rn | \
        xargs -I{} iptables -D INPUT {} 2>/dev/null
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        if [[ "$mc" -gt 0 ]] 2>/dev/null; then
            iptables -A INPUT -p udp --dport "$LISTEN_PORT" \
                -m connlimit --connlimit-above "$mc" --connlimit-mask 32 \
                -j REJECT --reject-with icmp-port-unreachable 2>/dev/null
        fi
    done < "$USERS_DB"
}

# ── Header ─────────────────────────────────────────────────────
show_header() {
    clear
    local svc_st auth_st users port ip live hwid_count mode mode_label
    svc_st=$(systemctl is-active "$SVC" 2>/dev/null)
    auth_st=$(systemctl is-active "$AUTH_SVC" 2>/dev/null)
    users=$(count_active)
    port=$(get_port)
    ip=$(get_ip)
    live=$(count_live_connections)
    hwid_count=$(count_hwid_bound)
    mode=$(auth_mode)

    if [[ "$mode" == "external" ]]; then
        mode_label="${M}HWID-ENFORCED${NC}"
    else
        mode_label="${Y}passwords (no HWID)${NC}"
    fi

    echo -e "${C}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${C}║${W}     OPUDP — ZIVPN UDP Control Panel  v${PANEL_VERSION}                 ${C}║${NC}"
    echo -e "${C}║${C}     True HWID Device Enforcement Edition                     ${C}║${NC}"
    echo -e "${C}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    printf "  ZIVPN : "
    [[ "$svc_st" == "active" ]] && echo -e "${G}active${NC}" || echo -e "${R}inactive${NC}"
    printf "  Auth  : "
    [[ "$auth_st" == "active" ]] && echo -e "${G}active${NC} (HWID daemon running)" || echo -e "${R}inactive${NC} ${Y}← run option 21!${NC}"
    printf "  Mode  : "
    echo -e "$mode_label"
    echo -e "  Users : ${G}${users}${NC}   Live: ${G}${live}${NC}   HWID-Bound: ${M}${hwid_count}${NC}   IP: ${C}${ip}${NC}   Port: ${Y}${port}${NC}"
    echo ""
}

# ── Menu ───────────────────────────────────────────────────────
show_menu() {
    echo -e "  ${G}1)${NC}  Start ZIVPN              ${G}11)${NC} Bandwidth + Expiry Report"
    echo -e "  ${G}2)${NC}  Stop ZIVPN               ${G}12)${NC} Reset All Bandwidth"
    echo -e "  ${G}3)${NC}  Restart ZIVPN            ${G}13)${NC} Speed Test"
    echo -e "  ${G}4)${NC}  Status                   ${G}14)${NC} Live Logs"
    echo -e "  ${G}5)${NC}  List Users + HWID        ${G}15)${NC} Backup All Data"
    echo -e "  ${G}6)${NC}  Add User                 ${G}16)${NC} Restore Backup"
    echo -e "  ${G}7)${NC}  Remove User              ${G}17)${NC} Change Port Range"
    echo -e "  ${G}8)${NC}  Renew/Extend User        ${G}18)${NC} Auto-Update ZIVPN"
    echo -e "  ${G}9)${NC}  Cleanup Expired Users    ${G}19)${NC} Set Connection Limit"
    echo -e "  ${G}10)${NC} Connection Stats         ${M}20)${NC} ${M}HWID Management${NC}"
    echo -e "                             ${M}21)${NC} ${M}HWID Enforcement Setup${NC}"
    echo -e "                             ${M}22)${NC} ${M}Auth Deny Log (live)${NC}"
    echo -e "                             ${R}99)${NC} UNINSTALL (DANGER)"
    echo -e "  ${G}0)${NC}  Exit"
    echo ""
    echo -ne "${Y}Choose [0-99] ► ${NC}"
}

# ══════════════════════════════════════════════════════════════
#  1) Start
# ══════════════════════════════════════════════════════════════
start_svc() {
    echo -e "${Y}Starting ZIVPN...${NC}"
    systemctl start "$SVC"
    sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}ZIVPN running.${NC}" \
        || echo -e "${R}Failed. Check: journalctl -u zivpn -n 20${NC}"
    if systemctl is-active --quiet "$AUTH_SVC"; then
        echo -e "${G}Auth daemon running.${NC}"
    else
        echo -e "${Y}Auth daemon not running. Starting...${NC}"
        systemctl start "$AUTH_SVC" 2>/dev/null
    fi
}

# ══════════════════════════════════════════════════════════════
#  2) Stop
# ══════════════════════════════════════════════════════════════
stop_svc() {
    systemctl stop "$SVC"
    echo -e "${R}ZIVPN stopped.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  3) Restart
# ══════════════════════════════════════════════════════════════
restart_svc() {
    echo -e "${Y}Restarting ZIVPN + Auth daemon...${NC}"
    systemctl restart "$SVC"
    systemctl restart "$AUTH_SVC" 2>/dev/null
    sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}ZIVPN restarted.${NC}" \
        || echo -e "${R}ZIVPN restart failed.${NC}"
    systemctl is-active --quiet "$AUTH_SVC" \
        && echo -e "${G}Auth daemon restarted.${NC}" \
        || echo -e "${Y}Auth daemon not running.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  4) Status
# ══════════════════════════════════════════════════════════════
show_status() {
    echo -e "${C}═══ ZIVPN ════════════════════════════════════════════════════${NC}"
    systemctl status "$SVC" --no-pager -l
    echo ""
    echo -e "${M}═══ OPUDP Auth Daemon ════════════════════════════════════════${NC}"
    systemctl status "$AUTH_SVC" --no-pager -l 2>/dev/null \
        || echo -e "  ${Y}Auth daemon service not installed. Use option 21.${NC}"
    echo ""
    divider
    echo -e "  Config      : ${Y}${CONFIG}${NC}"
    echo -e "  Auth mode   : ${Y}$(auth_mode)${NC}"
    echo -e "  Users DB    : ${Y}${USERS_DB}${NC}"
    echo -e "  Auth log    : ${Y}${AUTH_LOG}${NC}"
    echo -e "  Conn log    : ${Y}${CONN_LOG}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  5) List Users + HWID
# ══════════════════════════════════════════════════════════════
list_users() {
    echo -e "${C}═══ User List ═══════════════════════════════════════════════${NC}"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users found. Use option 6 to add one.${NC}"
        return
    fi
    printf "\n  %-16s %-18s %-12s %-6s %-6s %-22s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "CONN" "HWID" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0
        [[ -z "$hwid" ]] && hwid="unbound"
        local dl status conn_display hwid_display
        [[ "$mc" -eq 0 ]] && conn_display="∞" || conn_display="$mc"
        [[ ${#hwid} -gt 20 ]] && hwid_display="${hwid:0:17}..." || hwid_display="$hwid"
        if is_expired "$e"; then
            dl="—"; status="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            if [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${Y}EXPIRING${NC}"
            else
                status="${G}ACTIVE${NC}"
            fi
        fi
        [[ "$hwid" == "unbound" ]] \
            && hwid_display="${Y}unbound${NC}" \
            || hwid_display="${M}${hwid_display}${NC}"
        printf "  %-16s %-18s %-12s %-6s %-6s " "$u" "$p" "$e" "$dl" "$conn_display"
        printf "%-22b " "$hwid_display"
        echo -e "$status"
    done < "$USERS_DB"
    echo ""
    echo -e "  ${M}■${NC} HWID bound   ${Y}■${NC} unbound (no device restriction)"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  6) Add User
# ══════════════════════════════════════════════════════════════
add_user() {
    echo -e "${C}═══ Add New User ════════════════════════════════════════════${NC}"
    echo ""
    local mode; mode=$(auth_mode)
    if [[ "$mode" == "external" ]]; then
        echo -e "  ${M}HWID enforcement is ACTIVE.${NC}"
        echo -e "  The client must enter:  ${Y}password${M}|${Y}HWID${NC}  in the ZIVPN app."
    else
        echo -e "  ${Y}HWID enforcement is OFF. Enable it via option 21.${NC}"
    fi
    echo ""

    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}Empty.${NC}" && return

    read -rp "  Password: " password
    password=$(echo "$password" | tr -d ' ')
    [[ -z "$password" ]] && echo -e "${R}Empty.${NC}" && return
    if grep -q ":${password}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}  Password '${password}' already in use!${NC}"; return
    fi
    # Reject pipe in password (it's our HWID separator)
    if [[ "$password" == *"${HWID_SEP}"* ]]; then
        echo -e "${R}  Password cannot contain '${HWID_SEP}' (it is the HWID separator).${NC}"; return
    fi

    echo ""
    echo -e "  ${W}Expiry:${NC}"
    echo "    1) 1 month   2) 3 months  3) 6 months"
    echo "    4) 1 year    5) Never     6) Custom (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " exp_choice
    case $exp_choice in
        1) expiry=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) expiry=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) expiry=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) expiry=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) expiry="never" ;;
        6) read -rp "  Date (YYYY-MM-DD): " expiry
           date -d "$expiry" +%Y-%m-%d &>/dev/null || { echo -e "${R}Invalid.${NC}"; return; } ;;
        *) echo -e "${R}Invalid.${NC}"; return ;;
    esac

    echo ""
    echo -e "  ${W}Connection Limit:${NC}"
    echo "    1) 1 device   2) 2   3) 3   4) 5"
    echo "    5) 10         6) Unlimited  7) Custom"
    echo -e "    ${Y}Recommended: 1 per device when HWID is bound${NC}"
    read -rp "  Choose [1-7]: " cc
    case $cc in
        1) max_conn=1  ;; 2) max_conn=2  ;; 3) max_conn=3  ;;
        4) max_conn=5  ;; 5) max_conn=10 ;; 6) max_conn=0  ;;
        7) read -rp "  Number: " max_conn
           [[ ! "$max_conn" =~ ^[0-9]+$ ]] && max_conn=0 ;;
        *) max_conn=0 ;;
    esac

    echo ""
    echo -e "  ${M}══ HWID Device Binding ══════════════════════════════════════${NC}"
    echo -e "  Enter the device HWID to bind (or press Enter to skip):"
    echo -e "  ${Y}Android: Settings → About Phone → Android ID${NC}"
    echo -e "  ${Y}Termux:  settings get secure android_id${NC}"
    read -rp "  HWID: " hwid
    hwid=$(echo "$hwid" | tr -d ' ')
    [[ -z "$hwid" ]] && hwid="unbound"
    if [[ "$hwid" == *"${HWID_SEP}"* ]]; then
        echo -e "${R}  HWID cannot contain '${HWID_SEP}'.${NC}"; return
    fi
    if [[ "$hwid" != "unbound" ]] && grep -q ":${hwid}$" "$USERS_DB" 2>/dev/null; then
        local dupe_owner; dupe_owner=$(grep ":${hwid}$" "$USERS_DB" | cut -d: -f1 | head -1)
        echo -e "${Y}  Warning: HWID already registered to '${dupe_owner}'.${NC}"
        read -rp "  Continue? [y/N]: " dok
        [[ "$dok" != "y" && "$dok" != "Y" ]] && echo "  Cancelled." && return
    fi

    echo "${username}:${password}:${expiry}:0:${max_conn}:${hwid}" >> "$USERS_DB"
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null

    local server_ip; server_ip=$(get_ip)
    local conn_label; [[ "$max_conn" -eq 0 ]] && conn_label="∞" || conn_label="${max_conn}"
    local mode; mode=$(auth_mode)

    echo ""
    echo -e "${G}  ✓ User '${username}' added!${NC}"
    echo ""
    echo -e "${C}  ╔═══════════ ZIVPN App Configuration ══════════════════╗${NC}"
    echo -e "${C}  ║${NC}  UDP Server   :  ${Y}${server_ip}${NC}"
    if [[ "$mode" == "external" && "$hwid" != "unbound" ]]; then
        echo -e "${C}  ║${NC}  UDP Password :  ${Y}${password}${M}|${hwid}${NC}"
        echo -e "${C}  ║${NC}               ${M}  ↑ Enter EXACTLY as shown (with |)${NC}"
    else
        echo -e "${C}  ║${NC}  UDP Password :  ${Y}${password}${NC}"
        if [[ "$mode" == "external" && "$hwid" == "unbound" ]]; then
            echo -e "${C}  ║${NC}  ${Y}Note: No HWID bound — any HWID accepted for this entry${NC}"
        fi
    fi
    echo -e "${C}  ║${NC}  Expiry       :  ${Y}${expiry}${NC}"
    echo -e "${C}  ║${NC}  Max Devices  :  ${Y}${conn_label}${NC}"
    echo -e "${C}  ║${NC}  HWID         :  ${M}${hwid}${NC}"
    echo -e "${C}  ╚══════════════════════════════════════════════════════╝${NC}"
}

# ══════════════════════════════════════════════════════════════
#  7) Remove User
# ══════════════════════════════════════════════════════════════
remove_user() {
    echo -e "${C}═══ Remove User ═════════════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    echo -e "  ${Y}Enter username to remove all their entries,${NC}"
    echo -e "  ${Y}or username:password to remove a specific device entry.${NC}"
    read -rp "  Input: " input
    input=$(echo "$input" | tr -d ' ')
    [[ -z "$input" ]] && echo "  Cancelled." && return

    if [[ "$input" == *:* ]]; then
        local uname tpass
        uname=$(echo "$input" | cut -d: -f1)
        tpass=$(echo "$input" | cut -d: -f2)
        if ! grep -q "^${uname}:${tpass}:" "$USERS_DB" 2>/dev/null; then
            echo -e "${R}  Entry not found.${NC}"; return
        fi
        read -rp "  Remove device entry for '${uname}' (pass=${tpass})? [y/N]: " c
        [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
        sed -i "/^${uname}:${tpass}:/d" "$USERS_DB"
        rm -f "${SESSIONS_DIR}/${tpass}.sessions" 2>/dev/null
        echo -e "${G}  Device entry removed.${NC}"
    else
        if ! grep -q "^${input}:" "$USERS_DB" 2>/dev/null; then
            echo -e "${R}  User '${input}' not found.${NC}"; return
        fi
        local cnt; cnt=$(grep -c "^${input}:" "$USERS_DB")
        read -rp "  Remove ALL ${cnt} entries for '${input}'? [y/N]: " c
        [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
        while IFS=':' read -r u p e bw mc hwid; do
            [[ "$u" == "$input" ]] && rm -f "${SESSIONS_DIR}/${p}.sessions" 2>/dev/null
        done < "$USERS_DB"
        sed -i "/^${input}:/d" "$USERS_DB"
        echo -e "${G}  All entries for '${input}' removed.${NC}"
    fi
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
}

# ══════════════════════════════════════════════════════════════
#  8) Renew / Extend User
# ══════════════════════════════════════════════════════════════
renew_user() {
    echo -e "${C}═══ Renew / Extend User ═════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to renew (all devices): " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null || { echo -e "${R}Not found.${NC}"; return; }
    echo ""
    echo -e "  ${W}New Expiry:${NC}"
    echo "    1) 1 month   2) 3 months  3) 6 months"
    echo "    4) 1 year    5) Never     6) Custom (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " ec
    case $ec in
        1) ne=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) ne=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) ne=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) ne=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) ne="never" ;;
        6) read -rp "  Date: " ne
           date -d "$ne" +%Y-%m-%d &>/dev/null || { echo -e "${R}Invalid.${NC}"; return; } ;;
        *) echo -e "${R}Invalid.${NC}"; return ;;
    esac
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$u" == "$username" ]] \
            && echo "${u}:${p}:${ne}:${bw}:${mc}:${hwid}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  '${username}' renewed → ${ne}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  9) Cleanup Expired
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    echo -e "${C}═══ Cleanup Expired Users ═══════════════════════════════════${NC}"
    local count=0 tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${R}Removing:${NC} ${u} [${hwid}] expired ${e}"
            rm -f "${SESSIONS_DIR}/${p}.sessions" 2>/dev/null
            count=$((count+1))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Removed ${count} expired entry/entries.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) Connection Stats
# ══════════════════════════════════════════════════════════════
conn_stats() {
    echo -e "${C}═══ Connection Stats ════════════════════════════════════════${NC}"
    echo ""
    echo -e "  Live connections : ${G}$(count_live_connections)${NC}"
    echo -e "  Auth mode        : $(auth_mode)"
    echo ""
    local ips; ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Connected IPs:${NC}"
        while read -r ip; do [[ -n "$ip" ]] && echo -e "    ${G}→${NC} $ip"; done <<< "$ips"
    else
        echo -e "  ${Y}No active connections.${NC}"
    fi
    echo ""
    divider
    printf "\n  %-16s %-18s %-6s %-22s %s\n" "USERNAME" "PASSWORD" "CONN" "HWID" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0
        [[ -z "$hwid" ]] && hwid="unbound"
        local cd hs
        [[ "$mc" -eq 0 ]] && cd="∞" || cd="$mc"
        [[ ${#hwid} -gt 20 ]] && hs="${hwid:0:17}..." || hs="$hwid"
        local cs
        is_expired "$e" && cs="${R}EXPIRED${NC}" || cs="${G}ACTIVE${NC}"
        printf "  %-16s %-18s %-6s %-22s " "$u" "$p" "$cd" "$hs"
        echo -e "$cs"
    done < "$USERS_DB"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  11–16  (bandwidth, reset, speedtest, logs, backup, restore)
# ══════════════════════════════════════════════════════════════
bw_report() {
    echo -e "${C}═══ Bandwidth + Expiry Report ═══════════════════════════════${NC}"
    local iface; iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    local rx tx
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    echo -e "  RX: ${G}$(echo "scale=2; $rx/1048576" | bc) MB${NC}   TX: ${G}$(echo "scale=2; $tx/1048576" | bc) MB${NC}   Interface: ${Y}${iface}${NC}"
    echo ""
    list_users
}

reset_bandwidth() {
    echo -e "${C}═══ Reset Bandwidth Counters ════════════════════════════════${NC}"
    read -rp "  Reset iptables counters? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    iptables -Z 2>/dev/null && echo -e "${G}  Counters reset.${NC}"
}

speed_test() {
