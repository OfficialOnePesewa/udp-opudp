# ══════════════════════════════════════════════════════════════
#  1-4) SERVICE CONTROLS
# ══════════════════════════════════════════════════════════════
start_svc() {
    echo -e "${Y}Starting ZIVPN...${NC}"
    systemctl start "$SVC"; sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}  ZIVPN is now running.${NC}" \
        || echo -e "${R}  Failed. Check: journalctl -u zivpn -n 20${NC}"
}
stop_svc() {
    echo -e "${Y}Stopping ZIVPN...${NC}"
    systemctl stop "$SVC"
    echo -e "${R}  ZIVPN stopped.${NC}"
}
restart_svc() {
    echo -e "${Y}Restarting ZIVPN...${NC}"
    systemctl restart "$SVC"; sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}  ZIVPN restarted.${NC}" \
        || echo -e "${R}  Restart failed.${NC}"
}
show_status() {
    echo -e "${C}═══ ZIVPN Service ═══════════════════════════════════════════${NC}"
    systemctl status "$SVC" --no-pager -l
    echo ""
    echo -e "${C}═══ HWID Monitor ════════════════════════════════════════════${NC}"
    systemctl status opudp-hwid-monitor --no-pager -l
}

# ══════════════════════════════════════════════════════════════
#  5) LIST USERS — shows HWID status
# ══════════════════════════════════════════════════════════════
list_users() {
    echo -e "${C}═══ User List ═══════════════════════════════════════════════${NC}"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users found. Use option 6 to add one.${NC}"; return
    fi
    printf "\n  %-16s %-18s %-11s %-5s %-5s %-17s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "CONN" "HWID / DEVICE IP" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc="0"
        [[ -z "$hwid" ]] && hwid="none"
        [[ -z "$hl"   ]] && hl="0"

        local dl st conn_d hwid_d
        [[ "$mc" -eq 0 ]] && conn_d="∞" || conn_d="$mc"

        # HWID display
        if [[ "$hl" == "1" && "$hwid" != "none" ]]; then
            hwid_d="${M}${hwid}${NC}"
        elif [[ "$hl" == "0" ]]; then
            hwid_d="${Y}awaiting 1st connect${NC}"
        else
            hwid_d="${R}none${NC}"
        fi

        if is_expired "$e"; then
            dl="—"; st="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            [[ "$dl" != "∞" && "$dl" -le 3 ]] \
                && st="${Y}EXPIRING${NC}" || st="${G}ACTIVE${NC}"
        fi

        printf "  %-16s %-18s %-11s %-5s %-5s " "$u" "$p" "$e" "$dl" "$conn_d"
        echo -e "${hwid_d}  ${st}"
    done < "$USERS_DB"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  6) ADD USER — with HWID option
# ══════════════════════════════════════════════════════════════
add_user() {
    echo -e "${C}═══ Add New User ════════════════════════════════════════════${NC}"
    echo ""

    # Username
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}  Username cannot be empty.${NC}" && return
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
        && echo -e "${R}  User '${username}' already exists!${NC}" && return

    # Password
    read -rp "  Password: " password
    password=$(echo "$password" | tr -d ' ')
    [[ -z "$password" ]] && echo -e "${R}  Password cannot be empty.${NC}" && return

    # Expiry
    echo ""
    echo -e "  ${W}Expiry:${NC}"
    echo "    1) 1 month   2) 3 months  3) 6 months"
    echo "    4) 1 year    5) Never     6) Custom (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " ec
    case $ec in
        1) expiry=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) expiry=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) expiry=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) expiry=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) expiry="never" ;;
        6) read -rp "  Date (YYYY-MM-DD): " expiry
           date -d "$expiry" +%Y-%m-%d &>/dev/null \
               || { echo -e "${R}  Invalid date.${NC}"; return; } ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac

    # Connection limit
    echo ""
    echo -e "  ${W}Connection Limit:${NC}"
    echo "    1) 1 device  2) 2 devices  3) 3 devices"
    echo "    4) 5 devices 5) 10 devices 6) Unlimited  7) Custom"
    read -rp "  Choose [1-7]: " cc
    case $cc in
        1) max_conn=1  ;; 2) max_conn=2  ;; 3) max_conn=3 ;;
        4) max_conn=5  ;; 5) max_conn=10 ;; 6) max_conn=0 ;;
        7) read -rp "  Enter max: " max_conn
           [[ "$max_conn" =~ ^[0-9]+$ ]] || max_conn=0 ;;
        *) max_conn=0 ;;
    esac

    # ── HWID Setting ──────────────────────────────────────────
    echo ""
    echo -e "  ${M}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "  ${M}║             HWID — Device Lock Setting               ║${NC}"
    echo -e "  ${M}╠══════════════════════════════════════════════════════╣${NC}"
    echo -e "  ${M}║${NC}  HWID locks this password to ONE specific device.     ${M}║${NC}"
    echo -e "  ${M}║${NC}  If someone copies this password to another device,   ${M}║${NC}"
    echo -e "  ${M}║${NC}  their connection will be BLOCKED automatically.      ${M}║${NC}"
    echo -e "  ${M}╚══════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${W}HWID Options:${NC}"
    echo "    1) Auto-capture on first connect (recommended)"
    echo "       → User connects once, their device IP is locked automatically"
    echo "    2) Set manually now"
    echo "       → Enter the user's device IP address right now"
    echo "    3) No HWID lock (not recommended)"
    echo "       → Anyone with the password can connect from any device"
    echo ""
    read -rp "  Choose [1-3]: " hc

    local hwid="none"
    local hwid_locked="0"
    local hwid_note=""

    case $hc in
        1)
            hwid="none"
            hwid_locked="0"
            hwid_note="Auto-capture on first connect"
            ;;
        2)
            read -rp "  Enter device IP (e.g. 197.251.240.5): " hwid_input
            hwid_input=$(echo "$hwid_input" | tr -d ' ')
            if [[ "$hwid_input" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
                hwid="$hwid_input"
                hwid_locked="1"
                hwid_note="Manually locked to ${hwid}"
            else
                echo -e "  ${Y}  Invalid IP — defaulting to auto-capture.${NC}"
                hwid="none"
                hwid_locked="0"
                hwid_note="Auto-capture on first connect (fallback)"
            fi
            ;;
        3)
            hwid="none"
            hwid_locked="0"
            hwid_note="${R}No HWID lock${NC}"
            ;;
        *)
            hwid="none"
            hwid_locked="0"
            hwid_note="Auto-capture on first connect (default)"
            ;;
    esac

    # Save to DB
    echo "${username}:${password}:${expiry}:0:${max_conn}:${hwid}:${hwid_locked}" >> "$USERS_DB"
    rebuild_config
    apply_all_rules
    systemctl restart "$SVC" 2>/dev/null

    local server_ip; server_ip=$(get_ip)
    local cl; [[ "$max_conn" -eq 0 ]] && cl="Unlimited" || cl="${max_conn} device(s)"

    echo ""
    echo -e "${G}  ✓ User '${username}' added!${NC}"
    echo ""
    echo -e "${C}  ╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${C}  ║${W}          ZIVPN App Configuration                   ${C}║${NC}"
    echo -e "${C}  ╠══════════════════════════════════════════════════════╣${NC}"
    echo -e "${C}  ║${NC}  UDP Server   :  ${Y}${server_ip}${NC}"
    echo -e "${C}  ║${NC}  UDP Password :  ${Y}${password}${NC}  ${G}← enter in ZIVPN app${NC}"
    echo -e "${C}  ║${NC}  Expiry       :  ${Y}${expiry}${NC}"
    echo -e "${C}  ║${NC}  Max Devices  :  ${Y}${cl}${NC}"
    echo -e "${C}  ╠══════════════════════════════════════════════════════╣${NC}"
    echo -e "${C}  ║${W}          HWID Device Lock                          ${C}║${NC}"
    echo -e "${C}  ╠══════════════════════════════════════════════════════╣${NC}"
    echo -e "${C}  ║${NC}  Mode   :  ${M}${hwid_note}${NC}"
    if [[ "$hwid_locked" == "1" ]]; then
        echo -e "${C}  ║${NC}  Status :  ${M}LOCKED to ${hwid}${NC}"
    else
        echo -e "${C}  ║${NC}  Status :  ${Y}Unlocked — will lock on first connection${NC}"
    fi
    echo -e "${C}  ╚══════════════════════════════════════════════════════╝${NC}"
}

# ══════════════════════════════════════════════════════════════
#  7) REMOVE USER
# ══════════════════════════════════════════════════════════════
remove_user() {
    echo -e "${C}═══ Remove User ═════════════════════════════════════════════${NC}"
    list_users; [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to remove: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
        || { echo -e "${R}  User not found.${NC}"; return; }
    read -rp "  Confirm remove '${username}'? [y/N]: " c
    [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
    local pass; pass=$(grep "^${username}:" "$USERS_DB" | cut -d: -f2)
    sed -i "/^${username}:/d" "$USERS_DB"
    rm -f "${SESSIONS_DIR}/${pass}.sessions" 2>/dev/null
    rebuild_config; apply_all_rules
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  User '${username}' removed.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  8) RENEW USER
# ══════════════════════════════════════════════════════════════
renew_user() {
    echo -e "${C}═══ Renew / Extend User ═════════════════════════════════════${NC}"
    list_users; [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to renew: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
        || { echo -e "${R}  User not found.${NC}"; return; }
    echo ""
    echo "    1) 1 month  2) 3 months  3) 6 months  4) 1 year  5) Never  6) Custom"
    read -rp "  Choose [1-6]: " ec
    case $ec in
        1) ne=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) ne=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) ne=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) ne=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) ne="never" ;;
        6) read -rp "  Date (YYYY-MM-DD): " ne
           date -d "$ne" +%Y-%m-%d &>/dev/null || { echo -e "${R}  Invalid.${NC}"; return; } ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac
    # Update only field 3 (expiry), preserve hwid fields 6 & 7
    sed -i "s/^\(${username}:[^:]*\):[^:]*:\([^:]*:[^:]*:[^:]*:[^:]*\)$/\1:${ne}:\2/" "$USERS_DB"
    rebuild_config; systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  '${username}' renewed → ${ne}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  9) CLEANUP EXPIRED
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    echo -e "${C}═══ Cleanup Expired Users ═══════════════════════════════════${NC}"
    local count=0; local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${R}Removing:${NC} ${u} (expired: ${e})"
            rm -f "${SESSIONS_DIR}/${p}.sessions" 2>/dev/null
            count=$((count+1))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}:${hl}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config; apply_all_rules
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Done. Removed ${count} expired user(s).${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) CONNECTION STATS
# ══════════════════════════════════════════════════════════════
conn_stats() {
    echo -e "${C}═══ Connection Stats ════════════════════════════════════════${NC}"
    echo ""
    local total; total=$(count_live_connections)
    echo -e "  Total live connections: ${G}${total}${NC}"
    echo ""
    local ips; ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Connected IPs:${NC}"
        while read -r ip; do
            [[ -z "$ip" ]] && continue
            # Check if this IP matches any registered HWID
            local matched_user="unknown"
            while IFS=':' read -r u p e bw mc hwid hl; do
                [[ "$hwid" == "$ip" ]] && matched_user="$u" && break
            done < "$USERS_DB"
            if [[ "$matched_user" != "unknown" ]]; then
                echo -e "    ${G}→${NC} ${ip}  ${M}(registered: ${matched_user})${NC}"
            else
                echo -e "    ${Y}→${NC} ${ip}  ${Y}(unregistered device)${NC}"
            fi
        done <<< "$ips"
    else
        echo -e "  ${Y}No active connections.${NC}"
    fi
    echo ""
    divider
    printf "  %-16s %-18s %-8s %-8s %-17s %s\n" \
        "USERNAME" "PASSWORD" "CONN LIM" "LIVE" "HWID IP" "HWID STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc="0"
        [[ -z "$hwid" ]] && hwid="none"
        [[ -z "$hl"   ]] && hl="0"
        local lc ldisp hwid_st
        lc=$(ss -u state established 2>/dev/null | grep ":${LISTEN_PORT}" | wc -l)
        [[ "$mc" -eq 0 ]] && ldisp="∞" || ldisp="$mc"
        if [[ "$hl" == "1" && "$hwid" != "none" ]]; then
            hwid_st="${M}LOCKED${NC}"
        elif [[ "$hl" == "0" ]]; then
            hwid_st="${Y}PENDING${NC}"
        else
            hwid_st="${R}UNLOCKED${NC}"
        fi
        if is_expired "$e"; then
            hwid_st="${R}EXPIRED${NC}"
        fi
        local hwid_show="${hwid:0:15}"
        printf "  %-16s %-18s %-8s %-8s %-17s " "$u" "$p" "$ldisp" "$lc" "$hwid_show"
        echo -e "$hwid_st"
    done < "$USERS_DB"
}

# ══════════════════════════════════════════════════════════════
#  11) BANDWIDTH REPORT
# ══════════════════════════════════════════════════════════════
bw_report() {
    echo -e "${C}═══ Bandwidth + Expiry Report ═══════════════════════════════${NC}"
    local iface; iface=$(ip -4 route show default 2>/dev/null | awk 'NR==1{print $5}')
    local rx tx
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    echo -e "\n  Interface : ${Y}${iface}${NC}"
    echo -e "  Total RX  : ${G}$(echo "scale=2; $rx/1048576" | bc) MB${NC}"
    echo -e "  Total TX  : ${G}$(echo "scale=2; $tx/1048576" | bc) MB${NC}\n"
    divider
    [[ ! -s "$USERS_DB" ]] && echo -e "  ${Y}No users.${NC}" && return
    printf "  %-16s %-18s %-11s %-5s %-5s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "CONN" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc" ]] && mc="0"
        local dl st; [[ "$mc" -eq 0 ]] && cd="∞" || cd="$mc"
        if is_expired "$e"; then
            dl="—"; st="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            [[ "$dl" != "∞" && "$dl" -le 3 ]] \
                && st="${Y}EXPIRING SOON${NC}" || st="${G}ACTIVE${NC}"
        fi
        printf "  %-16s %-18s %-11s %-5s %-5s " "$u" "$p" "$e" "$dl" "$cd"
        echo -e "$st"
    done < "$USERS_DB"
}

# ══════════════════════════════════════════════════════════════
