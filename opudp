#!/bin/bash
# ============================================================
#  OPUDP — ZIVPN UDP Ultimate Control Panel
#  Author  : OfficialOnePesewa
#  GitHub  : https://github.com/OfficialOnePesewa/udp-opudp
#  Command : opudp
#  Version : 5.0.0  (True HWID Enforcement — Native Mode)
# ============================================================
#
#  HOW TRUE HWID ENFORCEMENT WORKS:
#  ─────────────────────────────────────────────────────────
#  ZIVPN only supports "passwords" auth mode. We exploit this
#  by making the FULL password = password|HWID combined.
#
#  Example:
#    Admin sets password : abc123
#    Admin sets HWID     : a1b2c3d4e5f6
#    ZIVPN config stores : "abc123|a1b2c3d4e5f6"
#    User types in app   : abc123|a1b2c3d4e5f6
#
#  Result:
#    ✓ Correct password + correct HWID  → ALLOWED
#    ✗ Correct password, no HWID        → DENIED
#    ✗ Correct password, wrong HWID     → DENIED
#    ✗ Wrong password entirely          → DENIED
#
#  No external daemon needed. Works with ALL ZIVPN versions.
#
#  users.db format (v5):
#  username:password:expiry:bandwidth:max_conn:hwid
#
#  NOTE: "password" field is the human-readable part only.
#        The actual ZIVPN password written to config.json is
#        password|hwid  (or just password if hwid=unbound)
# ============================================================

CONFIG="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
PORT_FILE="/etc/zivpn/port_range"
BACKUP_DIR="/etc/zivpn/backups"
SESSIONS_DIR="/etc/zivpn/sessions"
CONN_LOG="/etc/zivpn/connections.log"
SVC="zivpn"
BIN="/usr/local/bin/zivpn"
LISTEN_PORT="5667"
PANEL_VERSION="5.0.0"
HWID_SEP="|"
GITHUB_RAW="https://raw.githubusercontent.com/OfficialOnePesewa/udp-opudp/main"

# ── Colours ──────────────────────────────────────────────────
R='\033[0;31m' ; G='\033[0;32m' ; Y='\033[1;33m'
C='\033[0;36m' ; W='\033[1;37m' ; M='\033[0;35m' ; NC='\033[0m'

# ── Guard ─────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && echo -e "${R}Run as root: sudo opudp${NC}" && exit 1

# ── Init ──────────────────────────────────────────────────────
init() {
    mkdir -p /etc/zivpn "$BACKUP_DIR" "$SESSIONS_DIR"
    [[ ! -f "$USERS_DB"  ]] && touch "$USERS_DB"
    [[ ! -f "$PORT_FILE" ]] && echo "6000:19999" > "$PORT_FILE"
    [[ ! -f "$CONN_LOG"  ]] && touch "$CONN_LOG"
    migrate_db
}

# ── Migrate DB ────────────────────────────────────────────────
migrate_db() {
    local tmp changed=0
    tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0           && changed=1
        [[ -z "$hwid" ]] && hwid="unbound" && changed=1
        echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    [[ $changed -eq 1 ]] && mv "$tmp" "$USERS_DB" || rm -f "$tmp"
}

# ── Helpers ───────────────────────────────────────────────────
get_ip()   { curl -s4 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}'; }
get_port() { cat "$PORT_FILE" 2>/dev/null || echo "6000:19999"; }
today()    { date +%Y-%m-%d; }
pause()    { echo ""; read -rp "  Press Enter to continue..."; }
divider()  { echo -e "${C}──────────────────────────────────────────────────────────────${NC}"; }

is_expired() {
    local exp="$1"
    [[ "$exp" == "never" ]] && return 1
    [[ "$exp" < "$(today)" ]] && return 0
    return 1
}

days_left() {
    local exp="$1"
    [[ "$exp" == "never" ]] && echo "∞" && return
    local now_s exp_s
    now_s=$(date +%s)
    exp_s=$(date -d "$exp" +%s 2>/dev/null) || { echo "?"; return; }
    echo $(( (exp_s - now_s) / 86400 ))
}

count_active() {
    local n=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" || n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

count_hwid_bound() {
    local n=0
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$hwid" != "unbound" && -n "$hwid" ]] && n=$((n+1))
    done < "$USERS_DB"
    echo "$n"
}

count_live_connections() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u | wc -l
}

get_connected_ips() {
    ss -u state established 2>/dev/null | \
        grep ":${LISTEN_PORT}" | \
        awk '{print $5}' | cut -d: -f1 | sort -u
}

# ── Build the actual ZIVPN password string ────────────────────
# If hwid is set → password|hwid
# If hwid is unbound → just password
zivpn_password() {
    local password="$1"
    local hwid="$2"
    if [[ "$hwid" == "unbound" || -z "$hwid" ]]; then
        echo "$password"
    else
        echo "${password}${HWID_SEP}${hwid}"
    fi
}

# ── Rebuild config.json ───────────────────────────────────────
rebuild_config() {
    local pwds=()
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" || -z "$p" ]] && continue
        is_expired "$e" && continue
        local zp
        zp=$(zivpn_password "$p" "$hwid")
        pwds+=("\"${zp}\"")
    done < "$USERS_DB"

    local plist=""
    if [[ ${#pwds[@]} -gt 0 ]]; then
        plist=$(printf '%s,' "${pwds[@]}")
        plist="${plist%,}"
    fi

    cat > "$CONFIG" << EOF
{
  "listen": ":${LISTEN_PORT}",
  "cert": "/etc/zivpn/zivpn.crt",
  "key": "/etc/zivpn/zivpn.key",
  "obfs": "zivpn",
  "auth": {
    "mode": "passwords",
    "config": [${plist}]
  }
}
EOF
}

apply_conn_limits() {
    iptables -L INPUT --line-numbers -n 2>/dev/null | \
        grep "connlimit" | awk '{print $1}' | sort -rn | \
        xargs -I{} iptables -D INPUT {} 2>/dev/null
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        is_expired "$e" && continue
        if [[ "$mc" -gt 0 ]] 2>/dev/null; then
            iptables -A INPUT -p udp --dport "$LISTEN_PORT" \
                -m connlimit --connlimit-above "$mc" --connlimit-mask 32 \
                -j REJECT --reject-with icmp-port-unreachable 2>/dev/null
        fi
    done < "$USERS_DB"
}

# ── Header ─────────────────────────────────────────────────────
show_header() {
    clear
    local svc_st users port ip live hwid_count
    svc_st=$(systemctl is-active "$SVC" 2>/dev/null)
    users=$(count_active)
    port=$(get_port)
    ip=$(get_ip)
    live=$(count_live_connections)
    hwid_count=$(count_hwid_bound)

    echo -e "${C}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${C}║${W}     OPUDP — ZIVPN UDP Control Panel  v${PANEL_VERSION}                 ${C}║${NC}"
    echo -e "${C}║${M}     True HWID Enforcement — Native Password Mode              ${C}║${NC}"
    echo -e "${C}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    printf "  ZIVPN   : "
    [[ "$svc_st" == "active" ]] \
        && echo -e "${G}active${NC}" \
        || echo -e "${R}inactive${NC}"
    echo -e "  Users   : ${G}${users}${NC}   Live: ${G}${live}${NC}   HWID-Locked: ${M}${hwid_count}${NC}"
    echo -e "  IP      : ${C}${ip}${NC}   Ports: ${Y}${port}${NC}"
    echo ""
}

# ── Menu ───────────────────────────────────────────────────────
show_menu() {
    echo -e "  ${G}1)${NC}  Start ZIVPN              ${G}12)${NC} Reset Bandwidth"
    echo -e "  ${G}2)${NC}  Stop ZIVPN               ${G}13)${NC} Speed Test"
    echo -e "  ${G}3)${NC}  Restart ZIVPN            ${G}14)${NC} Live Logs"
    echo -e "  ${G}4)${NC}  Status                   ${G}15)${NC} Backup All Data"
    echo -e "  ${G}5)${NC}  List Users + HWID        ${G}16)${NC} Restore Backup"
    echo -e "  ${G}6)${NC}  Add User                 ${G}17)${NC} Change Port Range"
    echo -e "  ${G}7)${NC}  Remove User              ${G}18)${NC} Auto-Update ZIVPN"
    echo -e "  ${G}8)${NC}  Renew/Extend User        ${G}19)${NC} Set Connection Limit"
    echo -e "  ${G}9)${NC}  Cleanup Expired Users    ${M}20)${NC} ${M}HWID Management${NC}"
    echo -e "  ${G}10)${NC} Connection Stats         ${M}21)${NC} ${M}Client Setup Guide${NC}"
    echo -e "  ${G}11)${NC} Bandwidth Report         ${R}99)${NC} UNINSTALL"
    echo -e "  ${G}0)${NC}  Exit"
    echo ""
    echo -ne "${Y}Choose [0-99] ► ${NC}"
}

# ══════════════════════════════════════════════════════════════
#  1–4) Service controls
# ══════════════════════════════════════════════════════════════
start_svc() {
    systemctl start "$SVC"
    sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}  ZIVPN running.${NC}" \
        || echo -e "${R}  Failed. Check: journalctl -u zivpn -n 20${NC}"
}

stop_svc() {
    systemctl stop "$SVC"
    echo -e "${R}  ZIVPN stopped.${NC}"
}

restart_svc() {
    systemctl restart "$SVC"
    sleep 1
    systemctl is-active --quiet "$SVC" \
        && echo -e "${G}  ZIVPN restarted.${NC}" \
        || echo -e "${R}  Restart failed.${NC}"
}

show_status() {
    echo -e "${C}═══ ZIVPN Status ════════════════════════════════════════════${NC}"
    systemctl status "$SVC" --no-pager -l
    echo ""
    divider
    echo -e "  Config   : ${Y}${CONFIG}${NC}"
    echo -e "  Users DB : ${Y}${USERS_DB}${NC}"
    echo -e "  Conn Log : ${Y}${CONN_LOG}${NC}"
    echo ""
    echo -e "  ${W}Active ZIVPN passwords (including HWID):${NC}"
    grep '"config"' -A 999 "$CONFIG" | grep -o '"[^"]*"' | grep -v '"config"' | \
        sed 's/"//g' | while read -r pw; do
        [[ -z "$pw" || "$pw" == "[" || "$pw" == "]" ]] && continue
        echo -e "    ${Y}${pw}${NC}"
    done
}

# ══════════════════════════════════════════════════════════════
#  5) List Users + HWID
# ══════════════════════════════════════════════════════════════
list_users() {
    echo -e "${C}═══ User List ═══════════════════════════════════════════════${NC}"
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users found. Use option 6 to add one.${NC}"
        return
    fi
    printf "\n  %-16s %-16s %-12s %-6s %-6s %-22s %s\n" \
        "USERNAME" "PASSWORD" "EXPIRY" "DAYS" "CONN" "HWID" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0
        [[ -z "$hwid" ]] && hwid="unbound"
        local dl status conn_display hwid_display
        [[ "$mc" -eq 0 ]] && conn_display="∞" || conn_display="$mc"
        [[ ${#hwid} -gt 20 ]] && hwid_display="${hwid:0:17}..." || hwid_display="$hwid"
        if is_expired "$e"; then
            dl="—"; status="${R}EXPIRED${NC}"
        else
            dl=$(days_left "$e")
            if [[ "$dl" != "∞" && "$dl" -le 3 ]]; then
                status="${Y}EXPIRING${NC}"
            else
                status="${G}ACTIVE${NC}"
            fi
        fi
        [[ "$hwid" == "unbound" ]] \
            && hwid_display="${Y}unbound${NC}" \
            || hwid_display="${M}${hwid_display}${NC}"
        printf "  %-16s %-16s %-12s %-6s %-6s " "$u" "$p" "$e" "$dl" "$conn_display"
        printf "%-22b " "$hwid_display"
        echo -e "$status"
    done < "$USERS_DB"
    echo ""
    echo -e "  ${M}■${NC} HWID locked   ${Y}■${NC} unbound (any device can connect)"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  6) Add User
# ══════════════════════════════════════════════════════════════
add_user() {
    echo -e "${C}═══ Add New User ════════════════════════════════════════════${NC}"
    echo ""

    read -rp "  Username (label only): " username
    username=$(echo "$username" | tr -d ' ')
    [[ -z "$username" ]] && echo -e "${R}  Empty.${NC}" && return

    read -rp "  Password: " password
    password=$(echo "$password" | tr -d ' ')
    [[ -z "$password" ]] && echo -e "${R}  Empty.${NC}" && return
    # Reject pipe — it's our HWID separator
    if [[ "$password" == *"${HWID_SEP}"* ]]; then
        echo -e "${R}  Password cannot contain '|'.${NC}"; return
    fi
    if grep -q ":${password}:" "$USERS_DB" 2>/dev/null; then
        echo -e "${R}  Password '${password}' already in use!${NC}"; return
    fi

    echo ""
    echo -e "  ${W}Expiry:${NC}"
    echo "    1) 1 month   2) 3 months  3) 6 months"
    echo "    4) 1 year    5) Never     6) Custom (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " ec
    case $ec in
        1) expiry=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) expiry=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) expiry=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) expiry=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) expiry="never" ;;
        6) read -rp "  Date (YYYY-MM-DD): " expiry
           date -d "$expiry" +%Y-%m-%d &>/dev/null \
               || { echo -e "${R}  Invalid date.${NC}"; return; } ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac

    echo ""
    echo -e "  ${W}Connection Limit:${NC}"
    echo "    1) 1 device   2) 2   3) 3   4) 5"
    echo "    5) 10         6) Unlimited   7) Custom"
    echo -e "    ${Y}Tip: Use 1 when binding to a specific HWID${NC}"
    read -rp "  Choose [1-7]: " cc
    case $cc in
        1) max_conn=1  ;; 2) max_conn=2  ;; 3) max_conn=3  ;;
        4) max_conn=5  ;; 5) max_conn=10 ;; 6) max_conn=0  ;;
        7) read -rp "  Number: " max_conn
           [[ ! "$max_conn" =~ ^[0-9]+$ ]] && max_conn=0 ;;
        *) max_conn=0 ;;
    esac

    echo ""
    echo -e "  ${M}══ HWID Device Binding ══════════════════════════════════════${NC}"
    echo -e "  ${W}How to get Android ID:${NC}"
    echo -e "    • Settings → About Phone → Android ID"
    echo -e "    • Termux: ${Y}settings get secure android_id${NC}"
    echo -e "    • Dial:   ${Y}*#*#8255#*#*${NC}"
    echo ""
    echo -e "  Enter HWID to lock this account to one device,"
    echo -e "  or press Enter to skip (any device can connect):"
    read -rp "  HWID: " hwid
    hwid=$(echo "$hwid" | tr -d ' ')
    [[ -z "$hwid" ]] && hwid="unbound"
    if [[ "$hwid" == *"${HWID_SEP}"* ]]; then
        echo -e "${R}  HWID cannot contain '|'.${NC}"; return
    fi
    if [[ "$hwid" != "unbound" ]] && grep -q ":${hwid}$" "$USERS_DB" 2>/dev/null; then
        local dupe; dupe=$(grep ":${hwid}$" "$USERS_DB" | cut -d: -f1 | head -1)
        echo -e "${Y}  Warning: HWID already registered to '${dupe}'.${NC}"
        read -rp "  Continue? [y/N]: " dok
        [[ "$dok" != "y" && "$dok" != "Y" ]] && echo "  Cancelled." && return
    fi

    echo "${username}:${password}:${expiry}:0:${max_conn}:${hwid}" >> "$USERS_DB"
    rebuild_config
    apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null

    local server_ip zp conn_label
    server_ip=$(get_ip)
    zp=$(zivpn_password "$password" "$hwid")
    [[ "$max_conn" -eq 0 ]] && conn_label="∞" || conn_label="${max_conn}"

    echo ""
    echo -e "${G}  ✓ User '${username}' added!${NC}"
    echo ""
    echo -e "${C}  ╔════════════ ZIVPN App Configuration ═════════════════╗${NC}"
    echo -e "${C}  ║${NC}  UDP Server   :  ${Y}${server_ip}${NC}"
    echo -e "${C}  ║${NC}  UDP Password :  ${Y}${zp}${NC}"
    if [[ "$hwid" != "unbound" ]]; then
        echo -e "${C}  ║${NC}               ${M}  ↑ Includes HWID — copy EXACTLY${NC}"
    fi
    echo -e "${C}  ║${NC}  Expiry       :  ${Y}${expiry}${NC}"
    echo -e "${C}  ║${NC}  Max Devices  :  ${Y}${conn_label}${NC}"
    echo -e "${C}  ║${NC}  HWID Locked  :  ${M}${hwid}${NC}"
    echo -e "${C}  ╚══════════════════════════════════════════════════════╝${NC}"
}

# ══════════════════════════════════════════════════════════════
#  7) Remove User
# ══════════════════════════════════════════════════════════════
remove_user() {
    echo -e "${C}═══ Remove User ═════════════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    echo -e "  Enter username to remove all entries,"
    echo -e "  or username:password for a specific device entry."
    read -rp "  Input: " input
    input=$(echo "$input" | tr -d ' ')
    [[ -z "$input" ]] && echo "  Cancelled." && return

    if [[ "$input" == *:* ]]; then
        local un tp
        un=$(echo "$input" | cut -d: -f1)
        tp=$(echo "$input" | cut -d: -f2)
        grep -q "^${un}:${tp}:" "$USERS_DB" \
            || { echo -e "${R}  Entry not found.${NC}"; return; }
        read -rp "  Remove this device entry? [y/N]: " c
        [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
        sed -i "/^${un}:${tp}:/d" "$USERS_DB"
        echo -e "${G}  Device entry removed.${NC}"
    else
        grep -q "^${input}:" "$USERS_DB" \
            || { echo -e "${R}  User not found.${NC}"; return; }
        local cnt; cnt=$(grep -c "^${input}:" "$USERS_DB")
        read -rp "  Remove ALL ${cnt} entries for '${input}'? [y/N]: " c
        [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && return
        sed -i "/^${input}:/d" "$USERS_DB"
        echo -e "${G}  All entries for '${input}' removed.${NC}"
    fi
    rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
}

# ══════════════════════════════════════════════════════════════
#  8) Renew / Extend User
# ══════════════════════════════════════════════════════════════
renew_user() {
    echo -e "${C}═══ Renew / Extend User ═════════════════════════════════════${NC}"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username to renew (all devices): " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" || { echo -e "${R}  Not found.${NC}"; return; }
    echo ""
    echo -e "  ${W}New Expiry:${NC}"
    echo "    1) 1 month   2) 3 months  3) 6 months"
    echo "    4) 1 year    5) Never     6) Custom (YYYY-MM-DD)"
    read -rp "  Choose [1-6]: " ec
    case $ec in
        1) ne=$(date -d "+1 month"  +%Y-%m-%d) ;;
        2) ne=$(date -d "+3 months" +%Y-%m-%d) ;;
        3) ne=$(date -d "+6 months" +%Y-%m-%d) ;;
        4) ne=$(date -d "+1 year"   +%Y-%m-%d) ;;
        5) ne="never" ;;
        6) read -rp "  Date: " ne
           date -d "$ne" +%Y-%m-%d &>/dev/null \
               || { echo -e "${R}  Invalid.${NC}"; return; } ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac
    local tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ "$u" == "$username" ]] \
            && echo "${u}:${p}:${ne}:${bw}:${mc}:${hwid}" >> "$tmp" \
            || echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  '${username}' renewed → ${ne}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  9) Cleanup Expired
# ══════════════════════════════════════════════════════════════
cleanup_expired() {
    echo -e "${C}═══ Cleanup Expired Users ═══════════════════════════════════${NC}"
    local count=0 tmp; tmp=$(mktemp)
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        if is_expired "$e"; then
            echo -e "  ${R}Removing:${NC} ${u} [hwid:${hwid}] expired ${e}"
            count=$((count+1))
        else
            echo "${u}:${p}:${e}:${bw}:${mc}:${hwid}" >> "$tmp"
        fi
    done < "$USERS_DB"
    mv "$tmp" "$USERS_DB"
    rebuild_config; apply_conn_limits
    systemctl restart "$SVC" 2>/dev/null
    echo -e "${G}  Removed ${count} expired entry/entries.${NC}"
}

# ══════════════════════════════════════════════════════════════
#  10) Connection Stats
# ══════════════════════════════════════════════════════════════
conn_stats() {
    echo -e "${C}═══ Connection Stats ════════════════════════════════════════${NC}"
    echo ""
    echo -e "  Live connections : ${G}$(count_live_connections)${NC}"
    echo ""
    local ips; ips=$(get_connected_ips)
    if [[ -n "$ips" ]]; then
        echo -e "  ${W}Connected IPs:${NC}"
        while read -r ip; do [[ -n "$ip" ]] && echo -e "    ${G}→${NC} $ip"; done <<< "$ips"
    else
        echo -e "  ${Y}No active connections.${NC}"
    fi
    echo ""
    divider
    printf "\n  %-16s %-16s %-6s %-22s %s\n" \
        "USERNAME" "PASSWORD" "CONN" "HWID" "STATUS"
    divider
    while IFS=':' read -r u p e bw mc hwid; do
        [[ -z "$u" ]] && continue
        [[ -z "$mc"   ]] && mc=0
        [[ -z "$hwid" ]] && hwid="unbound"
        local cd hs cs
        [[ "$mc" -eq 0 ]] && cd="∞" || cd="$mc"
        [[ ${#hwid} -gt 20 ]] && hs="${hwid:0:17}..." || hs="$hwid"
        is_expired "$e" && cs="${R}EXPIRED${NC}" || cs="${G}ACTIVE${NC}"
        printf "  %-16s %-16s %-6s %-22s " "$u" "$p" "$cd" "$hs"
        echo -e "$cs"
    done < "$USERS_DB"
    echo ""
}

# ══════════════════════════════════════════════════════════════
#  11) Bandwidth Report
# ══════════════════════════════════════════════════════════════
bw_report() {
    echo -e "${C}═══ Bandwidth Report ════════════════════════════════════════${NC}"
    local iface; iface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)
    local rx tx
    rx=$(cat /sys/class/net/"$iface"/statistics/rx_bytes 2>/dev/null || echo 0)
    tx=$(cat /sys/class/net/"$iface"/statistics/tx_bytes 2>/dev/null || echo 0)
    echo -e "  RX : ${G}$(echo "scale=2; $rx/1048576" | bc) MB${NC}"
    echo -e "  TX : ${G}$(echo "scale=2; $tx/1048576" | bc) MB${NC}"
    echo -e "  IF : ${Y}${iface}${NC}"
    echo ""
    list_users
}

# ══════════════════════════════════════════════════════════════
