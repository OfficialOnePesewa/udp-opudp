        echo -e "${G}  ✓ ZIVPN updated.${NC}"
    } || {
        rm -f "${BIN}.new"; systemctl start "$SVC"
        echo -e "${FR}  Download failed.${NC}"
    }
    echo ""
    echo -e "  ${YW}Updating OPUDP panel...${NC}"
    wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new && {
        chmod +x /usr/local/bin/opudp.new
        mv /usr/local/bin/opudp.new /usr/local/bin/opudp
        install_bwmon
        echo -e "${G}  ✓ Panel updated. Re-run 'opudp'.${NC}"
    } || {
        rm -f /usr/local/bin/opudp.new
        echo -e "${YW}  Panel update skipped.${NC}"
    }
}

# ══════════════════════════════════════════════════════════════
#  19) Set Connection Limit
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    fire_header "Set Connection Limit"
    list_users
    [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null || { echo -e "${FR}Not found.${NC}"; return; }
    echo "    1)1  2)2  3)3  4)5  5)10  6)Unlimited  7)Custom"
    read -rp "  Choose [1-7]: " cc
    local nl
    case $cc in
        1)nl=1;;2)nl=2;;3)nl=3;;4)nl=5;;5)nl=10;;6)nl=0;;
        7) read -rp "  Number: " nl; [[ ! "$nl" =~ ^[0-9]+$ ]] && nl=0 ;;
        *) echo -e "${FR}Invalid.${NC}"; return ;;
    esac
    sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*\):[^:]*:\([^:]*\)$/\1:${nl}:\2/" "$USERS_DB"
    apply_conn_limits
    local lbl; [[ $nl -eq 0 ]] && lbl="Unlimited" || lbl="${nl} device(s)"
    echo -e "${G}  ✓ '${username}' → ${GO}${lbl}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  99) Uninstall
# ══════════════════════════════════════════════════════════════
uninstall() {
    fire_header "⚠ UNINSTALL — DANGER"
    echo -e "${FR}  Removes everything: ZIVPN, OPUDP, all data, cron, rules${NC}"
    echo ""
    read -rp "  Type 'yes' to confirm: " c
    [[ "$c" != "yes" ]] && echo "  Cancelled." && return
    local iface port ps pe
    iface=$(ip -4 route ls|grep default|grep -Po '(?<=dev )(\S+)'|head -1)
    port=$(get_port); ps=$(echo "$port"|cut -d: -f1); pe=$(echo "$port"|cut -d: -f2)
    systemctl stop    "$SVC" 2>/dev/null
    systemctl disable "$SVC" 2>/dev/null
    rm -f /etc/systemd/system/zivpn.service
    systemctl daemon-reload 2>/dev/null
    rm -f "$BIN" "$BWMON_SCRIPT" "$BWMON_CRON"
    iptables -D INPUT  -j ZIVPN_BW 2>/dev/null
    iptables -D OUTPUT -j ZIVPN_BW 2>/dev/null
    iptables -F ZIVPN_BW           2>/dev/null
    iptables -X ZIVPN_BW           2>/dev/null
    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    iptables -L INPUT --line-numbers -n 2>/dev/null | grep "connlimit" | \
        awk '{print $1}' | sort -rn | xargs -I{} iptables -D INPUT {} 2>/dev/null
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${ps}:${pe}/udp"    2>/dev/null
    ufw delete allow "${LISTEN_PORT}/udp" 2>/dev/null
    rm -rf /etc/zivpn
    rm -f /usr/local/bin/opudp
    echo ""; echo -e "${G}  ✓ Fully removed.${NC}"; exit 0
}

