    systemctl stop "$SVC" 2>/dev/null
    local BIN_URL="https://github.com/zahidbd2/udp-zivpn/releases/latest/download/udp-zivpn-linux-amd64"
    wget -q "$BIN_URL" -O "${BIN}.new" 2>/dev/null \
        && chmod +x "${BIN}.new" && mv "${BIN}.new" "$BIN" \
        && echo -e "${G}  ZIVPN binary updated.${NC}" \
        || { rm -f "${BIN}.new"; echo -e "${Y}  Binary update skipped.${NC}"; }
    systemctl start "$SVC"
    wget -q "${GITHUB_RAW}/opudp" -O /usr/local/bin/opudp.new 2>/dev/null \
        && chmod +x /usr/local/bin/opudp.new \
        && mv /usr/local/bin/opudp.new /usr/local/bin/opudp \
        && echo -e "${G}  Panel updated. Re-run: opudp${NC}" \
        || { rm -f /usr/local/bin/opudp.new; echo -e "${Y}  Panel update skipped.${NC}"; }
}

# ══════════════════════════════════════════════════════════════
#  19) SET CONNECTION LIMIT
# ══════════════════════════════════════════════════════════════
set_conn_limit() {
    echo -e "${C}═══ Set Connection Limit ════════════════════════════════════${NC}"
    list_users; [[ ! -s "$USERS_DB" ]] && return
    read -rp "  Username: " username
    username=$(echo "$username" | tr -d ' ')
    grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
        || { echo -e "${R}  Not found.${NC}"; return; }
    local cur; cur=$(grep "^${username}:" "$USERS_DB" | cut -d: -f5)
    [[ "$cur" -eq 0 ]] \
        && echo -e "  Current: ${G}Unlimited${NC}" \
        || echo -e "  Current: ${Y}${cur} device(s)${NC}"
    echo ""
    echo "    1) 1  2) 2  3) 3  4) 5  5) 10  6) Unlimited  7) Custom"
    read -rp "  Choose [1-7]: " cc
    case $cc in
        1) nl=1  ;; 2) nl=2  ;; 3) nl=3  ;;
        4) nl=5  ;; 5) nl=10 ;; 6) nl=0  ;;
        7) read -rp "  Max: " nl
           [[ "$nl" =~ ^[0-9]+$ ]] || nl=0 ;;
        *) echo -e "${R}  Invalid.${NC}"; return ;;
    esac
    # Update field 5 only — preserve hwid fields 6 & 7
    sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*\):[^:]*:\([^:]*:[^:]*\)$/\1:${nl}:\2/" "$USERS_DB"
    apply_all_rules
    local lbl; [[ "$nl" -eq 0 ]] && lbl="Unlimited" || lbl="${nl} device(s)"
    echo -e "${G}  '${username}' limit → ${lbl}${NC}"
}

# ══════════════════════════════════════════════════════════════
#  20) HWID — VIEW ALL  ← NEW
# ══════════════════════════════════════════════════════════════
hwid_view_all() {
    echo -e "${M}═══ HWID Device Lock — All Users ════════════════════════════${NC}"
    echo ""
    if [[ ! -s "$USERS_DB" ]]; then
        echo -e "  ${Y}No users found.${NC}"; return
    fi

    local locked=0 pending=0 unlocked=0

    printf "  %-16s %-18s %-19s %s\n" "USERNAME" "PASSWORD" "REGISTERED DEVICE IP" "HWID STATUS"
    divider

    while IFS=':' read -r u p e bw mc hwid hl; do
        [[ -z "$u" ]] && continue
        [[ -z "$hwid" ]] && hwid="none"
        [[ -z "$hl"   ]] && hl="0"

        local st_label ip_display
        if [[ "$hl" == "1" && "$hwid" != "none" ]]; then
            st_label="${M}● LOCKED${NC}"
            ip_display="${M}${hwid}${NC}"
            locked=$((locked+1))
        elif [[ "$hl" == "0" && "$hwid" == "none" ]]; then
            st_label="${Y}○ PENDING 1ST CONNECT${NC}"
            ip_display="${Y}awaiting...${NC}"
            pending=$((pending+1))
        else
            st_label="${R}○ NO LOCK${NC}"
            ip_display="${R}none${NC}"
            unlocked=$((unlocked+1))
        fi

        printf "  %-16s %-18s " "$u" "$p"
        echo -e "${ip_display}        ${st_label}"

    done < "$USERS_DB"

    echo ""
    divider
    echo -e "  ${M}Locked${NC}  : ${M}${locked}${NC} user(s) — device IP registered and enforced"
    echo -e "  ${Y}Pending${NC} : ${Y}${pending}${NC} user(s) — will lock on first connection"
    echo -e "  ${R}No Lock${NC} : ${R}${unlocked}${NC} user(s) — any device can connect"
    echo ""
    echo -e "  ${W}Tip:${NC} Use option ${M}21${NC} to manually set or reset a user's HWID."
}

# ══════════════════════════════════════════════════════════════
#  21) HWID — SET / RESET  ← NEW
# ══════════════════════════════════════════════════════════════
hwid_manage() {
    while true; do
        echo -e "${M}═══ HWID — Set / Reset Device Lock ══════════════════════════${NC}"
        echo ""
        echo -e "  ${M}a)${NC} Lock user to a specific IP now"
        echo -e "  ${M}b)${NC} Reset HWID (allow device change)"
        echo -e "  ${M}c)${NC} Remove HWID lock completely (no lock)"
        echo -e "  ${M}d)${NC} Force re-lock from current live connection"
        echo -e "  ${M}0)${NC} Back"
        echo ""
        echo -ne "${M}Choose: ${NC}"
        read -r sub; echo ""

        case $sub in
            # ── a) Lock to IP ─────────────────────────────────
            a)
                list_users; [[ ! -s "$USERS_DB" ]] && continue
                read -rp "  Username to lock: " username
                username=$(echo "$username" | tr -d ' ')
                grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
                    || { echo -e "${R}  User not found.${NC}"; pause; continue; }

                local cur_hwid cur_hl
                cur_hwid=$(grep "^${username}:" "$USERS_DB" | cut -d: -f6)
                cur_hl=$(grep "^${username}:"   "$USERS_DB" | cut -d: -f7)

                if [[ "$cur_hl" == "1" && "$cur_hwid" != "none" ]]; then
                    echo -e "  ${Y}Currently locked to: ${M}${cur_hwid}${NC}"
                    read -rp "  Override with new IP? [y/N]: " ov
                    [[ "$ov" != "y" && "$ov" != "Y" ]] && continue
                fi

                read -rp "  Enter device IP to lock to: " new_hwid
                new_hwid=$(echo "$new_hwid" | tr -d ' ')
                if ! [[ "$new_hwid" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
                    echo -e "${R}  Invalid IP address.${NC}"; pause; continue
                fi

                # Update fields 6 (hwid) and 7 (hwid_locked)
                sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:${new_hwid}:1/" \
                    "$USERS_DB"
                apply_all_rules
                echo -e "${G}  '${username}' locked to device IP: ${M}${new_hwid}${NC}"
                echo -e "${Y}  Only this IP can now connect with ${username}'s password.${NC}"
                ;;

            # ── b) Reset HWID — allows device change ──────────
            b)
                list_users; [[ ! -s "$USERS_DB" ]] && continue
                read -rp "  Username to reset HWID: " username
                username=$(echo "$username" | tr -d ' ')
                grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
                    || { echo -e "${R}  User not found.${NC}"; pause; continue; }

                local old_hwid
                old_hwid=$(grep "^${username}:" "$USERS_DB" | cut -d: -f6)

                echo ""
                echo -e "  ${Y}⚠  This will UNLOCK '${username}' from device IP: ${M}${old_hwid}${NC}"
                echo -e "  ${Y}   Their next connection will become the new registered device.${NC}"
                read -rp "  Confirm reset? [y/N]: " c
                [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && continue

                # Set hwid=none, hwid_locked=0 — auto-capture on next connect
                sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:none:0/" \
                    "$USERS_DB"
                apply_all_rules
                echo -e "${G}  HWID reset. '${username}' will re-lock on next connection.${NC}"
                echo -e "${G}  Old locked IP: ${R}${old_hwid}${G} — now cleared.${NC}"
                ;;

            # ── c) Remove lock completely ──────────────────────
            c)
                list_users; [[ ! -s "$USERS_DB" ]] && continue
                read -rp "  Username to remove lock: " username
                username=$(echo "$username" | tr -d ' ')
                grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
                    || { echo -e "${R}  User not found.${NC}"; pause; continue; }
                echo -e "  ${R}⚠  This permanently removes HWID protection for '${username}'.${NC}"
                echo -e "  ${R}   ANY device can connect with their password.${NC}"
                read -rp "  Confirm? [y/N]: " c
                [[ "$c" != "y" && "$c" != "Y" ]] && echo "  Cancelled." && continue
                sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:none:0/" \
                    "$USERS_DB"
                apply_all_rules
                echo -e "${G}  HWID lock removed for '${username}'.${NC}"
                ;;

            # ── d) Force lock from live connection ─────────────
            d)
                list_users; [[ ! -s "$USERS_DB" ]] && continue
                read -rp "  Username to force-lock: " username
                username=$(echo "$username" | tr -d ' ')
                grep -q "^${username}:" "$USERS_DB" 2>/dev/null \
                    || { echo -e "${R}  User not found.${NC}"; pause; continue; }

                # Get currently connected IPs
                local live_ips
                live_ips=$(get_connected_ips)
                if [[ -z "$live_ips" ]]; then
                    echo -e "${Y}  No live connections detected right now.${NC}"
                    echo -e "${Y}  Ask the user to connect first, then run this option.${NC}"
                    pause; continue
                fi

                echo ""
                echo -e "  ${W}Currently connected IPs:${NC}"
                local i=1
                declare -a ip_arr=()
                while read -r lip; do
                    [[ -z "$lip" ]] && continue
                    echo -e "    ${G}${i})${NC} ${lip}"
                    ip_arr+=("$lip")
                    i=$((i+1))
                done <<< "$live_ips"

                echo ""
                read -rp "  Select IP number to lock to: " sel
                if ! [[ "$sel" =~ ^[0-9]+$ ]] || \
                   [[ "$sel" -lt 1 || "$sel" -gt "${#ip_arr[@]}" ]]; then
                    echo -e "${R}  Invalid selection.${NC}"; pause; continue
                fi

                local chosen_ip="${ip_arr[$((sel-1))]}"
                sed -i "s/^\(${username}:[^:]*:[^:]*:[^:]*:[^:]*\):[^:]*:[^:]*$/\1:${chosen_ip}:1/" \
                    "$USERS_DB"
                apply_all_rules

                echo -e "${G}  '${username}' force-locked to live IP: ${M}${chosen_ip}${NC}"
                echo -e "${M}  $(now_ts) | FORCE-LOCKED | user=${username} | ip=${chosen_ip}${NC}" \
                    >> "$HWID_LOG"
                ;;

            0) break ;;
            *) echo -e "${R}  Invalid.${NC}" ;;
        esac
        pause
        clear
    done
}

# ══════════════════════════════════════════════════════════════
#  22) HWID — MONITOR LOGS  ← NEW
# ══════════════════════════════════════════════════════════════
hwid_logs() {
    echo -e "${M}═══ HWID Monitor Logs ═══════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${W}Recent HWID events (last 50 lines):${NC}"
    echo ""
    divider

    if [[ ! -s "$HWID_LOG" ]]; then
        echo -e "  ${Y}No HWID events logged yet.${NC}"
        echo -e "  ${Y}Events appear once users start connecting.${NC}"
    else
        tail -50 "$HWID_LOG" | while read -r line; do
            if echo "$line" | grep -q "BLOCKED"; then
                echo -e "  ${R}${line}${NC}"
            elif echo "$line" | grep -q "LOCKED\|FORCE"; then
                echo -e "  ${M}${line}${NC}"
            elif echo "$line" | grep -q "OK\|CAPTURE"; then
                echo -e "  ${G}${line}${NC}"
            else
                echo -e "  ${C}${line}${NC}"
            fi
        done
    fi

    echo ""
    divider
    echo ""
    echo -e "  ${W}Live monitor status:${NC}"
    systemctl is-active --quiet opudp-hwid-monitor \
        && echo -e "  ${G}● HWID Monitor is running${NC}" \
        || echo -e "  ${R}● HWID Monitor is stopped${NC}"

    echo ""
    echo -e "  ${W}Options:${NC}"
    echo -e "  ${M}r)${NC} Restart HWID monitor"
    echo -e "  ${M}c)${NC} Clear HWID log"
    echo -e "  ${M}l)${NC} Watch live (tail -f)"
    echo -e "  ${M}0)${NC} Back"
    echo ""
    echo -ne "${M}Choose: ${NC}"
    read -r lsub
    case $lsub in
        r)
            systemctl restart opudp-hwid-monitor
            echo -e "${G}  HWID Monitor restarted.${NC}"
            ;;
        c)
            read -rp "  Clear all HWID logs? [y/N]: " c
            [[ "$c" == "y" || "$c" == "Y" ]] \
                && > "$HWID_LOG" \
                && echo -e "${G}  Log cleared.${NC}" \
                || echo "  Cancelled."
            ;;
        l)
            echo -e "${C}  Watching live HWID log — Ctrl+C to stop${NC}"
            tail -f "$HWID_LOG"
            ;;
    esac
}

# ══════════════════════════════════════════════════════════════
#  99) UNINSTALL
# ══════════════════════════════════════════════════════════════
uninstall() {
    echo -e "${R}═══ UNINSTALL (DANGER) ══════════════════════════════════════${NC}"
    echo ""
    echo -e "${R}  Removes: ZIVPN, OPUDP, HWID monitor, all data${NC}"
    echo ""
    read -rp "  Type 'yes' to confirm: " confirm
    [[ "$confirm" != "yes" ]] && echo "  Cancelled." && return

    local iface port ps pe
    iface=$(ip -4 route show default 2>/dev/null | awk 'NR==1{print $5}')
    port=$(get_port); ps=$(echo "$port"|cut -d:-f1); pe=$(echo "$port"|cut -d:-f2)

    systemctl stop    "$SVC" opudp-hwid-monitor 2>/dev/null
    systemctl disable "$SVC" opudp-hwid-monitor 2>/dev/null
    rm -f /etc/systemd/system/zivpn.service
    rm -f /etc/systemd/system/opudp-hwid-monitor.service
    systemctl daemon-reload 2>/dev/null

    rm -f "$BIN" /usr/local/bin/opudp /usr/local/bin/opudp-hwid-monitor

    iptables -t nat -D PREROUTING -i "$iface" -p udp \
        --dport "${ps}:${pe}" -j DNAT --to-destination ":${LISTEN_PORT}" 2>/dev/null
    while iptables -L INPUT -n --line-numbers 2>/dev/null | grep -q "opudp"; do
        local ln
        ln=$(iptables -L INPUT -n --line-numbers 2>/dev/null | grep "opudp" | head -1 | awk '{print $1}')
        [[ -z "$ln" ]] && break
        iptables -D INPUT "$ln" 2>/dev/null
    done
    iptables-save > /etc/iptables/rules.v4 2>/dev/null
    ufw delete allow "${ps}:${pe}/udp"    2>/dev/null
    ufw delete allow "${LISTEN_PORT}/udp" 2>/dev/null

    rm -rf /etc/zivpn /etc/sysctl.d/99-opudp.conf
    rm -f /etc/network/if-pre-up.d/opudp-iptables

    echo -e "\n${G}  Fully removed.${NC}"
    exit 0
}

